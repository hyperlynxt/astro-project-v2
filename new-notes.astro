---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const notes = await getCollection('notes');
notes.sort((a, b) => {
  const ratingA = a.data.rating || 0;
  const ratingB = b.data.rating || 0;
  if (ratingB !== ratingA) return ratingB - ratingA;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlas Field Notes — Notes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@400;500;600;700&family=Reenie+Beanie&display=swap" rel="stylesheet">
    <style>
        /* ── Reset ── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        /* ── Variables ── */
        :root {
            --accent:       #9B7CC8;
            --accent-light: #C4A8E8;
            --accent-pale:  #EDE6F8;
            --accent-dark:  #7A5BA8;
            --ink:          #2A2724;
            --paper:        #FDFCF9;
        }

        /* ── Body ── */
        body {
            background-color: #FDFCF9;
            background-image:
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png");
            background-position: 0px 0px, 40px 60px, 80px 20px;
            background-repeat: repeat;
            color: var(--ink);
            min-height: 100vh;
            font-family: 'EB Garamond', serif;
        }

        /* ── Grid ── */
        .notes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.75rem;
            max-width: 1200px;
            margin: 0 auto;
            padding: 3rem 2rem 8rem;
            align-items: start;
        }

        /* ── Card ── */
        .note-card {
            cursor: pointer;
            background-color: #fff;
            border-radius: 24px;
            padding: 2.2rem 2.2rem 1.8rem;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(42,39,35,0.10);
            box-shadow: 0 2px 12px rgba(42,39,35,0.06);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            min-height: 260px;
        }
        .note-card:hover {
            background: #F8F4FD;
            border-color: #C4A8E8;
            transform: translateY(-4px);
            box-shadow: 0 14px 28px -10px rgba(155,124,200,0.18);
        }
        .note-card:hover .card-title { color: var(--accent); }

        .card-expand {
            position: absolute; top: 1.1rem; right: 1.1rem;
            opacity: 0; transform: scale(0.85);
            transition: opacity 0.25s ease, transform 0.25s ease;
            color: rgba(42,39,35,0.28); font-size: 0.75rem;
        }
        .note-card:hover .card-expand { opacity: 1; transform: scale(1); }

        .card-draft-icon { color: var(--accent); margin-bottom: 1rem; flex-shrink: 0; }

        .card-title {
            font-family: 'EB Garamond', serif;
            font-size: 1.45rem;
            font-weight: 500;
            line-height: 1.3;
            color: var(--ink);
            margin-bottom: 0.65rem;
            transition: color 0.3s ease;
        }
        .card-body {
            font-family: 'EB Garamond', serif;
            font-size: 1.01rem;
            line-height: 1.65;
            color: rgba(42,39,35,0.50);
            flex-grow: 1;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
        }

        .card-footer {
            margin-top: 1.4rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(42,39,35,0.06);
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 0.75rem;
            flex-wrap: wrap;
        }
        .card-tag {
            background: var(--accent-pale);
            color: var(--accent);
            font-family: 'Inter', sans-serif;
            font-size: 9px; font-weight: 700;
            letter-spacing: 0.1em; text-transform: uppercase;
            padding: 4px 10px; border-radius: 6px;
        }
        .card-tag-neutral {
            background: rgba(42,39,35,0.05);
            color: rgba(42,39,35,0.50);
            font-family: 'Inter', sans-serif;
            font-size: 9px; font-weight: 700;
            letter-spacing: 0.1em; text-transform: uppercase;
            padding: 4px 10px; border-radius: 6px;
        }
        .card-status-raw    { background: #FFF3E0; color: #B06A00; }
        .card-status-refine { background: var(--accent-pale); color: var(--accent); }
        .card-status-meta   { background: #E8F5E9; color: #2E7D32; }

        .dot-rating { display: flex; gap: 5px; align-items: center; }
        .dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--accent-pale);
            border: 1.5px solid var(--accent-light);
        }
        .dot.filled { background: var(--accent); border-color: var(--accent); }

        /* ── Animations ── */
        @keyframes cardIn     { from { opacity:0; transform: translateY(28px) scale(0.96); } to { opacity:1; transform:translateY(0) scale(1); } }
        @keyframes textReveal { from { opacity:0; transform: translateY(10px); } to { opacity:1; transform:translateY(0); } }
        @keyframes drawStroke { to { stroke-dashoffset: 0; } }

        .modal-card       { background-color:#FDFCF9; background-image:url("https://www.transparenttextures.com/patterns/natural-paper.png"); animation: cardIn 0.45s cubic-bezier(0.16,1,0.3,1) forwards; }
        .modal-title-text { opacity:0; animation: textReveal 0.6s cubic-bezier(0.16,1,0.3,1) 0.1s forwards; }
        .modal-reveal     { opacity:0; animation: textReveal 0.5s cubic-bezier(0.16,1,0.3,1) 0.28s forwards; }

        /* ─────────────────────────────────────
           NOTE MODAL  (layer 1)
        ───────────────────────────────────── */
        #note-modal {
            position: fixed; inset: 0; z-index: 100;
            display: none;
            align-items: center; justify-content: center;
            padding: 2rem;
            background: rgba(42,39,35,0.32);
            backdrop-filter: blur(9px);
            -webkit-backdrop-filter: blur(9px);
        }

        .note-modal-inner {
            width: 100%; max-width: 760px;
            max-height: 90vh;
            background-color: var(--paper);
            background-image:
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                radial-gradient(circle at 10% 90%, rgba(155,124,200,0.04) 0%, transparent 60%);
            background-position: 0 0, 0 0;
            background-repeat: repeat, no-repeat;
            border-radius: 36px;
            border: 1px solid rgba(255,255,255,0.6);
            box-shadow: 0 40px 100px rgba(155,124,200,0.18);
            overflow: hidden;
            position: relative;
            display: flex;
            flex-direction: column;
        }

        /* scrollable body */
        .note-modal-scroll {
            overflow-y: auto;
            flex: 1;
            padding: 3rem 3.5rem 2.5rem;
        }

        /* close btn */
        .modal-close {
            position: absolute; top: 1.4rem; right: 1.4rem; z-index: 10;
            width: 38px; height: 38px; border-radius: 50%;
            background: rgba(255,255,255,0.85);
            border: 1px solid rgba(42,39,35,0.12);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: rgba(42,39,35,0.45);
            transition: all 0.2s;
        }
        .modal-close:hover { background: var(--accent-pale); color: var(--accent); border-color: var(--accent-light); }
        .modal-close svg { transition: transform 0.3s; }
        .modal-close:hover svg { transform: rotate(90deg); }

        /* bg letter watermark */
        .modal-bg-letter {
            position: absolute; top: 1rem; right: 2rem;
            font-family: 'EB Garamond', serif;
            font-size: 20rem; font-weight: 700;
            color: rgba(42,39,35,0.018);
            line-height: 1; pointer-events: none;
            z-index: 0;
        }

        /* content above watermark */
        .note-modal-scroll > * { position: relative; z-index: 1; }

        /* title block */
        .modal-title-block { margin-bottom: 2rem; }
        .modal-title {
            font-family: 'EB Garamond', serif;
            font-size: 3rem; font-weight: 500;
            line-height: 1.1; color: var(--ink);
            margin-bottom: 0.5rem;
        }
        .modal-date {
            font-family: 'Reenie Beanie', cursive;
            font-size: 1.3rem; color: #A39985;
        }

        .modal-divider {
            width: 100%; height: 1px;
            background: linear-gradient(90deg, rgba(196,168,232,0.4), rgba(196,168,232,0.1), transparent);
            margin-bottom: 2rem;
        }

        .modal-body-prose {
            font-family: 'EB Garamond', serif;
            font-size: 1.2rem; line-height: 1.85;
            color: rgba(42,39,35,0.82);
            margin-bottom: 2.5rem;
        }

        /* ── Properties button (lives inside modal footer) ── */
        .modal-footer-bar {
            padding: 1rem 2.5rem 1.5rem;
            border-top: 1px solid rgba(155,124,200,0.10);
            display: flex;
            align-items: center;
            justify-content: flex-end;
            background: rgba(253,252,249,0.8);
            backdrop-filter: blur(8px);
            flex-shrink: 0;
        }

        .properties-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-family: 'Inter', sans-serif;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(42,39,35,0.45);
            background: transparent;
            border: 1.5px solid rgba(42,39,35,0.12);
            border-radius: 100px;
            padding: 7px 16px;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .properties-btn:hover {
            color: var(--accent);
            border-color: var(--accent-light);
            background: var(--accent-pale);
        }
        .properties-btn svg { flex-shrink: 0; transition: transform 0.2s; }
        .properties-btn:hover svg { transform: rotate(15deg); }

        /* ─────────────────────────────────────
           PROPERTIES PANEL  (layer 2 — nested)
        ───────────────────────────────────── */
        #props-overlay {
            position: absolute;
            inset: 0;
            z-index: 20;
            display: flex;
            align-items: flex-end;
            justify-content: stretch;
            background: rgba(42,39,35,0.18);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            border-radius: 36px;
            overflow: hidden;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease;
        }
        #props-overlay.open {
            opacity: 1;
            pointer-events: all;
        }

        .props-panel {
            width: 100%;
            background-color: var(--paper);
            background-image:
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                radial-gradient(circle at 95% 5%, rgba(155,124,200,0.07) 0%, transparent 55%);
            background-position: 0 0, 0 0;
            background-repeat: repeat, no-repeat;
            border-radius: 28px 28px 36px 36px;
            border-top: 1px solid rgba(155,124,200,0.18);
            box-shadow: 0 -12px 48px rgba(42,39,35,0.14);
            transform: translateY(100%);
            transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
            max-height: 82%;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        #props-overlay.open .props-panel {
            transform: translateY(0);
        }

        .props-band {
            height: 4px;
            background: linear-gradient(90deg, var(--accent-light), var(--accent), var(--accent-light));
            opacity: 0.55;
            border-radius: 28px 28px 0 0;
            flex-shrink: 0;
        }

        .props-handle {
            display: flex; justify-content: center;
            padding: 0.9rem 0 0.2rem;
            flex-shrink: 0;
        }
        .props-handle-bar {
            width: 36px; height: 4px;
            background: rgba(42,39,35,0.12);
            border-radius: 2px;
        }

        .props-header {
            padding: 0.5rem 1.8rem 1.1rem;
            display: flex; align-items: center; justify-content: space-between;
            flex-shrink: 0;
        }
        .props-eyebrow {
            font-family: 'Inter', sans-serif;
            font-size: 9px; font-weight: 700;
            letter-spacing: 0.16em; text-transform: uppercase;
            color: rgba(42,39,35,0.28);
            margin-bottom: 0.2rem;
        }
        .props-title {
            font-family: 'EB Garamond', serif;
            font-size: 1.35rem; font-weight: 500;
            color: var(--ink); line-height: 1.2;
        }

        .props-close {
            width: 30px; height: 30px; border-radius: 50%;
            background: rgba(255,255,255,0.9);
            border: 1px solid rgba(42,39,35,0.10);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: rgba(42,39,35,0.38);
            transition: all 0.2s; flex-shrink: 0;
        }
        .props-close:hover { background: var(--accent-pale); color: var(--accent); border-color: var(--accent-light); }

        .props-header-divider {
            height: 1px; margin: 0 1.8rem;
            background: linear-gradient(90deg, rgba(155,124,200,0.2), transparent);
            flex-shrink: 0;
        }

        .props-body {
            overflow-y: auto;
            padding: 1.2rem 1.8rem 2rem;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
        }
        .props-body::-webkit-scrollbar { width: 4px; }
        .props-body::-webkit-scrollbar-thumb { background: rgba(155,124,200,0.2); border-radius: 10px; }

        .prop-row {
            padding: 0.9rem 0.6rem;
            border-bottom: 1px solid rgba(42,39,35,0.05);
            opacity: 0;
            transform: translateY(6px);
            transition: opacity 0.3s ease, transform 0.3s ease;
        }
        .prop-row.full-width { grid-column: 1 / -1; }
        #props-overlay.open .prop-row { opacity: 1; transform: translateY(0); }
        #props-overlay.open .prop-row:nth-child(1)  { transition-delay: 0.08s; }
        #props-overlay.open .prop-row:nth-child(2)  { transition-delay: 0.12s; }
        #props-overlay.open .prop-row:nth-child(3)  { transition-delay: 0.16s; }
        #props-overlay.open .prop-row:nth-child(4)  { transition-delay: 0.20s; }
        #props-overlay.open .prop-row:nth-child(5)  { transition-delay: 0.24s; }
        #props-overlay.open .prop-row:nth-child(6)  { transition-delay: 0.28s; }
        #props-overlay.open .prop-row:nth-child(7)  { transition-delay: 0.32s; }
        #props-overlay.open .prop-row:nth-child(8)  { transition-delay: 0.36s; }
        #props-overlay.open .prop-row:nth-child(9)  { transition-delay: 0.40s; }
        #props-overlay.open .prop-row:nth-child(10) { transition-delay: 0.44s; }

        .prop-label {
            font-family: 'Inter', sans-serif;
            font-size: 8.5px; font-weight: 700;
            letter-spacing: 0.13em; text-transform: uppercase;
            color: rgba(42,39,35,0.30);
            margin-bottom: 0.4rem;
        }
        .prop-value {
            font-family: 'EB Garamond', serif;
            font-size: 1rem; color: rgba(42,39,35,0.78);
            line-height: 1.35;
        }
        .prop-value.italic-accent { color: var(--accent); font-style: italic; }
        .prop-value.handwriting {
            font-family: 'Reenie Beanie', cursive;
            font-size: 1.2rem; color: #A39985; line-height: 1.2;
        }

        .prop-chips { display: flex; flex-wrap: wrap; gap: 5px; }
        .prop-chip {
            font-family: 'Inter', sans-serif;
            font-size: 8.5px; font-weight: 700;
            letter-spacing: 0.09em; text-transform: uppercase;
            padding: 3px 9px; border-radius: 5px;
        }
        .prop-chip-accent   { background: var(--accent-pale); color: var(--accent); }
        .prop-chip-raw      { background: #FFF3E0; color: #B06A00; }
        .prop-chip-meta     { background: #E8F5E9; color: #2E7D32; }
        .prop-chip-neutral  { background: rgba(42,39,35,0.06); color: rgba(42,39,35,0.48); }
        .prop-concept-chip {
            display: inline-block;
            background: rgba(155,124,200,0.08);
            border: 1px solid rgba(155,124,200,0.22);
            color: var(--accent-dark);
            font-family: 'EB Garamond', serif;
            font-size: 0.88rem;
            padding: 4px 11px; border-radius: 9px;
        }

        .prop-pipeline { display: flex; flex-direction: column; gap: 0.4rem; }
        .prop-pipeline-step { display: flex; align-items: center; gap: 0.5rem; }
        .prop-pipeline-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
        .prop-pipeline-label { font-family: 'EB Garamond', serif; font-size: 0.9rem; }

        /* scrollbar (main modal) */
        .note-modal-scroll::-webkit-scrollbar { width: 5px; }
        .note-modal-scroll::-webkit-scrollbar-track { background: transparent; }
        .note-modal-scroll::-webkit-scrollbar-thumb { background: rgba(155,124,200,0.2); border-radius: 10px; }
    </style>
</head>
<body>

    <!-- ─────────────── GRID ─────────────── -->
    <main class="notes-grid" id="notes-grid">
        {notes.map((entry) => {
            const statusClass =
                entry.data.status === 'Raw'    ? 'card-status-raw'    :
                entry.data.status === 'Refine' ? 'card-status-refine' :
                'card-status-meta';

            const dotsHtml = [1,2,3].map(i =>
                `<span class="dot${i <= (entry.data.rating || 0) ? ' filled' : ''}"></span>`
            ).join('');

            const visibleTags = (entry.data.tags || []).slice(0, 2);

            return (
                <article
                    class="note-card"
                    data-title={entry.data.title}
                    data-body={entry.data.body || ''}
                    data-date={entry.data.date}
                    data-status={entry.data.status || ''}
                    data-notetype={entry.data.note_type || ''}
                    data-discipline={entry.data.primary_discipline || ''}
                    data-subdiscipline={entry.data.sub_discipline || ''}
                    data-lens={entry.data.analytical_lens || ''}
                    data-rating={entry.data.rating || 0}
                    data-tags={(entry.data.tags || []).join(',')}
                    data-concepts={Array.isArray(entry.data.concepts_used) ? entry.data.concepts_used.join('||') : (entry.data.concepts_used || '')}
                    data-vocabulary={Array.isArray(entry.data.vocabulary) ? entry.data.vocabulary.join('||') : (entry.data.vocabulary || '')}
                >
                    <span class="card-expand">↗</span>

                    <div class="card-draft-icon">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                        </svg>
                    </div>

                    <h3 class="card-title">{entry.data.title}</h3>
                    <p class="card-body">{entry.data.body || ''}</p>

                    <div class="card-footer">
                        <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
                            <span class={`card-tag ${statusClass}`}>{entry.data.status || 'Raw'}</span>
                            {entry.data.note_type && (
                                <span class="card-tag-neutral">{entry.data.note_type}</span>
                            )}
                            {visibleTags.map(tag => (
                                <span class="card-tag-neutral">{tag}</span>
                            ))}
                        </div>
                        <div class="dot-rating" set:html={dotsHtml}></div>
                    </div>
                </article>
            );
        })}
    </main>

    <!-- ─────────────── NOTE MODAL (layer 1) ─────────────── -->
    <div id="note-modal">
        <div class="note-modal-inner modal-card">

            <!-- bg watermark -->
            <div class="modal-bg-letter" id="modal-bg-letter"></div>

            <!-- close -->
            <button class="modal-close" id="close-note-modal">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>

            <!-- scrollable content -->
            <div class="note-modal-scroll">
                <div class="modal-title-block">
                    <h1 class="modal-title modal-title-text" id="modal-title"></h1>
                    <span class="modal-date" id="modal-date"></span>
                </div>

                <div class="modal-divider"></div>

                <div class="modal-body-prose modal-reveal" id="modal-body"></div>
            </div>

            <!-- Footer with Properties button -->
            <div class="modal-footer-bar">
                <button class="properties-btn" id="open-props-btn">
                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.07 4.93a10 10 0 0 0-14.14 0M4.93 19.07a10 10 0 0 0 14.14 0"/>
                        <path d="M12 2v2M12 20v2M2 12h2M20 12h2"/>
                    </svg>
                    Properties
                </button>
            </div>

            <!-- ─────────────── PROPERTIES PANEL (layer 2) ─────────────── -->
            <div id="props-overlay">
                <div class="props-panel">
                    <div class="props-band"></div>
                    <div class="props-handle"><div class="props-handle-bar"></div></div>

                    <div class="props-header">
                        <div>
                            <p class="props-eyebrow">Note properties</p>
                            <p class="props-title" id="props-title"></p>
                        </div>
                        <button class="props-close" id="close-props-btn">
                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>
                    </div>

                    <div class="props-header-divider"></div>

                    <div class="props-body" id="props-body">
                        <!-- filled by JS -->
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        /* ── Helpers ── */
        function dots(n: number): string {
            return [1,2,3].map(i => `<span class="dot${i<=n?' filled':''}"></span>`).join('');
        }
        function fmtDate(str: string): string {
            if (!str) return '—';
            return new Date(str).toLocaleDateString('en-GB', { day:'numeric', month:'long', year:'numeric' });
        }

        /* ── Note modal ── */
        const noteModal = document.getElementById('note-modal') as HTMLElement;

        document.querySelectorAll<HTMLElement>('.note-card').forEach(card => {
            card.addEventListener('click', () => {
                const d = card.dataset;

                // watermark
                (document.getElementById('modal-bg-letter') as HTMLElement).textContent =
                    (d.title || '')[0].toUpperCase();

                // title
                (document.getElementById('modal-title') as HTMLElement).textContent = d.title || '';

                // date
                (document.getElementById('modal-date') as HTMLElement).textContent = fmtDate(d.date || '');

                // body
                (document.getElementById('modal-body') as HTMLElement).textContent = d.body || '';

                // store data for props panel
                (document.getElementById('open-props-btn') as HTMLElement).dataset.cardData =
                    JSON.stringify(d);

                // reset props panel
                document.getElementById('props-overlay')!.classList.remove('open');

                noteModal.style.display = 'flex';
                document.body.style.overflow = 'hidden';
                (document.querySelector('.note-modal-scroll') as HTMLElement).scrollTop = 0;
            });
        });

        function closeNoteModal() {
            document.getElementById('props-overlay')!.classList.remove('open');
            noteModal.style.display = 'none';
            document.body.style.overflow = '';
        }

        document.getElementById('close-note-modal')!.addEventListener('click', closeNoteModal);
        noteModal.addEventListener('click', e => {
            if (e.target === noteModal) closeNoteModal();
        });

        /* ── Properties panel ── */
        document.getElementById('open-props-btn')!.addEventListener('click', () => {
            const raw = (document.getElementById('open-props-btn') as HTMLElement).dataset.cardData;
            if (!raw) return;
            buildPropsPanel(JSON.parse(raw));
            document.getElementById('props-overlay')!.classList.add('open');
        });

        document.getElementById('close-props-btn')!.addEventListener('click', () => {
            document.getElementById('props-overlay')!.classList.remove('open');
        });

        document.getElementById('props-overlay')!.addEventListener('click', e => {
            if (e.target === document.getElementById('props-overlay')) {
                document.getElementById('props-overlay')!.classList.remove('open');
            }
        });

        function buildPropsPanel(d: Record<string, string>) {
            (document.getElementById('props-title') as HTMLElement).textContent = d.title || '—';

            const body = document.getElementById('props-body') as HTMLElement;
            body.innerHTML = '';

            const pipeline = ['Raw', 'Refine', 'Metastasis / Converted'];
            const statusIdx = pipeline.findIndex(s =>
                s.toLowerCase().includes((d.status || '').toLowerCase())
            );

            const rows: Array<{ label: string; html: string; full?: boolean }> = [
                {
                    label: 'Status',
                    full: true,
                    html: `<div class="prop-pipeline">
                        ${pipeline.map((step, i) => {
                            const isCurrent = i === statusIdx;
                            const isPast    = i < statusIdx;
                            let dotStyle  = 'background:rgba(42,39,35,0.15);';
                            let labelStyle = 'color:rgba(42,39,35,0.35);';
                            if (isCurrent) {
                                if (d.status === 'Raw')
                                    { dotStyle = 'background:#B06A00;'; labelStyle = 'color:#B06A00;font-weight:500;'; }
                                else if (d.status === 'Refine')
                                    { dotStyle = 'background:var(--accent);'; labelStyle = 'color:var(--accent);font-weight:500;'; }
                                else
                                    { dotStyle = 'background:#2E7D32;'; labelStyle = 'color:#2E7D32;font-weight:500;'; }
                            } else if (isPast) {
                                dotStyle = 'background:var(--accent-light);';
                            }
                            return `<div class="prop-pipeline-step">
                                <span class="prop-pipeline-dot" style="${dotStyle}"></span>
                                <span class="prop-pipeline-label" style="${labelStyle}">${step}</span>
                            </div>`;
                        }).join('')}
                    </div>`
                },
                { label: 'Rating', html: `<div class="dot-rating">${dots(parseInt(d.rating) || 0)}</div>` },
                { label: 'Date',   html: `<span class="prop-value handwriting">${fmtDate(d.date)}</span>` },
                ...(d.notetype      ? [{ label: 'Note Type',       html: `<span class="prop-chip prop-chip-neutral">${d.notetype}</span>` }] : []),
                ...(d.discipline    ? [{ label: 'Discipline',       html: `<span class="prop-value">${d.discipline}</span>` }] : []),
                ...(d.subdiscipline ? [{ label: 'Sub-discipline',   html: `<span class="prop-value">${d.subdiscipline}</span>` }] : []),
                ...(d.lens          ? [{ label: 'Analytical Lens',  html: `<span class="prop-value italic-accent">${d.lens}</span>` }] : []),
                ...(d.tags ? [{
                    label: 'Tags', full: true,
                    html: `<div class="prop-chips">${d.tags.split(',').map((t: string) => `<span class="prop-chip prop-chip-neutral">${t.trim()}</span>`).join('')}</div>`
                }] : []),
                ...(d.concepts ? [{
                    label: 'Concepts', full: true,
                    html: `<div class="prop-chips">${d.concepts.split('||').map((c: string) => `<span class="prop-concept-chip">${c.trim()}</span>`).join('')}</div>`
                }] : []),
                ...(d.vocabulary ? [{
                    label: 'Vocabulary', full: true,
                    html: `<div class="prop-chips">${d.vocabulary.split('||').map((v: string) => `<span class="prop-concept-chip" style="font-style:italic;color:var(--accent);">${v.trim()}</span>`).join('')}</div>`
                }] : []),
            ];

            rows.forEach(row => {
                const div = document.createElement('div');
                div.className = 'prop-row' + (row.full ? ' full-width' : '');
                div.innerHTML = `<p class="prop-label">${row.label}</p><div>${row.html}</div>`;
                body.appendChild(div);
            });
        }

        /* ── Escape key ── */
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                if (document.getElementById('props-overlay')!.classList.contains('open')) {
                    document.getElementById('props-overlay')!.classList.remove('open');
                } else {
                    closeNoteModal();
                }
            }
        });
    </script>
</body>
</html>
