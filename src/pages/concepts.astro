                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#2A2724]/15 to-transparent"></div>

                <!-- Tags -->
                <div class="pb-4">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#8B2626]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Filter by Tags</h3>
                        </div>
                        <button id="toggle-all-tags" class="font-sans text-[10px] font-bold uppercase tracking-wider text-[#8B2626]/60 hover:text-[#8B2626] transition-colors">Select All</button>
                    </div>
                    <div id="filter-tags-container" class="flex flex-wrap gap-2"></div>
                </div>
            </div>

            <div class="p-6 border-t border-[#D5CCB6]/15 bg-[#FDFCF9] relative z-10 flex items-center justify-between flex-shrink-0">
                <button id="clear-filter-btn" class="font-['Reenie_Beanie'] text-[1.4rem] font-medium text-[#8B2626] hover:bg-[#8B2626]/10 px-4 py-1.5 rounded-lg transition-all underline underline-offset-4">Clear Filters</button>
                <button id="apply-filter-btn" class="bg-seal hover:bg-[#6D1E1E] text-white px-6 py-3 rounded-xl font-sans text-sm font-medium transition-all shadow-md hover:-translate-y-0.5 flex items-center gap-2">
                    <span>Apply Filters</span>
                    <span id="filter-result-count" class="font-['Reenie_Beanie'] text-lg text-white/80 pt-0.5">-- concepts</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Bottom Bar -->
    <div class="fixed bottom-10 left-0 right-0 flex justify-center pointer-events-none z-50">
        <div class="bg-white/80 backdrop-blur-xl border border-[#E8E2D2] rounded-[24px] shadow-[0_20px_50px_rgba(42,39,36,0.15)] p-2.5 flex items-center pointer-events-auto">
            <div class="flex items-center gap-3 pl-4 pr-3 py-2 group cursor-text" onclick="document.getElementById('concept-search').focus()">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#A39985] group-hover:text-seal transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <input type="text" id="concept-search" placeholder="Search concepts" class="bg-transparent border-none outline-none font-sans text-xs font-bold text-[#2A2724] placeholder:text-[#A39985] w-32 transition-all focus:w-48">
            </div>
            <div class="w-px h-6 bg-[#E8E2D2] mx-1"></div>
            <button id="filter-btn" class="bg-seal hover:bg-seal/90 text-white rounded-xl px-5 py-2.5 text-[11px] uppercase tracking-widest font-sans font-bold transition-colors shadow-sm">Filter & Sort</button>
        </div>
    </div>

    <script>
        // Data and DOM
        const conceptsJSON = JSON.parse(document.getElementById('concepts-data').textContent);
        const searchInput = document.getElementById('concept-search');
        const cards = document.querySelectorAll('.catalog-card');
        const filterModal = document.getElementById('filter-modal');
        const filterResultCount = document.getElementById('filter-result-count');
        const filterSortButtons = document.querySelectorAll('.sort-btn');
        const filterStarButtons = document.querySelectorAll('.star-filter');
        const masonryGrid = document.querySelector('.masonry-grid');
        const filterTagsContainer = document.getElementById('filter-tags-container');
        const filterDisciplinesContainer = document.getElementById('filter-disciplines-container');

        // Attach all button listeners
        document.getElementById('filter-btn').addEventListener('click', openFilterModal);
        document.getElementById('close-filter-btn').addEventListener('click', closeFilterModal);
        document.getElementById('apply-filter-btn').addEventListener('click', applyFilterSystem);
        document.getElementById('clear-filter-btn').addEventListener('click', clearAllFilters);
        // close-modal-btn is now in the shared component

        let currentFilterState = {
            query: '',
            sort: 'most-used',
            sortOrder: 'desc',
            disciplines: ['All'],
            tags: [],
            minUtility: 0
        };

        // Build disciplines
        const availableDisciplines = new Set();
        cards.forEach(card => {
            const disc = card.getAttribute('data-discipline');
            if (disc) disc.split('/').forEach(d => availableDisciplines.add(d.trim()));
        });
        const sortedDisciplines = Array.from(availableDisciplines).sort();

        function renderFilterDisciplines() {
            const allActive = currentFilterState.disciplines.includes('All');
            let html = `<button data-discipline="All" class="disc-filter-btn px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest transition-all ${allActive ? 'bg-[#2A2724] text-white shadow-md' : 'bg-[#F5F2EB] text-[#2A2724]/60 border border-[#D5CCB6]/20 hover:bg-[#E8E2D2]'}">All Disciplines</button>`;
            html += sortedDisciplines.map(disc => {
                const isActive = currentFilterState.disciplines.includes(disc);
                return `<button data-discipline="${disc}" class="disc-filter-btn px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest transition-all ${isActive ? 'bg-[#8B2626] text-white shadow-md' : 'bg-[#FDFCF9] text-[#2A2724]/60 border border-[#D5CCB6]/20 hover:bg-[#F5F2EB]'}">${disc}</button>`;
            }).join('');
            filterDisciplinesContainer.innerHTML = html;
            filterDisciplinesContainer.querySelectorAll('.disc-filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const disc = btn.getAttribute('data-discipline');
                    if (disc === 'All') {
                        currentFilterState.disciplines = ['All'];
                    } else {
                        currentFilterState.disciplines = currentFilterState.disciplines.filter(d => d !== 'All');
                        if (currentFilterState.disciplines.includes(disc)) {
                            currentFilterState.disciplines = currentFilterState.disciplines.filter(d => d !== disc);
                            if (currentFilterState.disciplines.length === 0) currentFilterState.disciplines = ['All'];
                        } else {
                            currentFilterState.disciplines.push(disc);
                        }
                    }
                    renderFilterDisciplines();
                    updateFilterPreview();
                });
            });
        }
        renderFilterDisciplines();

        // Build tags
        const availableTags = new Set();
        cards.forEach(card => {
            const tags = card.getAttribute('data-tags') || '';
            if (tags) tags.split(',').forEach(t => { if(t.trim()) availableTags.add(t.trim()); });
        });
        const sortedTags = Array.from(availableTags).sort();

        function renderFilterTags() {
            filterTagsContainer.innerHTML = sortedTags.map(tag => {
                const isActive = currentFilterState.tags.includes(tag);
                return `<button data-tag="${tag}" class="tag-filter-btn px-3 py-1 rounded-full text-[10px] font-semibold uppercase tracking-widest transition-all ${isActive ? 'bg-[#8B2626] text-white shadow-md' : 'bg-[#8B2626]/10 text-[#8B2626] border border-[#8B2626]/20 hover:bg-[#8B2626]/20'}">${tag}</button>`;
            }).join('');
            document.querySelectorAll('.tag-filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const tag = btn.getAttribute('data-tag');
                    if (currentFilterState.tags.includes(tag)) {
                        currentFilterState.tags = currentFilterState.tags.filter(t => t !== tag);
                    } else {
                        currentFilterState.tags.push(tag);
                    }
                    renderFilterTags();
                    updateFilterPreview();
                });
            });
        }
        renderFilterTags();

        document.getElementById('toggle-all-tags').addEventListener('click', (e) => {
            if (currentFilterState.tags.length === sortedTags.length) {
                currentFilterState.tags = [];
                e.target.textContent = 'Select All';
            } else {
                currentFilterState.tags = [...sortedTags];
                e.target.textContent = 'Clear All';
            }
            renderFilterTags();
            updateFilterPreview();
        });

        filterSortButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                currentFilterState.sort = btn.getAttribute('data-sort');
                filterSortButtons.forEach(b => {
                    b.classList.remove('bg-[#8B2626]', 'text-white', 'shadow-lg', 'border-[#8B2626]');
                    b.classList.add('bg-white', 'text-[#2A2724]/70');
                });
                btn.classList.add('bg-[#8B2626]', 'text-white', 'shadow-lg');
                btn.classList.remove('bg-white', 'text-[#2A2724]/70');
                updateFilterPreview();
            });
        });

        const sortDirectionBtn = document.getElementById('sort-direction-toggle');
        const sortDirectionLabel = document.getElementById('sort-direction-label');
        const sortDirectionIcon = document.getElementById('sort-direction-icon');
        sortDirectionBtn.addEventListener('click', () => {
            currentFilterState.sortOrder = currentFilterState.sortOrder === 'desc' ? 'asc' : 'desc';
            sortDirectionLabel.textContent = currentFilterState.sortOrder === 'desc' ? 'Descending' : 'Ascending';
            sortDirectionIcon.style.transform = currentFilterState.sortOrder === 'desc' ? 'rotate(0deg)' : 'rotate(180deg)';
            updateFilterPreview();
        });

        filterStarButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                const rating = parseInt(btn.getAttribute('data-rating'));
                currentFilterState.minUtility = rating;
                filterStarButtons.forEach((star, index) => {
                    if (index < rating) {
                        star.classList.add('active');
                    } else {
                        star.classList.remove('active');
                    }
                });
                document.getElementById('min-rating-label').textContent = `${rating}+ stars`;
                updateFilterPreview();
            });
        });

        function shouldShowCard(card) {
            const title = card.querySelector('.model-title').textContent.toLowerCase();
            const desc = card.querySelector('p')?.textContent.toLowerCase() || '';
            const tags = card.getAttribute('data-tags') ? card.getAttribute('data-tags').split(',').map(t => t.trim()) : [];
            const stars = parseInt(card.getAttribute('data-rating')) || 0;
            const discipline = card.getAttribute('data-discipline') || '';

            const queryMatch = !currentFilterState.query || title.includes(currentFilterState.query) || desc.includes(currentFilterState.query);
            let discMatch = currentFilterState.disciplines.includes('All');
            if (!discMatch) discMatch = currentFilterState.disciplines.some(d => discipline.includes(d));
            const tagsMatch = currentFilterState.tags.length === 0 || currentFilterState.tags.some(t => tags.includes(t));
            const starsMatch = stars >= currentFilterState.minUtility;

            return queryMatch && discMatch && tagsMatch && starsMatch;
        }

        function updateFilterPreview() {
            let count = 0;
            cards.forEach(card => { if (shouldShowCard(card)) count++; });
            filterResultCount.textContent = `${count} concepts`;
        }

        function openFilterModal() {
            filterModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            const path = filterModal.querySelector('.swoosh-path');
            if (path) { path.style.animation = 'none'; path.offsetHeight; path.style.animation = null; }
            updateFilterPreview();
        }

        function closeFilterModal() {
            filterModal.style.display = 'none';
            document.body.style.overflow = '';
        }

        function applyFilterSystem() {
            cards.forEach(card => { 
                const wrapper = card.closest('.masonry-item-wrapper');
                if (wrapper) wrapper.style.display = shouldShowCard(card) ? 'block' : 'none';
            });
            sortCards();
            closeFilterModal();
            
            // Trigger masonry reflow
            requestAnimationFrame(() => {
                requestAnimationFrame(layoutMasonryConcepts);
            });
        }

        function sortCards() {
            const cardsArray = Array.from(cards);
            const isDesc = currentFilterState.sortOrder === 'desc';
            cardsArray.sort((a, b) => {
                let result = 0;
                if (currentFilterState.sort === 'alphabetical') {
                    result = a.querySelector('.model-title').textContent.trim().localeCompare(b.querySelector('.model-title').textContent.trim());
                } else if (currentFilterState.sort === 'most-used') {
                    result = parseInt(a.getAttribute('data-linked')) - parseInt(b.getAttribute('data-linked'));
                } else if (currentFilterState.sort === 'rating') {
                    result = parseInt(a.getAttribute('data-rating')) - parseInt(b.getAttribute('data-rating'));
                }
                return isDesc ? -result : result;
            });
            
            // Move WRAPPERS, not just cards
            cardsArray.forEach(card => {
                const wrapper = card.closest('.masonry-item-wrapper');
                if (wrapper) masonryGrid.appendChild(wrapper);
            });
        }

        function clearAllFilters() {
            currentFilterState = { query: '', sort: 'most-used', sortOrder: 'desc', disciplines: ['All'], tags: [], minUtility: 0 };
            renderFilterDisciplines();
            renderFilterTags();
            filterStarButtons.forEach(star => { star.classList.remove('active'); });
            document.getElementById('min-rating-label').textContent = '0+ stars';
            searchInput.value = ''; // Clear search input
            applyFilterSystem();
        }

        searchInput.addEventListener('input', (e) => {
            currentFilterState.query = e.target.value.toLowerCase().trim();
            applyFilterSystem();
        });

        // Delegated Card Click Listener
        document.addEventListener('click', e => {
            const card = e.target.closest('.catalog-card');
            if (card) {
                const id = card.getAttribute('data-id');
                const contentEl = document.getElementById(`concept-content-${id}`);
                const bodyHtml = contentEl ? contentEl.innerHTML : '';
                
                if (window.openConceptModal) {
                    window.openConceptModal(id, conceptsJSON, bodyHtml);
                } else {
                    console.warn('openConceptModal not ready, retrying...');
                    setTimeout(() => window.openConceptModal && window.openConceptModal(id, conceptsJSON, bodyHtml), 100);
                }
            }
        });

        // Shared modal escape handler helper
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeFilterModal();
        });

        function layoutMasonryConcepts() {
            const grid = document.querySelector('.masonry-grid');
            if (!grid) return;

            const itemsArr = Array.from(grid.querySelectorAll('.masonry-item-wrapper')).filter(item => {
                return item.style.display !== 'none' && item.getClientRects().length > 0;
            });
            
            const containerWidth = grid.offsetWidth;
            let cols = 1;
            if (window.innerWidth >= 1024) cols = 3;
            else if (window.innerWidth >= 768) cols = 2;

            const gap = 20; // 1.25rem = 20px
            const colWidth = (containerWidth - (gap * (cols - 1))) / cols;
            const colHeights = new Array(cols).fill(0);

            itemsArr.forEach((item) => {
                const minHeight = Math.min(...colHeights);
                const colIndex = colHeights.indexOf(minHeight);
                const x = colIndex * (colWidth + gap);
                const y = minHeight;

                item.style.width = `${colWidth}px`;
                item.style.transform = `translate3d(${x}px, ${y}px, 0)`;
                
                colHeights[colIndex] += item.offsetHeight + gap;
            });

            grid.style.height = `${Math.max(...colHeights)}px`;
        }

        // Trigger masonry layout
        window.addEventListener('load', layoutMasonryConcepts);
        window.addEventListener('resize', layoutMasonryConcepts);
        
        // Initial run
        layoutMasonryConcepts();

        updateFilterPreview();
    </script>
</body>
