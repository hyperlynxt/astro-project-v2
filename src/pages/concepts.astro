---
import { getCollection, render } from 'astro:content';
import '../styles/global.css';
import ConceptModal from '../components/ConceptModal.astro';

const concepts = await getCollection('concepts');
// ... existing sort logic ...
concepts.sort((a, b) => {
  const ratingA = a.data.rating || 0;
  const ratingB = b.data.rating || 0;
  if (ratingB !== ratingA) return ratingB - ratingA;
  return new Date(b.data.date_added).getTime() - new Date(a.data.date_added).getTime();
});

const renderedConcepts = await Promise.all(
  concepts.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlas Field Notes - Concepts</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600;700&family=Reenie+Beanie&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #FDFCF9;
            background-image: 
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png");
            background-position: 0px 0px, 40px 60px, 80px 20px;
            background-repeat: repeat;
            color: #2A2724;
        }
        .hand-underline-sm { position: relative; display: inline-block; }
        .catalog-card {
            background: white !important;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
        }
        .catalog-card:hover {
            background: #F5F2EB !important;
            border-color: #D5CCB6;
            transform: translateY(-4px);
            box-shadow: 0 12px 24px -10px rgba(42, 39, 36, 0.1);
        }
        .catalog-card:hover .model-title { color: #8B2626; }
        .bookmark-icon {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            color: #A39985;
            transition: color 0.2s ease;
            z-index: 10;
        }
        .catalog-card:hover .bookmark-icon { color: #8B2626; }
        .star-rating { display: flex; gap: 4px; color: #8B2626; }
        .masonry-grid {
            position: relative;
            width: 100%;
            transition: height 0.4s ease;
        }
        .masonry-item-wrapper {
            position: absolute;
            transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.4s ease, width 0.4s ease;
            padding: 0;
            margin: 0;
        }
        .masonry-item { 
            break-inside: avoid; 
            margin-bottom: 1.25rem; 
            display: block; 
            position: relative;
        }
        .glass-nav { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.12); border-radius: 10px; border: 2px solid transparent; background-clip: content-box; }
        ::-webkit-scrollbar-thumb:hover { background-color: rgba(42, 39, 36, 0.25); }
    </style>
</head>
<body class="min-h-screen antialiased selection:bg-[#8B2626] selection:text-white flex flex-col">

    <header class="sticky top-0 z-50 w-full h-[80px] bg-[#F5F2EB]/95 glass-nav flex items-center justify-between px-10 shadow-sm" style="border-bottom: 0.5px solid rgba(42, 39, 35, 0.12);">
        <div class="flex items-center gap-10">
            <a href="/astro-project-v2/" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Main Page</a>
            <div class="h-8 w-px bg-[#E8E2D2]"></div>
            <nav class="flex items-center gap-8 translate-y-[2px]">
                <a href="/astro-project-v2/concepts" class="group flex items-center gap-2 transition-all duration-300 hover:-translate-y-[1px]">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#8B2626] shadow-[0_0_8px_rgba(139,38,38,0.4)]"></span>
                    <span class="font-serif text-xl text-[#2A2724]">Concepts</span>
                </a>
                <a href="/astro-project-v2/definitions" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Definitions</a>
                <a href="Grid Frameworks Main.html" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Frameworks</a>
            </nav>
        </div>
        <div class="font-['Reenie_Beanie'] text-[1.75rem] leading-none text-seal tracking-tight translate-y-1">hyperlynxt | teo</div>
    </header>

    <main class="flex-1 pb-32">
        <section class="w-full bg-gradient-to-b from-[#F5F2EB] to-transparent pt-20 pb-16 px-6">
            <div class="max-w-4xl mx-auto text-center">
