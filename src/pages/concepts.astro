                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" style={i === 1 ? "transform: rotate(15deg);" : i === 2 ? "transform: rotate(-10deg);" : i === 3 ? "transform: rotate(5deg);" : i === 4 ? "transform: rotate(-15deg);" : ""}>
                                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.3"></path>
                                            </svg>
