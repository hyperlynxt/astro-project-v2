        ::-webkit-scrollbar-thumb:hover { background-color: rgba(42, 39, 36, 0.25); }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideUpScale { from { opacity: 0; transform: translateY(40px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
        @keyframes slideInRight { from { opacity: 0; transform: translateX(-40px); } to { opacity: 1; transform: translateX(0); } }
        @keyframes slideUpStagger { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
        .animate-modal-enter { opacity: 0; animation: slideUpScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s forwards; }
        .animate-content-enter { opacity: 0; animation: slideInRight 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) 0.15s forwards; }
        .animate-sidebar-item { opacity: 0; animation: slideUpStagger 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
        .stagger-1 { animation-delay: 0.2s; } .stagger-2 { animation-delay: 0.28s; } .stagger-3 { animation-delay: 0.36s; }
        .stagger-4 { animation-delay: 0.44s; } .stagger-5 { animation-delay: 0.52s; } .stagger-6 { animation-delay: 0.6s; } .stagger-7 { animation-delay: 0.68s; }
        .ink-stain {
            background-color: #FDFCF9;
            background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png"), url("https://www.transparenttextures.com/patterns/natural-paper.png"), radial-gradient(circle at 10% 90%, rgba(42,39,36,0.03) 0%, rgba(253,252,249,0) 60%);
            background-position: 0px 0px, 40px 60px, 0 0;
            background-repeat: repeat, repeat, no-repeat;
        }
        .swoosh-path { stroke-dasharray: 100; stroke-dashoffset: 100; }
        @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }
        .animate-draw-line { animation: drawSwoosh 0.8s ease-out 0.4s forwards; }
        .hatched-pattern { background-image: repeating-linear-gradient(45deg, #2A2724 0, #2A2724 1px, transparent 0, transparent 8px); }
        .custom-scrollbar-modal::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.15); border-radius: 10px; }
        .modal-scrollbar::-webkit-scrollbar { width: 4px; }
        .modal-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .modal-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.15); border-radius: 10px; }
    </style>
</head>
