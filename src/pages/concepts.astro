                    <div class="flex items-center justify-between">
                        <h3 class="font-sans text-[10px] font-bold uppercase tracking-[0.15em] text-[#2A2724]/50">Utility Score</h3>
                        <div id="modal-stars" class="flex gap-1.5 items-center text-[#B08D57]"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Modal -->
    <div id="filter-modal" style="display:none;" class="fixed inset-0 z-[60] items-center justify-center p-6 bg-[#F5F2EB]/40 backdrop-blur-md">
        <div class="relative z-20 w-full max-w-[630px] bg-white rounded-[28px] shadow-2xl border border-white/60 overflow-hidden flex flex-col max-h-[85vh] ink-stain">
            <div class="px-7 pt-7 pb-4 border-b border-[#D5CCB6]/15 flex justify-between items-start relative bg-white/50 backdrop-blur-md z-10 flex-shrink-0">
                <div>
                    <div class="font-['Reenie_Beanie'] text-xl text-[#A39985] -rotate-2 transform origin-left mb-1 opacity-80">Refine the collection</div>
                    <h2 class="text-3xl font-serif font-medium text-[#2A2724] relative inline-block">
                        Filter & Sort
                        <svg class="absolute w-[110%] h-[12px] -bottom-1 -left-1 text-[#8B2626] opacity-70 overflow-visible" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                            <path d="M2 7C25 2 75 -1 98 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path animate-draw-line"></path>
                        </svg>
                    </h2>
                </div>
                <button id="close-filter-btn" class="w-8 h-8 rounded-full bg-[#FDFCF9] border border-[#D5CCB6]/20 flex items-center justify-center text-[#2A2724]/50 hover:text-[#2A2724] hover:bg-[#F5F2EB] transition-all mt-1 group">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <div class="px-7 py-6 overflow-y-auto modal-scrollbar relative z-0 flex-grow space-y-8 h-[500px]">
                <!-- Sort -->
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#8B2626]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Sort Order</h3>
                        </div>
                        <button id="sort-direction-toggle" class="flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-[#FDFCF9] border border-[#D5CCB6]/20 text-[10px] font-bold uppercase tracking-wider text-[#2A2724]/60 hover:text-[#8B2626] transition-all group">
                            <span id="sort-direction-label">Descending</span>
                            <svg id="sort-direction-icon" xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M7 15l5 5 5-5M7 9l5-5 5 5"/></svg>
                        </button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button data-sort="most-used" class="sort-btn px-4 py-2 bg-[#8B2626] text-white font-sans text-sm font-medium rounded-full shadow-lg border border-[#8B2626] transition-all">Most Used</button>
                        <button data-sort="alphabetical" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:text-[#2A2724] transition-all shadow-sm">Alphabetical</button>
                        <button data-sort="rating" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:text-[#2A2724] transition-all shadow-sm">Rating</button>
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#D5CCB6]/20 to-transparent"></div>

                <!-- Disciplines -->
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#8B2626]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                        <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Disciplines</h3>
                    </div>
                    <div id="filter-disciplines-container" class="flex flex-wrap gap-2"></div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#D5CCB6]/20 to-transparent"></div>

                <!-- Tags -->
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#8B2626]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Filter by Tags</h3>
                        </div>
                        <button id="toggle-all-tags" class="font-sans text-[10px] font-bold uppercase tracking-wider text-[#8B2626]/60 hover:text-[#8B2626] transition-colors">Select All</button>
                    </div>
                    <div id="filter-tags-container" class="flex flex-wrap gap-2"></div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#D5CCB6]/20 to-transparent"></div>

                <!-- Stars -->
                <div class="pb-4">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#8B2626]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Minimum Utility</h3>
                        </div>
                        <span id="min-rating-label" class="font-['Reenie_Beanie'] text-lg text-[#8B2626]">1+ stars</span>
                    </div>
                    <div class="flex gap-2 p-3 bg-white border border-[#D5CCB6]/10 rounded-xl w-fit" id="filter-utility-stars">
                        <button data-rating="1" class="star-filter text-[#B08D57] hover:scale-110 transition-transform"><svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg></button>
                        <button data-rating="2" class="star-filter text-[#E8E2D2] hover:scale-110 transition-transform"><svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg></button>
                        <button data-rating="3" class="star-filter text-[#E8E2D2] hover:scale-110 transition-transform"><svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg></button>
                        <button data-rating="4" class="star-filter text-[#E8E2D2] hover:scale-110 transition-transform"><svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg></button>
                        <button data-rating="5" class="star-filter text-[#E8E2D2] hover:scale-110 transition-transform"><svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg></button>
                    </div>
                </div>
            </div>

            <div class="p-6 border-t border-[#D5CCB6]/15 bg-[#FDFCF9] relative z-10 flex items-center justify-between flex-shrink-0">
                <button id="clear-filter-btn" class="font-sans text-sm font-medium text-[#2A2724]/50 hover:text-[#2A2724] transition-colors underline underline-offset-4">Clear Filters</button>
                <button id="apply-filter-btn" class="bg-[#2A2724] hover:bg-black text-white px-6 py-3 rounded-xl font-sans text-sm font-medium transition-all shadow-md hover:-translate-y-0.5 flex items-center gap-2">
                    <span>Apply Filters</span>
                    <span id="filter-result-count" class="font-['Reenie_Beanie'] text-lg text-white/80 pt-0.5">-- concepts</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Bottom Bar -->
    <div class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-white/80 backdrop-blur-xl border border-[#E8E2D2] rounded-[24px] shadow-[0_20px_50px_rgba(42,39,36,0.15)] p-2.5 flex items-center z-50">
        <div class="flex items-center gap-3 pl-4 pr-3 py-2 group cursor-text" onclick="document.getElementById('concept-search').focus()">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#A39985] group-hover:text-[#2A2724] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            <input type="text" id="concept-search" placeholder="Search concepts" class="bg-transparent border-none outline-none font-sans text-xs font-bold text-[#2A2724] placeholder:text-[#A39985] w-32 transition-all focus:w-48">
        </div>
        <div class="w-px h-6 bg-[#E8E2D2] mx-1"></div>
        <button id="filter-btn" class="bg-[#2A2724] hover:bg-[#2A2724]/90 text-white rounded-xl px-5 py-2.5 text-[11px] uppercase tracking-widest font-sans font-bold transition-colors shadow-sm">Filter & Sort</button>
    </div>

    <script is:inline>
        const searchInput = document.getElementById('concept-search');
        const cards = document.querySelectorAll('.catalog-card');
        const conceptModal = document.getElementById('concept-modal');
        const filterModal = document.getElementById('filter-modal');
        const filterResultCount = document.getElementById('filter-result-count');
        const filterSortButtons = document.querySelectorAll('.sort-btn');
        const filterStarButtons = document.querySelectorAll('.star-filter');
        const masonryGrid = document.querySelector('.masonry-grid');
        const filterTagsContainer = document.getElementById('filter-tags-container');
        const filterDisciplinesContainer = document.getElementById('filter-disciplines-container');

        // Attach all button listeners
        document.getElementById('filter-btn').addEventListener('click', openFilterModal);
        document.getElementById('close-filter-btn').addEventListener('click', closeFilterModal);
        document.getElementById('apply-filter-btn').addEventListener('click', applyFilterSystem);
        document.getElementById('clear-filter-btn').addEventListener('click', clearAllFilters);
        document.getElementById('close-modal-btn').addEventListener('click', hideModal);

        let currentFilterState = {
            query: '',
            sort: 'most-used',
            sortOrder: 'desc',
            disciplines: ['All'],
            tags: [],
            minUtility: 0
        };

        // Build disciplines
        const availableDisciplines = new Set();
        cards.forEach(card => {
            const disc = card.getAttribute('data-discipline');
            if (disc) disc.split('/').forEach(d => availableDisciplines.add(d.trim()));
        });
        const sortedDisciplines = Array.from(availableDisciplines).sort();

        function renderFilterDisciplines() {
            const allActive = currentFilterState.disciplines.includes('All');
            let html = `<button data-discipline="All" class="disc-filter-btn px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest transition-all ${allActive ? 'bg-[#2A2724] text-white shadow-md' : 'bg-[#F5F2EB] text-[#2A2724]/60 border border-[#D5CCB6]/20 hover:bg-[#E8E2D2]'}">All Disciplines</button>`;
            html += sortedDisciplines.map(disc => {
                const isActive = currentFilterState.disciplines.includes(disc);
                return `<button data-discipline="${disc}" class="disc-filter-btn px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest transition-all ${isActive ? 'bg-[#8B2626] text-white shadow-md' : 'bg-[#FDFCF9] text-[#2A2724]/60 border border-[#D5CCB6]/20 hover:bg-[#F5F2EB]'}">${disc}</button>`;
            }).join('');
            filterDisciplinesContainer.innerHTML = html;
            filterDisciplinesContainer.querySelectorAll('.disc-filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const disc = btn.getAttribute('data-discipline');
                    if (disc === 'All') {
                        currentFilterState.disciplines = ['All'];
                    } else {
                        currentFilterState.disciplines = currentFilterState.disciplines.filter(d => d !== 'All');
                        if (currentFilterState.disciplines.includes(disc)) {
                            currentFilterState.disciplines = currentFilterState.disciplines.filter(d => d !== disc);
                            if (currentFilterState.disciplines.length === 0) currentFilterState.disciplines = ['All'];
                        } else {
                            currentFilterState.disciplines.push(disc);
                        }
                    }
                    renderFilterDisciplines();
                    updateFilterPreview();
                });
            });
        }
        renderFilterDisciplines();

        // Build tags
        const availableTags = new Set();
        cards.forEach(card => {
            const tags = card.getAttribute('data-tags') || '';
            if (tags) tags.split(',').forEach(t => { if(t.trim()) availableTags.add(t.trim()); });
        });
        const sortedTags = Array.from(availableTags).sort();

        function renderFilterTags() {
            filterTagsContainer.innerHTML = sortedTags.map(tag => {
                const isActive = currentFilterState.tags.includes(tag);
                return `<button data-tag="${tag}" class="tag-filter-btn px-3 py-1 rounded-full text-[10px] font-semibold uppercase tracking-widest transition-all ${isActive ? 'bg-[#8B2626] text-white shadow-md' : 'bg-[#8B2626]/10 text-[#8B2626] border border-[#8B2626]/20 hover:bg-[#8B2626]/20'}">${tag}</button>`;
            }).join('');
            document.querySelectorAll('.tag-filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const tag = btn.getAttribute('data-tag');
                    if (currentFilterState.tags.includes(tag)) {
                        currentFilterState.tags = currentFilterState.tags.filter(t => t !== tag);
                    } else {
                        currentFilterState.tags.push(tag);
                    }
                    renderFilterTags();
                    updateFilterPreview();
                });
            });
        }
        renderFilterTags();

        document.getElementById('toggle-all-tags').addEventListener('click', (e) => {
            if (currentFilterState.tags.length === sortedTags.length) {
                currentFilterState.tags = [];
                e.target.textContent = 'Select All';
            } else {
                currentFilterState.tags = [...sortedTags];
                e.target.textContent = 'Clear All';
            }
            renderFilterTags();
            updateFilterPreview();
        });

        filterSortButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                currentFilterState.sort = btn.getAttribute('data-sort');
                filterSortButtons.forEach(b => {
                    b.classList.remove('bg-[#8B2626]', 'text-white', 'shadow-lg', 'border-[#8B2626]');
                    b.classList.add('bg-white', 'text-[#2A2724]/70');
                });
                btn.classList.add('bg-[#8B2626]', 'text-white', 'shadow-lg');
                btn.classList.remove('bg-white', 'text-[#2A2724]/70');
                updateFilterPreview();
            });
        });

        const sortDirectionBtn = document.getElementById('sort-direction-toggle');
        const sortDirectionLabel = document.getElementById('sort-direction-label');
        const sortDirectionIcon = document.getElementById('sort-direction-icon');
        sortDirectionBtn.addEventListener('click', () => {
            currentFilterState.sortOrder = currentFilterState.sortOrder === 'desc' ? 'asc' : 'desc';
            sortDirectionLabel.textContent = currentFilterState.sortOrder === 'desc' ? 'Descending' : 'Ascending';
            sortDirectionIcon.style.transform = currentFilterState.sortOrder === 'desc' ? 'rotate(0deg)' : 'rotate(180deg)';
            updateFilterPreview();
        });

        filterStarButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                const rating = parseInt(btn.getAttribute('data-rating'));
                currentFilterState.minUtility = rating;
                filterStarButtons.forEach((star, index) => {
                    star.classList.toggle('text-[#B08D57]', index < rating);
                    star.classList.toggle('text-[#E8E2D2]', index >= rating);
                });
                document.getElementById('min-rating-label').textContent = `${rating}+ stars`;
                updateFilterPreview();
            });
        });

        function shouldShowCard(card) {
            const title = card.querySelector('.model-title').textContent.toLowerCase();
            const desc = card.querySelector('p')?.textContent.toLowerCase() || '';
            const tags = card.getAttribute('data-tags') ? card.getAttribute('data-tags').split(',').map(t => t.trim()) : [];
            const stars = parseInt(card.getAttribute('data-rating')) || 0;
            const discipline = card.getAttribute('data-discipline') || '';

            const queryMatch = !currentFilterState.query || title.includes(currentFilterState.query) || desc.includes(currentFilterState.query);
            let discMatch = currentFilterState.disciplines.includes('All');
            if (!discMatch) discMatch = currentFilterState.disciplines.some(d => discipline.includes(d));
            const tagsMatch = currentFilterState.tags.length === 0 || currentFilterState.tags.some(t => tags.includes(t));
            const starsMatch = stars >= currentFilterState.minUtility;

            return queryMatch && discMatch && tagsMatch && starsMatch;
        }

        function updateFilterPreview() {
            let count = 0;
            cards.forEach(card => { if (shouldShowCard(card)) count++; });
            filterResultCount.textContent = `${count} concepts`;
        }

        function openFilterModal() {
            filterModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            const path = filterModal.querySelector('.swoosh-path');
            if (path) { path.style.animation = 'none'; path.offsetHeight; path.style.animation = null; }
            updateFilterPreview();
        }

        function closeFilterModal() {
            filterModal.style.display = 'none';
            if (conceptModal.style.display !== 'flex') document.body.style.overflow = '';
        }

        function applyFilterSystem() {
            cards.forEach(card => { card.style.display = shouldShowCard(card) ? 'flex' : 'none'; });
            sortCards();
            closeFilterModal();
        }

        function sortCards() {
            const cardsArray = Array.from(cards);
            const isDesc = currentFilterState.sortOrder === 'desc';
            cardsArray.sort((a, b) => {
                let result = 0;
                if (currentFilterState.sort === 'alphabetical') {
                    result = a.querySelector('.model-title').textContent.trim().localeCompare(b.querySelector('.model-title').textContent.trim());
                } else if (currentFilterState.sort === 'most-used') {
                    result = parseInt(a.getAttribute('data-linked')) - parseInt(b.getAttribute('data-linked'));
                } else if (currentFilterState.sort === 'rating') {
                    result = parseInt(a.getAttribute('data-rating')) - parseInt(b.getAttribute('data-rating'));
                }
                return isDesc ? -result : result;
            });
            cardsArray.forEach(card => masonryGrid.appendChild(card));
        }

        function clearAllFilters() {
            currentFilterState = { query: '', sort: 'most-used', sortOrder: 'desc', disciplines: ['All'], tags: [], minUtility: 0 };
            renderFilterDisciplines();
            renderFilterTags();
            filterStarButtons.forEach(star => { star.classList.remove('text-[#B08D57]'); star.classList.add('text-[#E8E2D2]'); });
            document.getElementById('min-rating-label').textContent = '0+ stars';
            applyFilterSystem();
        }

        searchInput.addEventListener('input', (e) => {
            currentFilterState.query = e.target.value.toLowerCase().trim();
            applyFilterSystem();
        });

        // Card click → open modal
        cards.forEach(card => {
            card.addEventListener('click', () => {
                const title = card.getAttribute('data-title');
                const description = card.getAttribute('data-description');
                const discipline = card.getAttribute('data-discipline');
                const tags = card.getAttribute('data-tags');
                const origin = card.getAttribute('data-origin');
                const rating = parseInt(card.getAttribute('data-rating')) || 0;
                const linked = card.getAttribute('data-linked');
                const fieldNote = card.getAttribute('data-fieldnote');
                const notesOfUsed = card.getAttribute('data-notesofused') || '';
                const related = card.getAttribute('data-related') || '';

                document.getElementById('modal-title').textContent = title;
                document.getElementById('modal-bg-letter').textContent = title.charAt(0);
		document.getElementById('modal-summary').textContent = card.getAttribute('data-short') || '';
		const bodyContent = document.getElementById(`content-${card.getAttribute('data-id')}`);
		document.getElementById('modal-detailed-desc').innerHTML = bodyContent ? bodyContent.innerHTML : `<p>${description}</p>`;
                document.getElementById('modal-origin').textContent = origin;
                document.getElementById('modal-linked').textContent = linked;

                // Discipline / parent framework
                if (discipline.includes('/')) {
                    const parts = discipline.split('/');
                    document.getElementById('modal-discipline').textContent = parts[0].trim();
                    document.getElementById('modal-parent').textContent = parts[1].trim();
                    document.getElementById('modal-parent-container').style.display = 'block';
                    document.getElementById('modal-parent-divider').style.display = 'block';
                } else {
                    document.getElementById('modal-discipline').textContent = discipline;
                    document.getElementById('modal-parent-container').style.display = 'none';
                    document.getElementById('modal-parent-divider').style.display = 'none';
                }

                // Tags
                const tagColors = ['#2A4747', '#B08D57', '#8B2626'];
                const tagBgColors = ['rgba(42,71,71,0.1)', 'rgba(176,141,87,0.1)', 'rgba(139,38,38,0.1)'];
                document.getElementById('modal-tags').innerHTML = tags ? tags.split(',').map((tag, i) => {
                    const c = tagColors[i % tagColors.length];
                    const bg = tagBgColors[i % tagBgColors.length];
                    return `<span style="color:${c};background:${bg};padding:4px 12px;border-radius:999px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;">${tag.trim()}</span>`;
                }).join('') : '';

                // Stars
                document.getElementById('modal-stars').innerHTML = Array.from({length: 5}).map((_, i) =>
                    `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" fill-opacity="${i < rating ? '1' : '0.2'}" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"></path></svg>`
                ).join('');

                // Field note
                if (fieldNote) {
                    document.getElementById('modal-field-note').textContent = fieldNote;
                    document.getElementById('modal-field-note-container').style.display = 'block';
                } else {
                    document.getElementById('modal-field-note-container').style.display = 'none';
                }

                // Notes of used
                if (notesOfUsed) {
                    const notes = notesOfUsed.split(',').filter(n => n.trim());
                    document.getElementById('modal-notes-items').innerHTML = notes.map(name =>
                        `<div class="group p-3.5 bg-[#FDFCF9]/50 border border-[#D5CCB6]/40 rounded-xl flex items-center justify-between cursor-pointer hover:bg-[#FDFCF9] hover:border-[#7C6B9E]/40 hover:shadow-sm transition-all">
    <p class="font-serif text-[17px] text-[#2A2724] group-hover:text-[#7C6B9E] font-medium transition-colors">${name.trim()}</p>
    <svg class="w-4 h-4 text-[#A39985] opacity-0 group-hover:opacity-100 group-hover:text-[#7C6B9E] group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
</div>`
                    ).join('');
                    document.getElementById('modal-notes-section').style.display = 'block';
                } else {
                    document.getElementById('modal-notes-section').style.display = 'none';
                }

                // Related concepts
                if (related) {
                    const relatedItems = related.split(',').filter(r => r.trim());
                    document.getElementById('modal-related-items').innerHTML = relatedItems.map(name =>
    `<div class="group p-3.5 bg-[#FDFCF9]/50 border border-[#D5CCB6]/40 rounded-xl flex items-center justify-between cursor-pointer hover:bg-[#FDFCF9] hover:border-[#B08D57]/40 hover:shadow-sm transition-all">
        <p class="font-serif text-[17px] text-[#2A2724] group-hover:text-[#B08D57] font-medium transition-colors">${name.trim()}</p>
        <svg class="w-4 h-4 text-[#A39985] opacity-0 group-hover:opacity-100 group-hover:text-[#B08D57] group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    </div>`
).join('');
                    document.getElementById('modal-related-section').style.display = 'block';
                } else {
                    document.getElementById('modal-related-section').style.display = 'none';
                }
		const authors = card.getAttribute('data-authors') || '';
const authorsList = document.getElementById('modal-authors-list');
const attribution = document.getElementById('modal-attribution');
if (authors) {
    authorsList.textContent = authors.split(',').map(a => a.trim()).join(', ');
    attribution.style.display = 'flex';
} else {
    attribution.style.display = 'none';
}
                // Underline animation
                const modalTitleEl = document.getElementById('modal-title');
                const modalTitleUnderline = document.getElementById('modal-title-underline');
                requestAnimationFrame(() => {
                    const rects = modalTitleEl.getClientRects();
                    const containerRect = modalTitleEl.parentElement.getBoundingClientRect();
                    if (rects.length > 0) {
                        const firstRect = rects[0];
                        modalTitleUnderline.style.width = (firstRect.width * 1.05) + 'px';
                        modalTitleUnderline.style.top = (firstRect.bottom - containerRect.top - (firstRect.height * 0.12)) + 'px';
                        modalTitleUnderline.style.left = (firstRect.left - containerRect.left - (firstRect.width * 0.025)) + 'px';
                        modalTitleUnderline.style.display = 'block';
                        const path = modalTitleUnderline.querySelector('path');
                        path.style.animation = 'none';
                        void path.offsetWidth;
                        path.style.animation = 'drawSwoosh 0.8s ease-out 0.4s forwards';
                    }
                });

		conceptModal.style.display = 'flex';
		document.body.style.overflow = 'hidden';
		requestAnimationFrame(() => {
    		conceptModal.querySelectorAll('.overflow-y-auto').forEach(el => el.scrollTop = 0);
		});
            });
        });

        function hideModal() {
            conceptModal.style.display = 'none';
            if (filterModal.style.display !== 'flex') document.body.style.overflow = '';
        }

        conceptModal.addEventListener('click', (e) => { if (e.target === conceptModal) hideModal(); });
        filterModal.addEventListener('click', (e) => { if (e.target === filterModal) closeFilterModal(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeFilterModal(); hideModal(); } });

        updateFilterPreview();
    </script>
</body>
</html>