---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const quotes = await getCollection('quotes');
quotes.sort((a, b) => new Date(b.data.date_added).getTime() - new Date(a.data.date_added).getTime());

const STAR_ROTATIONS = [0, 15, -10];
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlas Field Notes — Gathered Words</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@400;500;600;700&family=Reenie+Beanie&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #FDFCF9;
            background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
            color: #2A2724;
        }
        .glass-nav { backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); }
        .quotes-grid {
            display: grid;
            grid-template-columns: repeat(1, 1fr);
            gap: 1.75rem;
            align-items: start;
        }
        @media (min-width: 640px)  { .quotes-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (min-width: 1024px) { .quotes-grid { grid-template-columns: repeat(3, 1fr); } }
        .quote-card {
            cursor: pointer;
            background-color: #ffffff;
            border-radius: 22px;
            padding: 2rem 2rem 1.6rem;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(42,39,35,0.10);
            box-shadow: 0 2px 12px rgba(42,39,35,0.06);
            transition: all 0.3s ease;
            backface-visibility: hidden;
            transform: translateZ(0);
            display: flex;
            flex-direction: column;
        }
        .quote-card:hover {
            background: #F5F2EB;
            border-color: #D5CCB6;
            transform: translateY(-4px);
            box-shadow: 0 12px 24px -10px rgba(42, 39, 36, 0.1);
        }
        .quote-card:hover .card-body p { color: #7BA08A; }
        .quote-card:hover .card-quote-icon { color: #7BA08A; }
        .card-expand {
            position: absolute;
            top: 1.1rem;
            right: 1.1rem;
            opacity: 0;
            transform: scale(0.85);
            transition: opacity 0.25s ease, transform 0.25s ease;
            color: rgba(42,39,35,0.28);
            font-size: 0.75rem;
            line-height: 1;
        }
        .quote-card:hover .card-expand { opacity: 1; transform: scale(1); }
        .card-quote-icon { color: #7BA08A; margin-bottom: 1rem; flex-shrink: 0; transition: color 0.3s ease; }
        .card-body p { transition: color 0.3s ease; }
        .card-body { flex-grow: 1; }
        .card-footer {
            margin-top: 1.6rem;
            padding-top: 1.1rem;
            border-top: 1px solid rgba(42,39,35,0.06);
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 0.75rem;
        }
        .card-tag {
            background: rgba(42,39,35,0.04);
            color: rgba(42,39,35,0.5);
            font-family: 'Inter', sans-serif;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 4px 9px;
            border-radius: 6px;
        }
        #modal-overlay {
            background: rgba(42, 39, 35, 0.38);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            transition: opacity 0.35s ease;
        }
        @keyframes cardIn {
            from { opacity: 0; transform: translateY(28px) scale(0.96); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }
        @keyframes textReveal {
            from { opacity: 0; transform: translateY(10px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes drawStroke { to { stroke-dashoffset: 0; } }
        .scene { 
            perspective: 1200px; 
            perspective-origin: center;
            width: 100%; 
            min-height: 500px;
            display: flex; 
            justify-content: center; 
            align-items: center;
            z-index: 10; 
            position: relative;
            overflow: visible;
        }
        .modal-card {
            background-color: #FDFCF9;
            perspective: 1200px;
            transform-style: preserve-3d;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            text-rendering: optimizeLegibility;
            backface-visibility: hidden;
            transform: translateZ(0);
        }
        .modal-card-initial {
            animation: cardIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .modal-quote-text { opacity: 0; animation: textReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.12s forwards; }
        .modal-attribution { opacity: 0; animation: textReveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.32s forwards; }
        .draw-line path {
            stroke-dasharray: 600;
            stroke-dashoffset: 600;
            animation: drawStroke 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.28s forwards;
        }
        .star-rating { display: flex; gap: 4px; color: #7BA08A; }
        ::-webkit-scrollbar { width: 7px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background-color: rgba(42,39,35,0.1); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background-color: rgba(42,39,35,0.2); }
        .sidebar-block { opacity: 0; transform: translateY(12px); animation: sidebarIn 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .sidebar-block:nth-child(1) { animation-delay: 0.2s; }
        .sidebar-block:nth-child(2) { animation-delay: 0.32s; }
        @keyframes sidebarIn { to { opacity: 1; transform: translateY(0); } }
        .hand-underline-sm { position: relative; display: inline-block; }
        .swoosh-path { stroke-dasharray: 100; stroke-dashoffset: 100; }
        @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }
        .animate-draw-line { animation: drawSwoosh 0.8s ease-out 0.4s forwards; }

        /* 3D Flip Animations */
        @keyframes flipNext {
            0%     { transform: perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1); opacity: 1; }
            33%    { transform: perspective(1000px) rotateX(0deg) rotateY(90deg) scale(0.92); opacity: 0.8; }
            100%   { transform: perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1); opacity: 1; }
        }
        @keyframes flipPrev {
            0%     { transform: perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1); opacity: 1; }
            33%    { transform: perspective(1000px) rotateX(0deg) rotateY(-90deg) scale(0.92); opacity: 0.8; }
            100%   { transform: perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1); opacity: 1; }
        }
        .flipping-next { animation: flipNext 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards !important; z-index: 100; transition: none !important; }
        .flipping-prev { animation: flipPrev 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards !important; z-index: 100; transition: none !important; }
    </style>
</head>
<body class="min-h-screen">

    <header class="sticky top-0 z-50 w-full h-[80px] bg-[#F5F2EB]/95 glass-nav flex items-center justify-between px-10 shadow-sm" style="border-bottom: 0.5px solid rgba(42,39,35,0.08);">
        <div class="flex items-center gap-10">
            <a href="index.html" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px] hover:opacity-80">Main Page</a>
            <div class="h-8 w-px bg-[#E8E2D2]"></div>
            <nav class="flex items-center gap-8 translate-y-[2px]">
                <a href="/quotes" class="group flex items-center gap-2 transition-all duration-300 hover:-translate-y-[1px]">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#7BA08A] shadow-[0_0_8px_rgba(123,160,138,0.5)]"></span>
                    <span class="font-serif text-xl text-[#2A2724]">Quotes</span>
                </a>

            </nav>
        </div>
        <div class="font-['Reenie_Beanie'] text-[1.75rem] leading-none text-[#7BA08A] tracking-tight translate-y-1">hyperlynxt | teo</div>
    </header>

    <section class="w-full bg-gradient-to-b from-[#F5F2EB] to-transparent pt-20 pb-16 px-6">
        <div class="max-w-4xl mx-auto text-center">
            <span class="font-['Reenie_Beanie'] text-2xl text-[#8C8070] mb-2 block">A catalog of gathered words</span>
            <h2 class="font-serif text-5xl md:text-7xl leading-tight text-[#2A2724] mb-8">
                Collected <span class="italic hand-underline-sm inline-block">
                    Quotes
                    <svg class="absolute w-[110%] h-[12px] -bottom-1 -left-[5%] text-[#7BA08A] opacity-80 overflow-visible" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                        <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path animate-draw-line"></path>
                    </svg>
                </span>
            </h2>
            <p class="font-serif italic text-lg md:text-xl text-[#8C8070] max-w-2xl mx-auto leading-relaxed">Things worth keeping. Words that stayed.</p>
        </div>
    </section>

    <div class="max-w-[1400px] mx-auto px-6 md:px-10 mb-6 flex items-center justify-between pb-3" style="border-bottom: 1px solid rgba(42,39,35,0.08);">
        <span class="font-sans text-[10px] font-bold uppercase tracking-[0.14em] text-[#2A2724]/40">The Collection</span>
        <span id="count-label" class="font-serif italic text-[#2A2724]/35 text-sm">{quotes.length} entries</span>
    </div>

    <main class="max-w-[1400px] mx-auto px-6 md:px-10 pb-36">
        <div class="quotes-grid" id="quotes-grid">
            {quotes.map((entry) => {
                const visibleTags = entry.data.tags.slice(0, 2);
                const overflow = entry.data.tags.length > 2 ? entry.data.tags.length - 2 : 0;
                return (
                    <article
                        class="quote-card"
                        data-tags={entry.data.tags.join(',')}
                        data-stars={entry.data.stars}
                        data-author={entry.data.author}
                        data-text={entry.data.text.toLowerCase()}
                        data-summary={entry.data.summary || ''}
                        data-source={entry.data.source || ''}
                        data-fulltext={entry.data.text}
                    >
                        <span class="card-expand">↗</span>
                        <div class="card-quote-icon">
                            <svg width="22" height="16" viewBox="0 0 22 16" fill="none">
                                <path d="M0 16V9.6C0 4.267 2.667 1.067 8 0l1.067 1.6C6.4 2.4 4.8 4.133 4.267 6.667H8V16H0ZM12 16V9.6C12 4.267 14.667 1.067 20 0l1.067 1.6C18.4 2.4 16.8 4.133 16.267 6.667H20V16H12Z" fill="currentColor"/>
                            </svg>
                        </div>
                        <div class="card-body">
                            <p class="font-serif text-[1.45rem] leading-[1.75] text-[#2A2724]" style="display:-webkit-box;-webkit-line-clamp:5;-webkit-box-orient:vertical;overflow:hidden;">{entry.data.text}</p>
                        </div>
                        <div class="card-footer">
                            <div class="min-w-0">
                                <div class="star-rating mb-1.5">
                                    {Array.from({ length: entry.data.stars }).map((_, i) => (
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style={i === 1 ? "transform:rotate(15deg)" : i === 2 ? "transform:rotate(-10deg)" : ""}>
                                            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"></path>
                                        </svg>
                                    ))}
                                </div>
                                <p class="font-sans text-[10px] font-bold uppercase tracking-[0.12em] text-[#2A2724]/70 truncate">{entry.data.author}</p>
                            </div>
                            <div class="flex items-center gap-1.5 flex-wrap justify-end flex-shrink-0">
                                {visibleTags.map(t => <span class="card-tag">{t}</span>)}
                                {overflow > 0 && <span class="card-tag">+{overflow}</span>}
                            </div>
                        </div>
                    </article>
                );
            })}
        </div>
    </main>

    <!-- Modal Overlay -->
    <div id="modal-overlay" class="fixed inset-0 z-50 items-center justify-center p-6 md:p-10" style="display:none; background-color: rgba(245, 242, 235, 0.4); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
        <div class="relative w-full max-w-[640px]">
            <button id="modal-prev-btn" class="absolute top-1/2 -translate-y-1/2 -left-4 md:-left-16 w-10 h-10 md:w-12 md:h-12 rounded-full bg-[#FDFCF9]/90 border border-[#2A2724]/10 text-[#2A2724]/50 flex items-center justify-center cursor-pointer transition-all hover:bg-white hover:text-[#2A2724] hover:border-[#2A2724]/20 hover:scale-105 backdrop-blur-md shadow-sm z-[60]">
                <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
            </button>
            <button id="modal-next-btn" class="absolute top-1/2 -translate-y-1/2 -right-4 md:-right-16 w-10 h-10 md:w-12 md:h-12 rounded-full bg-[#FDFCF9]/90 border border-[#2A2724]/10 text-[#2A2724]/50 flex items-center justify-center cursor-pointer transition-all hover:bg-white hover:text-[#2A2724] hover:border-[#2A2724]/20 hover:scale-105 backdrop-blur-md shadow-sm z-[60]">
                <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </button>

        <div class="scene">
            <div id="modal-card" class="modal-card relative w-full rounded-[24px] flex flex-col border border-[#2A2724]/[0.08] shadow-[0_25px_50px_-12px_rgba(42,39,36,0.25)]" style="max-height: 94vh;">
            <button id="close-modal-btn" class="absolute top-4 right-4 z-20 w-7 h-7 rounded-full border border-[#2A2724]/10 bg-white/60 text-[#2A2724]/35 hover:text-[#2A2724]/70 hover:border-[#2A2724]/25 flex items-center justify-center transition-all font-sans text-xs leading-none backdrop-blur-sm">✕</button>

            <div class="flex-1 overflow-y-auto px-8 md:px-12 pt-14 pb-6 relative">
                <div class="flex justify-center mb-6">
                    <div id="modal-stars" class="star-rating px-1"></div>
                </div>
                <blockquote class="modal-quote-text font-serif font-bold text-[1.8rem] md:text-[2.1rem] leading-relaxed text-[#2A2724] mt-2 mb-2 relative z-10" id="modal-quote-text"></blockquote>
                <svg class="draw-line w-full mb-4" height="14" viewBox="0 0 480 14" preserveAspectRatio="none" style="overflow:visible;">
                    <path d="M0,10 Q60,14 120,8 T240,10 T360,8 T480,10" fill="none" stroke="#7BA08A" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                <div id="summary-container" class="modal-attribution border-l-4 border-[#7BA08A] pl-6 py-1 mb-6">
                    <p id="modal-summary" class="font-serif italic text-[1.1rem] leading-relaxed text-[#8C8070]"></p>
                </div>
            </div>

            <div class="w-full border-t border-[#2A2724]/[0.08] bg-white/50 backdrop-blur-sm px-8 py-8 flex flex-col md:flex-row gap-6">
                <div class="sidebar-block flex-1 bg-white/80 rounded-2xl border border-[#2A2724]/[0.07] p-5 shadow-sm">
                    <div class="flex items-center gap-2 mb-3">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#7BA08A]"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
                        <span class="font-sans text-[9.5px] font-bold uppercase tracking-[0.14em] text-[#2A2724]/40">Origin</span>
                    </div>
                    <p id="sidebar-author" class="font-serif text-[1.3rem] text-[#2A2724] leading-tight mb-1"></p>
                    <p id="sidebar-source" class="font-serif italic text-[0.9rem] text-[#2A2724]/45"></p>
                </div>
                <div class="sidebar-block flex-1 bg-white/80 rounded-2xl border border-[#2A2724]/[0.07] p-5 shadow-sm">
                    <div class="flex items-center gap-2 mb-3">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#7BA08A]"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                        <span class="font-sans text-[9.5px] font-bold uppercase tracking-[0.14em] text-[#2A2724]/40">Categories</span>
                    </div>
                    <div id="sidebar-tags" class="flex flex-wrap gap-2"></div>
                </div>
            </div>
            </div>
        </div>
    </div>
    </div>

    <!-- Filter Modal -->
    <div id="filter-modal" style="display:none;" class="fixed inset-0 z-[60] flex items-center justify-center p-6 bg-[#F5F2EB]/40 backdrop-blur-md">
        <div class="relative w-full max-w-[630px] bg-white rounded-[28px] shadow-2xl border border-white/60 overflow-hidden flex flex-col max-h-[85vh]" style="background-image: url('https://www.transparenttextures.com/patterns/natural-paper.png'), linear-gradient(white,white);">
            <div class="px-7 pt-9 pb-6 border-b border-[#2A2724]/10 flex flex-col items-center justify-center bg-white/60 backdrop-blur-md flex-shrink-0 relative">
                <div class="text-center">
                    <h2 class="text-3xl md:text-4xl font-serif font-medium text-[#2A2724] relative inline-block">
                        Filter & Sort
                        <svg class="absolute w-[110%] h-[15px] -bottom-2 -left-[5%] text-[#7BA08A] opacity-80 overflow-visible" viewBox="0 0 100 10" fill="none" preserveAspectRatio="none">
                            <path d="M2 7C25 2 75 -1 98 8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="swoosh-path animate-draw-line"/>
                        </svg>
                    </h2>
                </div>
                <button id="close-filter-btn" class="absolute top-7 right-7 w-8 h-8 rounded-full bg-[#FDFCF9] border border-[#2A2724]/15 flex items-center justify-center text-[#2A2724]/50 hover:text-[#2A2724] hover:bg-[#F5F2EB] transition-all group">
                    <svg class="w-4 h-4 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>

            <div class="px-7 py-6 overflow-y-auto flex-grow space-y-8" style="max-height:500px;">
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Sort Order</h3>
                        </div>
                        <button id="sort-direction-toggle" class="flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-[#FDFCF9] border border-[#2A2724]/15 text-[10px] font-bold uppercase tracking-wider text-[#2A2724]/60 hover:text-[#7BA08A] transition-all group">
                            <span id="sort-direction-label">Descending</span>
                            <svg id="sort-direction-icon" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M7 15l5 5 5-5M7 9l5-5 5 5"/></svg>
                        </button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button data-sort="default" class="sort-btn px-4 py-2 bg-[#7BA08A] text-white font-sans text-sm font-medium rounded-full shadow-lg border border-[#7BA08A] transition-all">Default</button>
                        <button data-sort="alphabetical" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#2A2724]/20 hover:text-[#2A2724] transition-all shadow-sm">Alphabetical</button>
                        <button data-sort="category" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#2A2724]/20 hover:text-[#2A2724] transition-all shadow-sm">By Category</button>
                        <button data-sort="most-stars" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#2A2724]/20 hover:text-[#2A2724] transition-all shadow-sm">Most Stars</button>
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#2A2724]/15 to-transparent"></div>

                <div>
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Filter by Tags</h3>
                        </div>
                        <button id="toggle-all-tags" class="font-sans text-[10px] font-bold uppercase tracking-wider text-[#7BA08A]/70 hover:text-[#7BA08A] transition-colors">Select All</button>
                    </div>
                    <div id="filter-tags-container" class="flex flex-wrap gap-2"></div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#2A2724]/15 to-transparent"></div>

                <div class="pb-4">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Minimum Stars</h3>
                        </div>
                        <span class="font-['Reenie_Beanie'] text-lg text-[#7BA08A] hand-label">1+ stars</span>
                    </div>
                    <div class="flex gap-3 p-3.5 bg-[#FDFCF9] border border-[#2A2724]/10 rounded-2xl w-fit shadow-inner" id="filter-utility-stars">
                        <button data-rating="1" class="star-filter text-[#B08D57] hover:scale-110 transition-all active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"></path>
                            </svg>
                        </button>
                        <button data-rating="2" class="star-filter text-[#E8E2D2] hover:scale-110 transition-all active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(15deg)">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"></path>
                            </svg>
                        </button>
                        <button data-rating="3" class="star-filter text-[#E8E2D2] hover:scale-110 transition-all active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(-10deg)">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <div class="p-6 border-t border-[#2A2724]/10 bg-[#FDFCF9] flex items-center justify-between flex-shrink-0">
                <button id="clear-filter-btn" class="font-['Reenie_Beanie'] text-[1.4rem] font-medium text-[#7BA08A] hover:bg-[#7BA08A]/10 px-4 py-1.5 rounded-lg transition-all underline underline-offset-4">Clear Filters</button>
                <button id="apply-filter-btn" class="bg-[#7BA08A] hover:bg-[#6a9079] text-white px-6 py-3 rounded-xl font-sans text-sm font-medium transition-all shadow-md hover:-translate-y-0.5 flex items-center gap-2">
                    <span>Apply Filters</span>
                    <span id="filter-result-count" class="font-['Reenie_Beanie'] text-lg text-white/90 pt-0.5">-- quotes</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Floating bar -->
    <div class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-white/80 backdrop-blur-xl border border-[#E8E2D2] rounded-[24px] shadow-[0_20px_50px_rgba(42,39,36,0.15)] p-2.5 flex items-center z-50">
        <div class="flex items-center gap-3 pl-4 pr-3 py-2 group cursor-text" onclick="document.getElementById('quotes-search').focus()">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#A39985] group-hover:text-[#2A2724] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" id="quotes-search" placeholder="Search quotes" class="bg-transparent border-none outline-none font-sans text-xs font-bold text-[#2A2724] placeholder:text-[#A39985] w-32 transition-all focus:w-48">
        </div>
        <div class="w-px h-6 bg-[#E8E2D2] mx-1"></div>
        <button id="filter-btn" class="bg-[#7BA08A] hover:bg-[#6a9079] text-white rounded-xl px-5 py-2.5 text-[11px] uppercase tracking-widest font-sans font-bold transition-colors shadow-sm">Filter & Sort</button>
    </div>

    <script is:inline>
        const overlay = document.getElementById('modal-overlay');
        const filterModal = document.getElementById('filter-modal');
        const cards = document.querySelectorAll('.quote-card');
        const quotesGrid = document.getElementById('quotes-grid');

        // Button listeners
        document.getElementById('filter-btn').addEventListener('click', openFilterModal);
        document.getElementById('close-filter-btn').addEventListener('click', closeFilterModal);
        document.getElementById('apply-filter-btn').addEventListener('click', applyFilterSystem);
        document.getElementById('clear-filter-btn').addEventListener('click', clearAllFilters);
        document.getElementById('close-modal-btn').addEventListener('click', closeModalDirect);

        // Star builder
        const STAR_ROTATIONS = [0, 15, -10];
        function buildStars(count) {
            return Array.from({ length: count }, (_, i) =>
                `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(${STAR_ROTATIONS[i] || 0}deg)">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"/>
                </svg>`
            ).join('');
        }

        function buildModalStars(count) {
            return Array.from({ length: count }, (_, i) =>
                `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(${STAR_ROTATIONS[i] || 0}deg)">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"/>
                </svg>`
            ).join('');
        }

        function resetAnimation(el) {
            if (!el) return;
            el.style.animation = 'none';
            el.offsetHeight;
            el.style.animation = null;
        }

        let currentVisibleCards = [];
        let currentCardIndex = -1;

        function populateModal(card, isNavigation = false) {
            const text = card.getAttribute('data-fulltext');
            const summary = card.getAttribute('data-summary') || '';
            const author = card.getAttribute('data-author');
            const source = card.getAttribute('data-source') || '';
            const stars = parseInt(card.getAttribute('data-stars')) || 0;
            const tags = card.getAttribute('data-tags') ? card.getAttribute('data-tags').split(',') : [];

            document.getElementById('modal-quote-text').textContent = '\u201C' + text + '\u201D';
            
            const summaryContainer = document.getElementById('summary-container');
            if (summary && summary.trim() !== '') {
                document.getElementById('modal-summary').textContent = summary;
                summaryContainer.style.display = 'block';
            } else {
                summaryContainer.style.display = 'none';
            }

            document.getElementById('modal-stars').innerHTML = buildModalStars(stars);
            document.getElementById('sidebar-author').textContent = author;
            document.getElementById('sidebar-source').textContent = source;
            document.getElementById('sidebar-tags').innerHTML = tags.map(t =>
                `<span class="card-tag" style="font-size:10px;padding:5px 11px;border-radius:8px;border:1px solid rgba(42,39,35,0.1);">${t.trim()}</span>`
            ).join('');

            // Restart line drawing
            const path = overlay.querySelector('.draw-line path');
            if (path) {
                path.style.animation = 'none';
                path.offsetHeight;
                path.style.animation = null;
            }
            
            // Only re-trigger reveal animations on initial modal open
            if (!isNavigation) {
                resetAnimation(document.getElementById('modal-quote-text'));
                overlay.querySelectorAll('.modal-attribution').forEach(el => resetAnimation(el));
            }
        }

        // Card click → open modal
        cards.forEach(card => {
            card.addEventListener('click', () => {
                currentVisibleCards = Array.from(quotesGrid.querySelectorAll('.quote-card')).filter(c => c.style.display !== 'none');
                currentCardIndex = currentVisibleCards.indexOf(card);
                
                document.getElementById('modal-prev-btn').style.display = currentVisibleCards.length > 1 ? 'flex' : 'none';
                document.getElementById('modal-next-btn').style.display = currentVisibleCards.length > 1 ? 'flex' : 'none';

                populateModal(card, false);

                overlay.style.display = 'flex';
                overlay.style.opacity = '0';
                document.body.style.overflow = 'hidden';
                requestAnimationFrame(() => { 
                    overlay.style.opacity = '1'; 
                    modalCard.classList.add('modal-card-initial');
                    // Clear the entry animation after it finishes so it doesn't fight Y-axis transforms
                    setTimeout(() => {
                        modalCard.classList.remove('modal-card-initial');
                        modalCard.style.animation = 'none';
                        modalCard.style.transform = 'none';
                        modalCard.style.opacity = '1';
                    }, 550);
                });
            });
        });

        function doClose() {
            overlay.style.opacity = '0';
            document.body.style.overflow = '';
            setTimeout(() => { overlay.style.display = 'none'; }, 320);
        }
        function closeModalDirect() { doClose(); }
        overlay.addEventListener('click', (e) => { if (e.target === overlay) doClose(); });

        // Navigation controls
        let isNavigating = false;
        async function navigateModal(direction) {
            if (isNavigating || currentVisibleCards.length <= 1) return;
            isNavigating = true;

            const modalCard = document.getElementById('modal-card');
            
            // Clean up any existing flip or entry classes explicitly before starting
            modalCard.classList.remove('flipping-next', 'flipping-prev', 'modal-card-initial');
            modalCard.style.animation = 'none';
            modalCard.style.transform = 'none';
            modalCard.offsetHeight; // force reflow

            // Phase 1: Start CSS Animation
            modalCard.classList.add(direction === 'next' ? 'flipping-next' : 'flipping-prev');

            // Phase 2: Swap content at the "edge-on" mark (approx 200ms into 400ms total)
            setTimeout(() => {
                currentCardIndex = direction === 'next' 
                    ? (currentCardIndex + 1) % currentVisibleCards.length 
                    : (currentCardIndex - 1 + currentVisibleCards.length) % currentVisibleCards.length;
                
                populateModal(currentVisibleCards[currentCardIndex], true);
            }, 200);

            // Phase 3: Animation cleanup
            setTimeout(() => {
                modalCard.classList.remove('flipping-next', 'flipping-prev');
                isNavigating = false;
            }, 600);
        }

        document.getElementById('modal-prev-btn').addEventListener('click', (e) => { e.stopPropagation(); navigateModal('prev'); });
        document.getElementById('modal-next-btn').addEventListener('click', (e) => { e.stopPropagation(); navigateModal('next'); });

        document.addEventListener('keydown', (e) => {
            if (overlay.style.display === 'flex') {
                if (e.key === 'ArrowRight') navigateModal('next');
                if (e.key === 'ArrowLeft') navigateModal('prev');
                if (e.key === 'Escape') closeModalDirect();
            }
        });

        // Filter state
        let filterState = { query: '', sort: 'default', sortOrder: 'desc', tags: [], minStars: 1 };

        const allTags = [...new Set(Array.from(cards).flatMap(c => 
            c.getAttribute('data-tags') ? c.getAttribute('data-tags').split(',').map(t => t.trim()) : []
        ))].sort();

        function renderTagFilters() {
            const container = document.getElementById('filter-tags-container');
            container.innerHTML = allTags.map(tag => {
                const active = filterState.tags.includes(tag);
                return `<button data-tag="${tag}" class="tag-filter-btn px-3 py-1 rounded-full text-[10px] font-semibold uppercase tracking-widest transition-all ${active ? 'bg-[#2A4747] text-white shadow-md scale-105' : 'bg-[#F5F2EB] text-[#2A2724]/60 border border-[#2A2724]/10 hover:bg-[#E8E2D2]'}">${tag}</button>`;
            }).join('');
            container.querySelectorAll('.tag-filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const t = btn.dataset.tag;
                    filterState.tags = filterState.tags.includes(t) ? filterState.tags.filter(x => x !== t) : [...filterState.tags, t];
                    renderTagFilters();
                    updatePreviewCount();
                });
            });
        }
        renderTagFilters();

        document.getElementById('toggle-all-tags').addEventListener('click', function() {
            filterState.tags = filterState.tags.length === allTags.length ? [] : [...allTags];
            renderTagFilters();
            updatePreviewCount();
            this.textContent = filterState.tags.length === allTags.length ? 'Clear All' : 'Select All';
        });

        document.querySelectorAll('.sort-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                filterState.sort = btn.dataset.sort;
                document.querySelectorAll('.sort-btn').forEach(b => {
                    b.classList.remove('bg-[#7BA08A]', 'text-white', 'shadow-lg', 'border-[#7BA08A]');
                    b.classList.add('bg-white', 'text-[#2A2724]/70', 'border-[#2A2724]/20');
                });
                btn.classList.remove('bg-white', 'text-[#2A2724]/70', 'border-[#2A2724]/20');
                btn.classList.add('bg-[#7BA08A]', 'text-white', 'shadow-lg', 'border-[#7BA08A]');
                updatePreviewCount();
            });
        });

        document.getElementById('sort-direction-toggle').addEventListener('click', function() {
            filterState.sortOrder = filterState.sortOrder === 'desc' ? 'asc' : 'desc';
            document.getElementById('sort-direction-label').textContent = filterState.sortOrder === 'desc' ? 'Descending' : 'Ascending';
            document.getElementById('sort-direction-icon').style.transform = filterState.sortOrder === 'asc' ? 'rotate(180deg)' : '';
            updatePreviewCount();
        });

        document.querySelectorAll('.star-filter').forEach(btn => {
            btn.addEventListener('click', () => {
                const rating = parseInt(btn.dataset.rating);
                filterState.minStars = rating;
                document.querySelectorAll('.star-filter').forEach(s => {
                    const isActive = parseInt(s.dataset.rating) <= rating;
                    s.classList.toggle('text-[#B08D57]', isActive);
                    s.classList.toggle('text-[#E8E2D2]', !isActive);
                    s.classList.toggle('opacity-40', !isActive);
                    s.classList.toggle('opacity-100', isActive);
                });
                const label = document.querySelector('.hand-label');
                if (label) label.textContent = `${rating}+ stars`;
                updatePreviewCount();
            });
        });

        function cardMatchesFilters(card) {
            const text   = card.dataset.text || '';
            const author = (card.dataset.author || '').toLowerCase();
            const tags   = card.dataset.tags ? card.dataset.tags.split(',').map(t => t.trim()) : [];
            const stars  = parseInt(card.dataset.stars) || 0;
            const matchesQuery = !filterState.query || text.includes(filterState.query) || author.includes(filterState.query);
            const matchesTags  = filterState.tags.length === 0 || filterState.tags.some(t => tags.includes(t));
            const matchesStars = stars >= filterState.minStars;
            return matchesQuery && matchesTags && matchesStars;
        }

        function updatePreviewCount() {
            const count = Array.from(cards).filter(c => cardMatchesFilters(c)).length;
            document.getElementById('filter-result-count').textContent = `${count} quotes`;
        }

        function applyFilters() {
            const cardsArr = Array.from(cards);
            cardsArr.forEach(c => { c.style.display = cardMatchesFilters(c) ? '' : 'none'; });
            const visible = cardsArr.filter(c => c.style.display !== 'none');
            const isDesc = filterState.sortOrder === 'desc';
            if (filterState.sort !== 'default') {
                visible.sort((a, b) => {
                    let cmp = 0;
                    if (filterState.sort === 'alphabetical') {
                        cmp = a.dataset.fulltext.localeCompare(b.dataset.fulltext);
                    } else if (filterState.sort === 'category') {
                        const catA = (a.dataset.tags || '').split(',')[0] || '';
                        const catB = (b.dataset.tags || '').split(',')[0] || '';
                        cmp = catA.localeCompare(catB);
                    } else if (filterState.sort === 'most-stars') {
                        cmp = parseInt(a.dataset.stars) - parseInt(b.dataset.stars);
                    }
                    return isDesc ? -cmp : cmp;
                });
                visible.forEach(c => quotesGrid.appendChild(c));
            }
            const total = cards.length;
            document.getElementById('count-label').textContent =
                visible.length === total ? `${total} entries` : `${visible.length} of ${total} entries`;
        }

        function openFilterModal() {
            filterModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            renderTagFilters();
            updatePreviewCount();
            const p = filterModal.querySelector('.swoosh-path');
            if (p) { p.style.animation = 'none'; p.offsetHeight; p.style.animation = null; }
        }

        function closeFilterModal() {
            filterModal.style.display = 'none';
            if (overlay.style.display !== 'flex') document.body.style.overflow = '';
        }

        function applyFilterSystem() { applyFilters(); closeFilterModal(); }

        function clearAllFilters() {
            filterState = { query: '', sort: 'default', sortOrder: 'desc', tags: [], minStars: 1 };
            document.getElementById('quotes-search').value = '';
            renderTagFilters();
            updatePreviewCount();
            document.querySelectorAll('.sort-btn').forEach((b, i) => {
                b.classList.remove('bg-[#7BA08A]', 'text-white', 'shadow-lg', 'border-[#7BA08A]');
                b.classList.add('bg-white', 'text-[#2A2724]/70', 'border-[#2A2724]/20');
                if (i === 0) {
                    b.classList.add('bg-[#7BA08A]', 'text-white', 'shadow-lg');
                    b.classList.remove('bg-white', 'text-[#2A2724]/70', 'border-[#2A2724]/20');
                }
            });
            document.querySelectorAll('.star-filter').forEach(s => {
                s.classList.toggle('text-[#B08D57]', parseInt(s.dataset.rating) <= 1);
                s.classList.toggle('text-[#E8E2D2]', parseInt(s.dataset.rating) > 1);
            });
            cards.forEach(c => { c.style.display = ''; });
            document.getElementById('count-label').textContent = `${cards.length} entries`;
        }

        document.getElementById('quotes-search').addEventListener('input', e => {
            filterState.query = e.target.value.toLowerCase().trim();
            applyFilters();
        });

        filterModal.addEventListener('click', (e) => { if (e.target === filterModal) closeFilterModal(); });
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') { doClose(); closeFilterModal(); }
        });

        updatePreviewCount();
    </script>
</body>
</html>