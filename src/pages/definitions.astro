---
import { getCollection } from 'astro:content';
import '../styles/global.css';
const definitions = await getCollection('definitions');

definitions.sort((a, b) => new Date(b.data.date_added).getTime() - new Date(a.data.date_added).getTime());

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

function starRotations(index: number) {
  const rotations = ['', 'style="transform: rotate(15deg);"', 'style="transform: rotate(-10deg);"'];
  return rotations[index] || '';
}
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlas Field Notes - Lexicon</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600;700&family=Reenie+Beanie&display=swap" rel="stylesheet">

    <style>
        :root {
            --font-serif: "EB Garamond", serif;
            --font-sans: Inter, sans-serif;
            --font-hand: "Reenie Beanie", cursive;
        }
        body {
            background-color: #FDFCF9;
            background-image: 
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png");
            background-position: 0px 0px, 40px 60px, 80px 20px;
            background-repeat: repeat;
            color: #2A2724;
        }
        .hand-underline-long { position: relative; display: inline-block; }
        .lexicon-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 40px;
        }
        .lexicon-card {
            background: white !important;
            padding: 24px;
            border: 1px solid #E8E2D2;
            border-radius: 24px;
            transition: all 0.3s ease;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            gap: 12px;
            position: relative;
        }
        .lexicon-card:hover {
            background: #F5F2EB !important;
            border-color: #D5CCB6;
            transform: translateY(-4px);
            box-shadow: 0 12px 24px -10px rgba(42, 39, 36, 0.1);
        }
        .lexicon-card:hover .card-word { color: #8B2626; }
        .card-word {
            font-family: var(--font-serif);
            font-size: 2.25rem;
            font-weight: 500;
            color: #2A2724;
            transition: color 0.3s ease;
            line-height: 1.1;
            display: flex;
            align-items: baseline;
            gap: 8px;
        }
        .card-pos {
            font-family: Inter, sans-serif;
            font-size: 0.65rem;
            font-style: italic;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: rgba(42, 39, 36, 0.65);
        }
        .card-snippet {
            font-family: var(--font-serif);
            font-size: 1.15rem;
            font-style: italic;
            line-height: 1.5;
            color: rgba(42, 39, 36, 0.75);
        }
        .card-note-container {
            margin-top: 8px;
            padding-top: 16px;
            border-top: 1px dashed #D5CCB6;
        }
        .card-note {
            font-family: var(--font-hand);
            font-size: 1.6rem;
            line-height: 1.1;
            color: #2A2724;
            display: block;
            margin-bottom: 8px;
            transform: rotate(-1deg);
        }
        .card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
        }
        .star-rating { display: flex; gap: 4px; color: #B08D57; }
        .card-date {
            font-family: Inter, sans-serif;
            font-size: 0.65rem;
            color: rgba(42, 39, 36, 0.4);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .glass-nav { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb {
            background-color: rgba(42, 39, 36, 0.12);
            border-radius: 10px;
            border: 2px solid transparent;
            background-clip: content-box;
        }
        ::-webkit-scrollbar-thumb:hover { background-color: rgba(42, 39, 36, 0.25); }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        @keyframes slideUpScale {
            from { opacity: 0; transform: translateY(40px) scale(0.97); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        @keyframes slideUpStagger {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
        .animate-modal-enter {
            opacity: 0;
            animation: slideUpScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s forwards;
        }
        .animate-sidebar-item {
            opacity: 0;
            animation: slideUpStagger 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }
        .stagger-1 { animation-delay: 0.2s; }
        .stagger-2 { animation-delay: 0.28s; }
        .stagger-3 { animation-delay: 0.36s; }
        .ink-stain {
            background-color: #FDFCF9;
            background-image: 
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                radial-gradient(circle at 10% 90%, rgba(42,39,36,0.03) 0%, rgba(253,252,249,0) 60%);
            background-position: 0px 0px, 40px 60px, 0 0;
            background-repeat: repeat, repeat, no-repeat;
        }
        .underline-svg { position: absolute; bottom: -8px; left: -5%; width: 110%; height: 20px; pointer-events: none; }
        .underline-path { fill: none; stroke: #B08D57; stroke-width: 2.5; stroke-linecap: round; }
        .modal-scroll::-webkit-scrollbar { width: 6px; }
        .modal-scroll::-webkit-scrollbar-track { background: transparent; }
        .modal-scroll::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.1); border-radius: 10px; }
        .swoosh-path { stroke-dasharray: 100; stroke-dashoffset: 100; }
        @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }
        .animate-draw-line { animation: drawSwoosh 0.8s ease-out 0.4s forwards; }
    </style>
</head>
<body class="min-h-screen bg-parchment-50 antialiased selection:bg-seal selection:text-white flex flex-col">

    <header class="sticky top-0 z-50 w-full h-[80px] bg-parchment-100/95 glass-nav border-b-[0.5px] border-ink-hairline flex items-center justify-between px-10 shadow-sm" style="border-bottom: 0.5px solid rgba(42, 39, 35, 0.12);">
        <div class="flex items-center gap-10">
            <a href="/astro-project-v2/" class="font-serif text-xl text-parchment-400 transition-all duration-300 ease-in-out hover:text-ink hover:-translate-y-[1px] hover:opacity-80">Main Page</a>
            <div class="h-8 w-px bg-parchment-200"></div>
            <div class="w-auto min-w-fit">
                <span class="font-hand text-[2rem] leading-none text-ink tracking-tight whitespace-nowrap translate-y-1 block">Knowledge Playground</span>
            </div>
            <div class="h-8 w-px bg-parchment-200"></div>
            <nav class="flex items-center gap-8 translate-y-[2px]">
                <a href="/astro-project-v2/concepts" class="font-serif text-xl text-parchment-400 transition-all duration-300 ease-in-out hover:text-ink hover:-translate-y-[1px] hover:opacity-80">Concepts</a>
                <a href="#" class="group flex items-center gap-2 transition-all duration-300 ease-in-out hover:-translate-y-[1px]">
                    <span class="w-1.5 h-1.5 rounded-full bg-seal shadow-[0_0_8px_rgba(139,38,38,0.4)]"></span>
                    <span class="font-serif text-xl text-ink">Definitions</span>
                </a>
                <a href="Grid Frameworks Main.html" class="font-serif text-xl text-parchment-400 transition-all duration-300 ease-in-out hover:text-ink hover:-translate-y-[1px] hover:opacity-80">Frameworks</a>
            </nav>
        </div>
        <div class="font-hand text-[1.75rem] leading-none text-ink tracking-tight translate-y-1">
            hyperlynxt | teo
        </div>
    </header>

    <main class="flex-1 pb-32">
        <section class="w-full bg-gradient-to-b from-parchment-100 to-transparent pt-20 pb-16 px-6">
            <div class="max-w-4xl mx-auto text-center">
                <span class="font-hand text-2xl text-parchment-500 mb-2 block">Personal Dictionary</span>
                <h2 class="font-serif text-5xl md:text-7xl leading-tight text-ink mb-8">
                    A Curated <span class="italic hand-underline-long inline-block">
                        Glossary
                        <svg class="absolute w-[110%] h-[12px] -bottom-2 -left-[5%] text-seal opacity-70 overflow-visible" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                            <path d="M0,8 C30,12 70,4 100,10" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path animate-draw-line"></path>
                        </svg>
                    </span>
                </h2>
                <p class="font-serif italic text-lg md:text-xl text-parchment-500 max-w-2xl mx-auto leading-relaxed">
                    A collection of specific words that gives shape to abstract feelings, unseen boundaries, and complex systems.
                </p>
            </div>
        </section>

        <div class="max-w-7xl mx-auto px-6 pb-40">
            <div class="lexicon-grid">
                {definitions.map((entry) => (
                    <div 
                        class="lexicon-card"
                        data-discipline={entry.data.discipline || ''}
                        data-stars={entry.data.rating}
                        data-usage="0"
                        data-tags={entry.data.tags.join(',')}
                        data-pronunciation={entry.data.pronunciation || ''}
                        data-etymology={entry.data.etymology || ''}
                        data-date={formatDate(entry.data.date_added)}
                    >
                        <div class="card-word">
                            {entry.data.title}
                            <span class="card-pos">{entry.data.part_of_speech}.</span>
                        </div>
                        <p class="card-snippet">{entry.data.definition}</p>
                        {entry.data.personal_note && (
                            <div class="card-note-container">
                                <span class="card-note">{entry.data.personal_note}</span>
                                <div class="card-footer">
                                    <div class="star-rating">
                                        {Array.from({ length: entry.data.rating }).map((_, i) => (
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style={i === 1 ? "transform: rotate(15deg);" : i === 2 ? "transform: rotate(-10deg);" : ""}>
                                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"></path>
                                            </svg>
                                        ))}
                                    </div>
                                    <span class="card-date">{formatDate(entry.data.date_added)}</span>
                                </div>
                            </div>
                        )}
                    </div>
                ))}
            </div>
        </div>
    </main>

    <div class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-white/80 backdrop-blur-xl border border-parchment-200 rounded-[24px] shadow-[0_20px_50px_rgba(42,39,36,0.15)] p-2.5 flex items-center z-50">
        <div class="flex items-center gap-3 pl-4 pr-3 py-2 group cursor-text" onclick="document.getElementById('def-search').focus()">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-parchment-400 group-hover:text-ink transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input type="text" id="def-search" placeholder="Search definitions" class="bg-transparent border-none outline-none font-sans text-xs font-bold text-ink placeholder:text-parchment-400 w-32 transition-all focus:w-48">
        </div>
        <div class="w-px h-6 bg-parchment-200 mx-1"></div>
        <button id="filter-btn" class="bg-ink hover:bg-ink/90 text-white rounded-xl px-5 py-2.5 text-[11px] uppercase tracking-widest font-sans font-bold transition-colors shadow-sm">
            Filter & Sort
        </button>
    </div>

    <!-- Definition Modal -->
    <div id="definition-modal" style="display:none;" class="fixed inset-0 bg-ink/40 hidden items-center justify-center z-[100] animate-fade-in p-6">
        <div class="bg-[#F9F7F2] w-full max-w-[580px] max-h-[90vh] rounded-[28px] p-10 relative shadow-[0_40px_100px_-20px_rgba(0,0,0,0.2)] border border-ink/5 animate-slide-up flex flex-col modal-scroll overflow-y-auto">
            <button id="close-modal" class="absolute top-6 right-6 w-11 h-11 rounded-full bg-parchment-200 flex items-center justify-center text-ink hover:bg-parchment-300 transition-colors text-lg focus:outline-none focus:ring-2 focus:ring-ink/20 shrink-0 z-10" aria-label="Close modal">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
            <header class="mb-7 pr-12 shrink-0">
                <div class="flex items-center gap-3 mb-2">
                    <span id="modal-pronunciation" class="font-serif text-[1.35rem] text-gold italic"></span>
                    <span id="modal-pos" class="font-sans text-[10px] uppercase tracking-[0.1em] text-ink-light border border-parchment-300 px-2 py-0.5 rounded"></span>
                </div>
                <h2 id="modal-word" class="font-serif text-[4.25rem] font-normal leading-[0.9] text-ink mb-5 tracking-tight"></h2>
                <div id="modal-tags" class="flex flex-wrap items-center gap-2"></div>
            </header>
            <div id="modal-definition" class="font-serif text-xl leading-[1.65] text-ink mb-8 pl-6 border-l-[3px] border-gold/40 shrink-0"></div>
            <div class="flex flex-col gap-6 border-t border-parchment-200 pt-7 mt-auto shrink-0">
                <div class="flex justify-between items-start gap-6">
                    <div class="flex-1">
                        <span class="font-sans text-[10px] uppercase tracking-[0.12em] text-ink-light mb-2 block font-medium">Etymology Source</span>
                        <p id="modal-etymology" class="font-serif italic text-ink-muted text-[0.95rem] leading-snug"></p>
                    </div>
                    <div id="modal-stars" class="flex gap-1 mt-0.5 shrink-0" style="color: #B08D57;"></div>
                </div>
                <div class="bg-parchment-100 rounded-xl p-5 border border-dashed border-parchment-300 relative">
                    <span class="font-sans text-[10px] uppercase tracking-[0.12em] text-ink-light mb-3 block font-medium absolute top-4 right-5 bg-parchment-100 px-1">Personal Note</span>
                    <span id="modal-note" class="font-hand text-[1.85rem] text-ink leading-tight -rotate-1 block mt-2"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Modal -->
    <div id="filter-modal" style="display:none" class="fixed inset-0 z-[110] flex items-center justify-center p-6 bg-parchment-100/40 backdrop-blur-md animate-fade-in">
        <div class="relative z-20 w-full max-w-[630px] bg-white rounded-[28px] shadow-2xl border border-white/60 overflow-hidden flex flex-col max-h-[85vh] animate-modal-enter ink-stain">
            <div class="px-7 pt-7 pb-4 border-b border-parchment-dark/15 flex justify-between items-start relative bg-white/50 backdrop-blur-md z-10 flex-shrink-0">
                <div>
                    <div class="font-hand text-xl text-parchment-400 -rotate-2 transform origin-left mb-1 opacity-80">Refine the collection</div>
                    <h2 class="text-3xl font-serif font-medium text-ink relative inline-block">
                        Filter & Sort
                        <svg class="absolute w-[110%] h-[12px] -bottom-1 -left-1 text-seal opacity-70 overflow-visible" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                            <path d="M2 7C25 2 75 -1 98 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path animate-draw-line"></path>
                        </svg>
                    </h2>
                </div>
                <button id="close-filter-btn" class="w-8 h-8 rounded-full bg-parchment-50 border border-parchment-dark/20 flex items-center justify-center text-ink/50 hover:text-ink hover:bg-parchment-100 transition-all focus:outline-none focus:ring-2 focus:ring-seal/30 mt-1 group">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <div class="px-7 py-6 overflow-y-auto modal-scrollbar relative z-0 flex-grow space-y-8 h-[500px]">
                <div class="animate-sidebar-item stagger-1">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-seal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-ink/50">Sort Order</h3>
                        </div>
                        <button id="sort-direction-toggle" class="flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-parchment-50 border border-parchment-dark/20 text-[10px] font-bold uppercase tracking-wider text-ink/60 hover:text-seal hover:border-seal/30 transition-all group">
                            <span id="sort-direction-label">Descending</span>
                            <svg id="sort-direction-icon" xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M7 15l5 5 5-5M7 9l5-5 5 5"/></svg>
                        </button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button data-sort="alphabetical" class="sort-btn px-4 py-2 bg-seal text-white font-sans text-sm font-medium rounded-full shadow-lg border border-seal transition-all">Alphabetical</button>
                        <button data-sort="recently-added" class="sort-btn px-4 py-2 bg-white text-ink/70 font-sans text-sm font-medium rounded-full border border-parchment-dark/30 hover:border-parchment-dark hover:text-ink transition-all shadow-sm">Recently Added</button>
                        <button data-sort="rating" class="sort-btn px-4 py-2 bg-white text-ink/70 font-sans text-sm font-medium rounded-full border border-parchment-dark/30 hover:border-parchment-dark hover:text-ink transition-all shadow-sm">Rating</button>
                    </div>
                </div>
                <div class="w-full h-px bg-gradient-to-r from-transparent via-parchment-dark/20 to-transparent"></div>
                <div class="animate-sidebar-item stagger-2">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-seal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-ink/50">Minimum Rating</h3>
                        </div>
                        <span class="font-hand text-lg text-seal" id="min-rating-label">1+ stars</span>
                    </div>
                    <div class="flex gap-2 p-3 bg-white border border-parchment-dark/10 rounded-xl shadow-inner-subtle w-fit" id="filter-utility-stars">
                        <button data-rating="1" class="star-filter text-gold hover:scale-110 transition-transform"><svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg></button>
                        <button data-rating="2" class="star-filter text-parchment-200 hover:scale-110 transition-transform"><svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg></button>
                        <button data-rating="3" class="star-filter text-parchment-200 hover:scale-110 transition-transform"><svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg></button>
                    </div>
                </div>
                <div class="w-full h-px bg-gradient-to-r from-transparent via-parchment-dark/20 to-transparent"></div>
                <div class="animate-sidebar-item stagger-3">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-seal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-ink/50">Filter by Tags</h3>
                        </div>
                        <button id="toggle-all-tags" class="font-sans text-[10px] font-bold uppercase tracking-wider text-seal/60 hover:text-seal transition-colors">Select All</button>
                    </div>
                    <div id="filter-tags-container" class="flex flex-wrap gap-2"></div>
                </div>
            </div>
            <div class="p-6 border-t border-parchment-dark/15 bg-parchment-50 relative z-10 flex items-center justify-between flex-shrink-0">
                <button id="clear-filter-btn" class="font-sans text-sm font-medium text-ink/50 hover:text-ink transition-colors underline underline-offset-4 decoration-parchment-300">Clear Filters</button>
                <button id="apply-filter-btn" class="bg-ink hover:bg-black text-white px-6 py-3 rounded-xl font-sans text-sm font-medium transition-all shadow-md hover:-translate-y-0.5 flex items-center gap-2">
                    <span>Apply Filters</span>
                    <span id="filter-result-count" class="font-hand text-lg text-white/80 pt-0.5">-- definitions</span>
                </button>
            </div>
        </div>
    </div>

    <script>
        const searchInput = document.getElementById('def-search');
        const cards = document.querySelectorAll('.lexicon-card');
        const definitionModal = document.getElementById('definition-modal');
        const closeDefModalBtn = document.getElementById('close-modal');
        const filterModal = document.getElementById('filter-modal');
        document.getElementById('filter-btn').addEventListener('click', openFilterModal);
	document.getElementById('filter-btn').addEventListener('click', openFilterModal);
	document.getElementById('close-filter-btn').addEventListener('click', closeFilterModal);
	document.getElementById('apply-filter-btn').addEventListener('click', applyFilterSystem);
	document.getElementById('clear-filter-btn').addEventListener('click', clearAllFilters);
        const filterResultCount = document.getElementById('filter-result-count');
        const filterSortButtons = document.querySelectorAll('.sort-btn');
        const filterStarButtons = document.querySelectorAll('.star-filter');
        const lexiconGrid = document.querySelector('.lexicon-grid');


        const modalWord = document.getElementById('modal-word');
        const modalPOS = document.getElementById('modal-pos');
        const modalDef = document.getElementById('modal-definition');
        const modalNote = document.getElementById('modal-note');
        const modalStars = document.getElementById('modal-stars');
        const modalPronunciation = document.getElementById('modal-pronunciation');
        const modalEtymology = document.getElementById('modal-etymology');
        const modalTags = document.getElementById('modal-tags');

        let currentFilterState = {
            query: '',
            sort: 'alphabetical',
            sortOrder: 'asc',
            minRating: 0,
            tags: []
        };

        // Build tag list from cards
        const availableTags = new Set();
        cards.forEach(card => {
            const tags = card.getAttribute('data-tags');
            if (tags) tags.split(',').forEach(t => { if(t.trim()) availableTags.add(t.trim()); });
        });

        const filterTagsContainer = document.getElementById('filter-tags-container');
        const sortedTags = Array.from(availableTags).sort();

        function renderFilterTags() {
            filterTagsContainer.innerHTML = sortedTags.map((tag) => {
                const isActive = currentFilterState.tags.includes(tag);
                return `<button data-tag="${tag}" class="tag-filter-btn px-3 py-1 rounded-full text-[10px] font-semibold uppercase tracking-widest transition-all
                    ${isActive ? 'bg-seal text-white shadow-md scale-105' : 'bg-seal/10 text-seal border border-seal/20 hover:bg-seal/20'}">${tag}</button>`;
            }).join('');
            document.querySelectorAll('.tag-filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const tag = btn.getAttribute('data-tag');
                    if (currentFilterState.tags.includes(tag)) {
                        currentFilterState.tags = currentFilterState.tags.filter(t => t !== tag);
                    } else {
                        currentFilterState.tags.push(tag);
                    }
                    renderFilterTags();
                    updateFilterPreview();
                });
            });
        }

        renderFilterTags();

        document.getElementById('toggle-all-tags').addEventListener('click', (e) => {
            const btn = e.target;
            if (currentFilterState.tags.length === sortedTags.length) {
                currentFilterState.tags = [];
                btn.textContent = 'Select All';
            } else {
                currentFilterState.tags = [...sortedTags];
                btn.textContent = 'Clear All';
            }
            renderFilterTags();
            updateFilterPreview();
        });

        function openFilterModal() {
            filterModal.classList.remove('hidden');
            filterModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            const path = filterModal.querySelector('.swoosh-path');
            if (path) { path.style.animation = 'none'; path.offsetHeight; path.style.animation = null; }
            updateFilterPreview();
        }

        function closeFilterModal() {
            filterModal.classList.add('hidden');
            filterModal.style.display = 'none';
            if (!definitionModal.classList.contains('flex')) document.body.style.overflow = '';
        }

        filterSortButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                currentFilterState.sort = btn.getAttribute('data-sort');
                filterSortButtons.forEach(b => {
                    b.classList.remove('bg-seal', 'text-white', 'shadow-lg', 'border-seal');
                    b.classList.add('bg-white', 'text-ink/70', 'border-parchment-dark/30');
                });
                btn.classList.add('bg-seal', 'text-white', 'shadow-lg', 'border-seal');
                btn.classList.remove('bg-white', 'text-ink/70', 'border-parchment-dark/30');
                updateFilterPreview();
            });
        });

        const sortDirectionBtn = document.getElementById('sort-direction-toggle');
        const sortDirectionLabel = document.getElementById('sort-direction-label');
        const sortDirectionIcon = document.getElementById('sort-direction-icon');

        sortDirectionBtn.addEventListener('click', () => {
            currentFilterState.sortOrder = currentFilterState.sortOrder === 'desc' ? 'asc' : 'desc';
            sortDirectionLabel.textContent = currentFilterState.sortOrder === 'desc' ? 'Descending' : 'Ascending';
            sortDirectionIcon.style.transform = currentFilterState.sortOrder === 'desc' ? 'rotate(0deg)' : 'rotate(180deg)';
            updateFilterPreview();
        });

        filterStarButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                const rating = parseInt(btn.getAttribute('data-rating'));
                currentFilterState.minRating = rating;
                filterStarButtons.forEach((star, index) => {
                    star.classList.toggle('text-gold', index < rating);
                    star.classList.toggle('text-parchment-200', index >= rating);
                });
                document.getElementById('min-rating-label').textContent = `${rating}+ stars`;
                updateFilterPreview();
            });
        });

        function shouldShowCard(card) {
            const cardStars = parseInt(card.getAttribute('data-stars')) || 0;
            const cardWord = card.querySelector('.card-word').textContent.toLowerCase();
            const cardSnippet = card.querySelector('.card-snippet')?.textContent.toLowerCase() || '';
            const cardTags = card.getAttribute('data-tags') ? card.getAttribute('data-tags').split(',').map(t => t.trim()) : [];

            const queryMatch = !currentFilterState.query || cardWord.includes(currentFilterState.query) || cardSnippet.includes(currentFilterState.query);
            const starMatch = cardStars >= currentFilterState.minRating;
            const tagsMatch = currentFilterState.tags.length === 0 || currentFilterState.tags.some(t => cardTags.includes(t));

            return queryMatch && starMatch && tagsMatch;
        }

        function updateFilterPreview() {
            let count = 0;
            cards.forEach(card => { if (shouldShowCard(card)) count++; });
            filterResultCount.textContent = `${count} definitions`;
        }

        function applyFilterSystem() {
            cards.forEach(card => { card.style.display = shouldShowCard(card) ? 'flex' : 'none'; });
            sortCards();
            closeFilterModal();
        }

        function sortCards() {
            const cardsArray = Array.from(cards);
            const isDesc = currentFilterState.sortOrder === 'desc';
            cardsArray.sort((a, b) => {
                let result = 0;
                if (currentFilterState.sort === 'alphabetical') {
                    result = a.querySelector('.card-word').textContent.trim().localeCompare(b.querySelector('.card-word').textContent.trim());
                } else if (currentFilterState.sort === 'rating') {
                    result = parseInt(a.getAttribute('data-stars')) - parseInt(b.getAttribute('data-stars'));
                }
                return isDesc ? -result : result;
            });
            cardsArray.forEach(card => lexiconGrid.appendChild(card));
        }

        function clearAllFilters() {
            currentFilterState = { query: '', sort: 'alphabetical', sortOrder: 'asc', minRating: 0, tags: [] };
            renderFilterTags();
            filterStarButtons.forEach(star => {
                star.classList.remove('text-gold');
                star.classList.add('text-parchment-200');
            });
            document.getElementById('min-rating-label').textContent = '1+ stars';
            applyFilterSystem();
        }

        searchInput.addEventListener('input', (e) => {
            currentFilterState.query = e.target.value.toLowerCase().trim();
            applyFilterSystem();
        });

        // Card click → open modal with full data
        cards.forEach(card => {
            card.addEventListener('click', () => {
                const wordEl = card.querySelector('.card-word');
                const wordText = Array.from(wordEl.childNodes).filter(n => n.nodeType === 3).map(n => n.textContent.trim()).join(' ');
                const pos = card.querySelector('.card-pos').textContent;
                const snippet = card.querySelector('.card-snippet')?.textContent || '';
                const note = card.querySelector('.card-note')?.textContent || '';
                const starsCount = parseInt(card.getAttribute('data-stars')) || 0;
                const pronunciation = card.getAttribute('data-pronunciation') || '';
                const etymology = card.getAttribute('data-etymology') || '';
                const tags = card.getAttribute('data-tags') ? card.getAttribute('data-tags').split(',').map(t => t.trim()).filter(Boolean) : [];

                modalWord.textContent = wordText;
                modalPOS.textContent = pos;
                modalDef.textContent = snippet;
                modalNote.textContent = note;
                modalPronunciation.textContent = pronunciation;
                modalEtymology.textContent = etymology;

                modalTags.innerHTML = tags.map(tag =>
                    `<span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-semibold uppercase tracking-widest text-teal bg-teal/10">${tag}</span>`
                ).join('');

                const rotations = ['', 'transform: rotate(15deg);', 'transform: rotate(-10deg);'];
                modalStars.innerHTML = Array.from({ length: starsCount }).map((_, i) =>
                    `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="${rotations[i] || ''}"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"></path></svg>`
                ).join('');

		definitionModal.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            });
        });

        const hideDefModal = () => {
            definitionModal.style.display = 'none';
            if (filterModal.style.display !== 'flex') document.body.style.overflow = '';
        };

        closeDefModalBtn.addEventListener('click', hideDefModal);
        definitionModal.addEventListener('click', (e) => { if (e.target === definitionModal) hideDefModal(); });
	filterModal.addEventListener('click', (e) => { if (e.target === filterModal) closeFilterModal(); });
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') { closeFilterModal(); hideDefModal(); }
        });

        updateFilterPreview();
    </script is:inline>
</body>
</html>