---
import { getCollection, render } from 'astro:content';
import '../styles/global.css';
import ContentNoteModal from '../components/ContentNoteModal.astro';

const contentNotes = await getCollection('contentNotes');
contentNotes.sort((a, b) => {
  const ratingA = a.data.rating || 0;
  const ratingB = b.data.rating || 0;
  if (ratingB !== ratingA) return ratingB - ratingA;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const renderedNotes = await Promise.all(
  contentNotes.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

const accentColor = "#B4BCC0";
const accentColorDark = "#8C8C8C";
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlas Field Notes - Content Notes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600;700&family=Reenie+Beanie&display=swap" rel="stylesheet">
    <style define:vars={{ accentColor, accentColorDark }}>
        body {
            background-color: #FDFCF9;
            background-image: 
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png");
            background-position: 0px 0px, 40px 60px, 80px 20px;
            background-repeat: repeat;
            color: #2A2724;
        }
        .hand-underline-sm { position: relative; display: inline-block; }
        .catalog-card {
            background: white !important;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
        }
        .catalog-card:hover {
            background: #F5F2EB !important;
            border-color: #D5CCB6;
            transform: translateY(-4px);
            box-shadow: 0 12px 24px -10px rgba(42, 39, 36, 0.1);
        }
        .catalog-card:hover .model-title { color: var(--accentColorDark); }
        .bookmark-icon {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            color: #A39985;
            transition: color 0.2s ease;
            z-index: 10;
        }
        .catalog-card:hover .bookmark-icon { color: var(--accentColorDark); }
        .star-rating { display: flex; gap: 4px; color: var(--accentColorDark); }
        .masonry-grid {
            position: relative;
            width: 100%;
            transition: height 0.4s ease;
        }
        .masonry-item-wrapper {
            position: absolute;
            transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.4s ease, width 0.4s ease;
            padding: 0;
            margin: 0;
        }
        .masonry-item { 
            break-inside: avoid; 
            margin-bottom: 1.25rem; 
            display: block; 
            position: relative;
        }
        .glass-nav { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.12); border-radius: 10px; border: 2px solid transparent; background-clip: content-box; }
        ::-webkit-scrollbar-thumb:hover { background-color: rgba(42, 39, 36, 0.25); }
        
        @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }
        .swoosh-path { stroke-dasharray: 100; stroke-dashoffset: 100; }
        .animate-draw-line { animation: drawSwoosh 0.8s ease-out 0.4s forwards; }

        .catalog-card strong {
            color: var(--accentColorDark) !important;
            font-weight: 600 !important;
        }
    </style>
</head>
<body class={`min-h-screen antialiased selection:bg-[${accentColor}] selection:text-white flex flex-col`}>

    <header class="sticky top-0 z-50 w-full h-[80px] bg-[#F5F2EB]/95 glass-nav flex items-center justify-between px-10 shadow-sm" style="border-bottom: 0.5px solid rgba(42, 39, 35, 0.12);">
        <div class="flex items-center gap-10">
            <a href="/astro-project-v2/" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Main Page</a>
            <div class="h-8 w-px bg-[#E8E2D2]"></div>
            <nav class="flex items-center gap-8 translate-y-[2px]">
                <a href="/astro-project-v2/content-notes" class="group flex items-center gap-2 transition-all duration-300 hover:-translate-y-[1px]">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#B4BCC0] shadow-[0_0_8px_rgba(180,188,192,0.4)]"></span>
                    <span class="font-serif text-xl text-[#2A2724]">Content Notes</span>
                </a>
                <a href="/astro-project-v2/research-dives" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Research Dives</a>
            </nav>
        </div>
        <div class="font-['Reenie_Beanie'] text-[1.75rem] leading-none tracking-tight translate-y-1 text-[#B4BCC0]">hyperlynxt | teo</div>
    </header>

    <main class="flex-1 pb-32">
        <section class="w-full bg-gradient-to-b from-[#F5F2EB] to-transparent pt-20 pb-16 px-6">
            <div class="max-w-4xl mx-auto text-center">
                <span class="font-['Reenie_Beanie'] text-2xl text-[#8C8070] mb-2 block">Part IV</span>
                <h2 class="font-serif text-5xl md:text-7xl leading-tight text-[#2A2724] mb-8">
                    Learning & <span class="italic hand-underline-sm inline-block">
                        Research
                        <svg class="absolute w-[110%] h-[12px] -bottom-1 -left-[5%] text-[#B4BCC0] opacity-70 overflow-visible" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                            <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path animate-draw-line"></path>
                        </svg>
                    </span>
                </h2>
                <p class="font-serif italic text-lg md:text-xl text-[#8C8070] max-w-2xl mx-auto leading-relaxed">
                    Notes on content consumed, research conducted, and knowledge syntheses.
                </p>
            </div>
        </section>
        <div class="max-w-7xl mx-auto px-6 mb-12 flex items-center justify-between pb-4" style="border-bottom: 1px solid rgba(42,39,35,0.08);">
            <span class="font-sans text-[10px] font-bold uppercase tracking-[0.14em] text-[#2A2724]/40">The Field Notes</span>
            <span id="note-count-label" class="font-serif italic text-[#2A2724]/35 text-sm">{contentNotes.length} notes</span>
        </div>

        <div class="max-w-7xl mx-auto px-6">
            <div class="masonry-grid">
                {renderedNotes.map(({ entry, Content }) => (
                    <div class="masonry-item-wrapper">
                        <article
                            class="masonry-item catalog-card group bg-white rounded-3xl border border-[#E8E2D2] p-8 flex flex-col gap-6 transition-all duration-500 hover:shadow-[0_20px_40px_-15px_rgba(213,204,182,0.5)]"
                            data-title={entry.data.title}
                            data-description={entry.data.description}
                            data-id={entry.id}
                            data-source={entry.data.source || ''}
                            data-tags={entry.data.tags.join(',')}
                            data-rating={entry.data.rating}
                            data-summary={entry.data.summary || ''}
                        >
                            <svg class="bookmark-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plug-zap-icon lucide-plug-zap"><path d="M6.3 20.3a2.4 2.4 0 0 0 3.4 0L12 18l-6-6-2.3 2.3a2.4 2.4 0 0 0 0 3.4Z"/><path d="m2 22 3-3"/><path d="M7.5 13.5 10 11"/><path d="M10.5 16.5 13 14"/><path d="m18 3-4 4h6l-4 4"/></svg>
                            <div class="flex flex-col gap-2">
                                <p class="font-sans text-[10px] font-bold uppercase tracking-widest text-[#B4BCC0] opacity-80">{entry.data.source || 'General Research'}</p>
                                <h3 class="model-title font-serif text-3xl font-medium text-[#2A2724] transition-colors leading-tight">{entry.data.title}</h3>
                                <p class="font-serif text-[#8C8070] text-[16px] leading-relaxed mt-2" set:html={(entry.data.description || '').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}></p>
                            </div>
                            <div class="pt-5 border-t border-[#F5F2EB]/80 mt-auto">
                                <div class="flex items-center justify-between mb-3">
                                    <div class="star-rating">
                                        {Array.from({ length: entry.data.rating || 0 }).map((_, i) => (
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" style={i === 1 ? "transform: rotate(15deg);" : i === 2 ? "transform: rotate(-10deg);" : i === 3 ? "transform: rotate(5deg);" : ""}>
                                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.3"></path>
                                            </svg>
                                        ))}
                                    </div>
                                    <div class="flex items-center gap-1.5 opacity-40 group-hover:opacity-100 transition-opacity">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#B4BCC0]"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                        <span class="font-sans text-[10px] font-bold uppercase tracking-widest text-[#2A2724]">Research Note</span>
                                    </div>
                                </div>
                            </div>
                        </article>
                    </div>
                ))}
            </div>
        </div>
    </main>

    <style>
        .star-filter { transition: all 0.25s ease; cursor: pointer; display: flex; align-items: center; justify-content: center; }
        .star-filter.active { color: var(--accentColor) !important; opacity: 1 !important; }
        .star-filter.active svg { color: var(--accentColor) !important; }
        .star-filter.active svg path { fill: var(--accentColor) !important; fill-opacity: 0.2 !important; stroke: var(--accentColor) !important; stroke-width: 1.5 !important; }
        .star-filter:not(.active) { color: #A39985 !important; opacity: 0.5 !important; }
        .star-filter:not(.active) svg { color: #A39985 !important; }
        .star-filter:not(.active) svg path { fill: #A39985 !important; fill-opacity: 0.1 !important; stroke: #A39985 !important; stroke-width: 1.5 !important; }
        .star-filter:hover { transform: scale(1.1); }
    </style>

    <ContentNoteModal />

    <!-- Filter Modal -->
    <div id="filter-modal" style="display:none;" class="fixed inset-0 z-[60] items-center justify-center p-6 bg-[#F5F2EB]/40 backdrop-blur-md">
        <div class="relative z-20 w-full max-w-[630px] bg-white rounded-[28px] shadow-2xl border border-white/60 overflow-hidden flex flex-col max-h-[85vh] ink-stain">
            <div class="px-7 pt-9 pb-6 border-b border-[#D5CCB6]/15 flex flex-col items-center justify-center bg-white/50 backdrop-blur-md z-10 flex-shrink-0 relative">
                <div class="text-center w-full">
                    <h2 class="text-3xl md:text-4xl font-serif font-medium text-[#2A2724] relative inline-block">
                        Filter & Sort
                        <svg class="absolute w-[110%] h-[15px] -bottom-2 -left-[5%] text-[#B4BCC0] opacity-80 overflow-visible" viewBox="0 0 100 10" fill="none" preserveAspectRatio="none">
                            <path d="M0 7 Q12.5 10 25 6 T50 7 T75 6 T100 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="swoosh-path animate-draw-line"/>
                        </svg>
                    </h2>
                </div>
                <button id="close-filter-btn" class="absolute top-7 right-7 w-8 h-8 rounded-full bg-[#FDFCF9] border border-[#D5CCB6]/20 flex items-center justify-center text-[#2A2724]/50 hover:text-[#2A2724] hover:bg-[#F5F2EB] transition-all group">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <div class="px-7 py-6 overflow-y-auto modal-scrollbar relative z-0 flex-grow space-y-8 h-[400px]">
                <!-- Sort -->
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#B4BCC0]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Sort Order</h3>
                        </div>
                        <button id="sort-direction-toggle" class="flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-[#FDFCF9] border border-[#D5CCB6]/20 text-[10px] font-bold uppercase tracking-wider text-[#2A2724]/60 hover:text-[#B4BCC0] transition-all group">
                            <span id="sort-direction-label">Descending</span>
                            <svg id="sort-direction-icon" xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M7 15l5 5 5-5M7 9l5-5 5 5"/></svg>
                        </button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button data-sort="rating" class="sort-btn px-4 py-2 bg-[#B4BCC0] text-white font-sans text-sm font-medium rounded-full shadow-lg border border-[#B4BCC0] transition-all">Rating</button>
                        <button data-sort="date" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:text-[#2A2724] transition-all shadow-sm">Date</button>
                        <button data-sort="alphabetical" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:text-[#2A2724] transition-all shadow-sm">Alphabetical</button>
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#2A2724]/15 to-transparent"></div>

                <!-- Stars -->
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#B4BCC0]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Minimum Utility</h3>
                        </div>
                        <span id="min-rating-label" class="font-['Reenie_Beanie'] text-lg text-[#B4BCC0]">1+ stars</span>
                    </div>
                    <div class="flex gap-3 p-3.5 bg-white border border-[#D5CCB6]/20 rounded-2xl w-fit shadow-inner" id="filter-utility-stars">
                        <button data-rating="1" class="star-filter active active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"></path>
                            </svg>
                        </button>
                        <button data-rating="2" class="star-filter active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(15deg)">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"></path>
                            </svg>
                        </button>
                        <button data-rating="3" class="star-filter active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(-10deg)">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"></path>
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#2A2724]/15 to-transparent"></div>

                <!-- Tags -->
                <div class="pb-4">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#B4BCC0]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Filter by Tags</h3>
                        </div>
                        <button id="toggle-all-tags" class="font-sans text-[10px] font-bold uppercase tracking-wider text-[#B4BCC0]/60 hover:text-[#B4BCC0] transition-colors">Select All</button>
                    </div>
                    <div id="filter-tags-container" class="flex flex-wrap gap-2"></div>
                </div>
            </div>

            <div class="p-6 border-t border-[#D5CCB6]/15 bg-[#FDFCF9] relative z-10 flex items-center justify-between flex-shrink-0">
                <button id="clear-filter-btn" class="font-['Reenie_Beanie'] text-[1.4rem] font-medium text-[#B4BCC0] hover:bg-[#B4BCC0]/10 px-4 py-1.5 rounded-lg transition-all underline underline-offset-4">Clear Filters</button>
                <button id="apply-filter-btn" class="bg-[#B4BCC0] hover:bg-[#8C8C8C] text-white px-6 py-3 rounded-xl font-sans text-sm font-medium transition-all shadow-md hover:-translate-y-0.5 flex items-center gap-2">
                    <span>Apply Filters</span>
                    <span id="filter-result-count" class="font-['Reenie_Beanie'] text-lg text-white/80 pt-0.5">-- notes</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Bottom Bar -->
    <div class="fixed bottom-10 left-0 right-0 flex justify-center pointer-events-none z-50">
        <div class="bg-white/80 backdrop-blur-xl border border-[#E8E2D2] rounded-[24px] shadow-[0_20px_50px_rgba(42,39,36,0.15)] p-2.5 flex items-center pointer-events-auto">
            <div class="flex items-center gap-3 pl-4 pr-3 py-2 group cursor-text" onclick="document.getElementById('note-search').focus()">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#A39985] group-hover:text-[#B4BCC0] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <input type="text" id="note-search" placeholder="Search notes" class="bg-transparent border-none outline-none font-sans text-xs font-bold text-[#2A2724] placeholder:text-[#A39985] w-32 transition-all focus:w-48">
            </div>
            <div class="w-px h-6 bg-[#E8E2D2] mx-1"></div>
            <button id="filter-btn" class="bg-[#B4BCC0] hover:bg-[#B4BCC0]/90 text-white rounded-xl px-5 py-2.5 text-[11px] uppercase tracking-widest font-sans font-bold transition-colors shadow-sm">Filter & Sort</button>
        </div>
    </div>

    <!-- Data for JS -->
    <script id="notes-data" type="application/json" is:inline set:html={JSON.stringify(contentNotes.map(c => ({
            id: c.id,
            ...c.data,
            date: c.data.date?.toISOString()
        })))} />
    <div style="display:none;" aria-hidden="true">
        {renderedNotes.map(({ entry, Content }) => (
            <div id={`note-content-${entry.id}`}><Content /></div>
        ))}
    </div>

    <script is:inline>
        // Data and DOM
        const notesJSON = JSON.parse(document.getElementById('notes-data').textContent);
        const searchInput = document.getElementById('note-search');
        const cards = document.querySelectorAll('.catalog-card');
        const filterModal = document.getElementById('filter-modal');
        const filterResultCount = document.getElementById('filter-result-count');
        const filterSortButtons = document.querySelectorAll('.sort-btn');
        const filterStarButtons = document.querySelectorAll('.star-filter');
        const masonryGrid = document.querySelector('.masonry-grid');
        const filterTagsContainer = document.getElementById('filter-tags-container');

        // Attach all button listeners
        document.getElementById('filter-btn').addEventListener('click', openFilterModal);
        document.getElementById('close-filter-btn').addEventListener('click', closeFilterModal);
        document.getElementById('apply-filter-btn').addEventListener('click', applyFilterSystem);
        document.getElementById('clear-filter-btn').addEventListener('click', clearAllFilters);
        
        let currentFilterState = {
            query: '',
            sort: 'rating',
            sortOrder: 'desc',
            tags: [],
            minUtility: 0
        };

        // Build tags
        const availableTags = new Set();
        cards.forEach(card => {
            const tags = card.getAttribute('data-tags') || '';
            if (tags) tags.split(',').forEach(t => { if(t.trim()) availableTags.add(t.trim()); });
        });
        const sortedTags = Array.from(availableTags).sort();

        function renderFilterTags() {
            filterTagsContainer.innerHTML = sortedTags.map(tag => {
                const isActive = currentFilterState.tags.includes(tag);
                return `<button data-tag="${tag}" class="tag-filter-btn px-3 py-1 rounded-full text-[10px] font-semibold uppercase tracking-widest transition-all ${isActive ? 'bg-[#B4BCC0] text-white shadow-md' : 'bg-[#B4BCC0]/10 text-[#B4BCC0] border border-[#B4BCC0]/20 hover:bg-[#B4BCC0]/20'}">${tag}</button>`;
            }).join('');
            document.querySelectorAll('.tag-filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const tag = btn.getAttribute('data-tag');
                    if (currentFilterState.tags.includes(tag)) {
                        currentFilterState.tags = currentFilterState.tags.filter(t => t !== tag);
                    } else {
                        currentFilterState.tags.push(tag);
                    }
                    renderFilterTags();
                    updateFilterPreview();
                });
            });
        }
        renderFilterTags();

        document.getElementById('toggle-all-tags').addEventListener('click', (e) => {
            if (currentFilterState.tags.length === sortedTags.length) {
                currentFilterState.tags = [];
                e.target.textContent = 'Select All';
            } else {
                currentFilterState.tags = [...sortedTags];
                e.target.textContent = 'Clear All';
            }
            renderFilterTags();
            updateFilterPreview();
        });

        filterSortButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                currentFilterState.sort = btn.getAttribute('data-sort');
                filterSortButtons.forEach(b => {
                    b.classList.remove('bg-[#B4BCC0]', 'text-white', 'shadow-lg', 'border-[#B4BCC0]');
                    b.classList.add('bg-white', 'text-[#2A2724]/70');
                });
                btn.classList.add('bg-[#B4BCC0]', 'text-white', 'shadow-lg');
                btn.classList.remove('bg-white', 'text-[#2A2724]/70');
                updateFilterPreview();
            });
        });

        const sortDirectionBtn = document.getElementById('sort-direction-toggle');
        const sortDirectionLabel = document.getElementById('sort-direction-label');
        const sortDirectionIcon = document.getElementById('sort-direction-icon');
        sortDirectionBtn.addEventListener('click', () => {
            currentFilterState.sortOrder = currentFilterState.sortOrder === 'desc' ? 'asc' : 'desc';
            sortDirectionLabel.textContent = currentFilterState.sortOrder === 'desc' ? 'Descending' : 'Ascending';
            sortDirectionIcon.style.transform = currentFilterState.sortOrder === 'desc' ? 'rotate(0deg)' : 'rotate(180deg)';
            updateFilterPreview();
        });

        filterStarButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                const rating = parseInt(btn.getAttribute('data-rating'));
                currentFilterState.minUtility = rating;
                document.getElementById('min-rating-label').textContent = `${rating}+ stars`;
                filterStarButtons.forEach(b => {
                    if (parseInt(b.getAttribute('data-rating')) <= rating) b.classList.add('active');
                    else b.classList.remove('active');
                });
                updateFilterPreview();
            });
        });

        function openFilterModal() {
            filterModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            updateFilterPreview();
        }

        function closeFilterModal() {
            filterModal.style.display = 'none';
            document.body.style.overflow = '';
        }

        filterModal.onclick = (e) => { if (e.target === filterModal) closeFilterModal(); };

        searchInput.addEventListener('input', (e) => {
            currentFilterState.query = e.target.value.toLowerCase();
            applyFilterSystem();
        });

        function updateFilterPreview() {
            const filtered = getFilteredData();
            filterResultCount.textContent = `${filtered.length} notes`;
            syncDividerCount();
        }

        function syncDividerCount() {
            const countLabel = document.getElementById('note-count-label');
            if (countLabel) {
                const visibleCount = Array.from(cards).filter(c => c.closest('.masonry-item-wrapper').style.display !== 'none').length;
                const totalCount = cards.length;
                countLabel.textContent = visibleCount === totalCount ? `${totalCount} notes` : `${visibleCount} of ${totalCount} notes`;
            }
        }

        function getFilteredData() {
            return notesJSON.filter(item => {
                const matchesQuery = !currentFilterState.query || 
                                   item.title.toLowerCase().includes(currentFilterState.query) || 
                                   item.description.toLowerCase().includes(currentFilterState.query);
                const matchesRating = (item.rating || 0) >= currentFilterState.minUtility;
                const itemTags = Array.isArray(item.tags) ? item.tags : (item.tags ? item.tags.split(',') : []);
                const matchesTags = currentFilterState.tags.length === 0 || 
                                   currentFilterState.tags.every(t => itemTags.map(it => it.trim()).includes(t));
                return matchesQuery && matchesRating && matchesTags;
            });
        }

        function applyFilterSystem() {
            const filtered = getFilteredData();
            
            // Sort
            filtered.sort((a, b) => {
                let vA, vB;
                if (currentFilterState.sort === 'rating') {
                    vA = a.rating || 0;
                    vB = b.rating || 0;
                } else if (currentFilterState.sort === 'date') {
                    vA = new Date(a.date).getTime();
                    vB = new Date(b.date).getTime();
                } else {
                    vA = a.title.toLowerCase();
                    vB = b.title.toLowerCase();
                }

                if (vA < vB) return currentFilterState.sortOrder === 'desc' ? 1 : -1;
                if (vA > vB) return currentFilterState.sortOrder === 'desc' ? -1 : 1;
                return 0;
            });

            // Show/Hide and Reorder DOM
            const filteredIds = new Set(filtered.map(f => f.id));
            cards.forEach(card => {
                const wrapper = card.closest('.masonry-item-wrapper');
                if (filteredIds.has(card.getAttribute('data-id'))) {
                    wrapper.style.display = 'block';
                    wrapper.style.opacity = '1';
                } else {
                    wrapper.style.display = 'none';
                    wrapper.style.opacity = '0';
                }
            });

            // Reorder in DOM to help masonry
            filtered.forEach(item => {
                const card = document.querySelector(`.catalog-card[data-id="${item.id}"]`);
                masonryGrid.appendChild(card.closest('.masonry-item-wrapper'));
            });

            setTimeout(layoutMasonry, 50);
            syncDividerCount();
            closeFilterModal();
        }

        function clearAllFilters() {
            currentFilterState = { query: '', sort: 'rating', sortOrder: 'desc', tags: [], minUtility: 0 };
            searchInput.value = '';
            document.getElementById('min-rating-label').textContent = '1+ stars';
            filterStarButtons.forEach((b, i) => { if(i===0) b.classList.add('active'); else b.classList.remove('active'); });
            renderFilterTags();
            filterSortButtons.forEach(b => {
                if (b.getAttribute('data-sort') === 'rating') b.classList.add('bg-[#B4BCC0]', 'text-white', 'shadow-lg');
                else b.classList.remove('bg-[#B4BCC0]', 'text-white', 'shadow-lg');
            });
            applyFilterSystem();
        }

        function layoutMasonry() {
            if (!masonryGrid) return;
            const items = Array.from(masonryGrid.querySelectorAll('.masonry-item-wrapper')).filter(i => i.style.display !== 'none');
            const containerWidth = masonryGrid.offsetWidth;
            let cols = 1;
            if (window.innerWidth >= 1024) cols = 3;
            else if (window.innerWidth >= 768) cols = 2;
            const gap = 20;
            const colWidth = (containerWidth - (gap * (cols - 1))) / cols;
            const colHeights = new Array(cols).fill(0);
            items.forEach(item => {
                const minH = Math.min(...colHeights);
                const colIdx = colHeights.indexOf(minH);
                const x = colIdx * (colWidth + gap);
                const y = minH;
                item.style.width = colWidth + 'px';
                item.style.transform = `translate3d(${x}px, ${y}px, 0)`;
                colHeights[colIdx] += item.offsetHeight + gap;
            });
            masonryGrid.style.height = Math.max(...colHeights) + 'px';
        }
        window.addEventListener('load', layoutMasonry);
        window.addEventListener('resize', layoutMasonry);
        document.addEventListener('click', e => {
            const card = e.target.closest('.catalog-card');
            if (card) {
                const id = card.getAttribute('data-id');
                const contentEl = document.getElementById(`note-content-${id}`);
                const bodyHtml = contentEl ? contentEl.innerHTML : '';
                const data = JSON.parse(document.getElementById('notes-data').textContent);
                if (window.openNoteModal) window.openNoteModal(id, data, bodyHtml);
            }
        });
    </script>
</body>
</html>
