---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';
import ConceptModal from '../../components/ConceptModal.astro';

const frameworks = await getCollection('frameworks');
const allConcepts = await getCollection('concepts');

frameworks.sort((a, b) => {
  const ratingA = a.data.rating || 0;
  const ratingB = b.data.rating || 0;
  if (ratingB !== ratingA) return ratingB - ratingA;
  return new Date(b.data.date_added).getTime() - new Date(a.data.date_added).getTime();
});

const renderedFrameworks = await Promise.all(
  frameworks.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

const renderedConcepts = await Promise.all(
  allConcepts.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

const ACCENT_COLOR = '#8B2626'; // Seal
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlas Field Notes — Frameworks</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600;700&family=Reenie+Beanie&display=swap" rel="stylesheet">
    <style define:vars={{ accent: ACCENT_COLOR }}>
        body {
            background-color: #FDFCF9;
            background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
            color: #2A2724;
        }
        .glass-nav { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
        .hand-underline-sm { position: relative; display: inline-block; }
        
        .framework-card {
            background: white;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            border: 1px solid rgba(42, 39, 35, 0.1);
            box-shadow: 0 2px 12px rgba(42, 39, 35, 0.06);
        }
        .framework-card:hover {
            background: #F5F2EB;
            border-color: #D5CCB6;
            transform: translateY(-4px);
            box-shadow: 0 12px 24px -10px rgba(42, 39, 36, 0.1);
        }
        .framework-card:hover .card-title { color: var(--accent); }
        .card-icon {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            color: #A39985;
            transition: color 0.2s ease;
        }
        .framework-card:hover .card-icon { color: var(--accent); }
        
        .star-rating { display: flex; gap: 4px; color: var(--accent); }
        
        .masonry-grid {
            position: relative;
            width: 100%;
            transition: height 0.4s ease;
        }
        .masonry-item-wrapper {
            position: absolute;
            transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.4s ease, width 0.4s ease;
        }
        
        /* Modal Styles */
        #modal-overlay { 
            background: rgba(42, 39, 35, 0.38); 
            backdrop-filter: blur(8px); 
            -webkit-backdrop-filter: blur(8px); 
            transition: opacity 0.35s ease; 
        }
        .modal-card { 
            background-color: #FDFCF9; 
            background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
        }
        
        @keyframes textReveal { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .modal-title-text { opacity: 0; animation: textReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards; }
        .modal-reveal { opacity: 0; animation: textReveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.28s forwards; }
        
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.12); border-radius: 10px; border: 2px solid transparent; background-clip: content-box; }
        ::-webkit-scrollbar-thumb:hover { background-color: rgba(42, 39, 36, 0.25); }

        @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }
        .swoosh-path { stroke-dasharray: 100; stroke-dashoffset: 100; }
        .animate-draw-line { animation: drawSwoosh 0.8s ease-out 0.4s forwards; }

        /* Star Filter Fixes */
        .star-filter { transition: all 0.25s ease; cursor: pointer; display: flex; align-items: center; justify-content: center; }
        .star-filter.active { color: #8B2626 !important; opacity: 1 !important; }
        .star-filter.active svg { color: #8B2626 !important; }
        .star-filter.active svg path { fill: #8B2626 !important; fill-opacity: 0.2 !important; stroke: #8B2626 !important; stroke-width: 1.5 !important; }
        .star-filter:not(.active) { color: #A39985 !important; opacity: 0.5 !important; }
        .star-filter:not(.active) svg { color: #A39985 !important; }
        .star-filter:not(.active) svg path { fill: #A39985 !important; fill-opacity: 0.1 !important; stroke: #A39985 !important; stroke-width: 1.5 !important; }
        .star-filter:hover { transform: scale(1.1); }

        .ink-stain {
            background-color: #FDFCF9;
            background-image: 
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                radial-gradient(circle at 10% 90%, rgba(42,39,36,0.03) 0%, rgba(253,252,249,0) 60%);
            background-position: 0px 0px, 40px 60px, 0 0;
            background-repeat: repeat, repeat, no-repeat;
        }
        .modal-scrollbar::-webkit-scrollbar { width: 6px; }
        .modal-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .modal-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.1); border-radius: 10px; }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <header class="sticky top-0 z-50 w-full h-[80px] bg-[#F5F2EB]/95 glass-nav flex items-center justify-between px-10 shadow-sm" style="border-bottom: 0.5px solid rgba(42, 39, 35, 0.12);">
        <div class="flex items-center gap-10">
            <a href="/astro-project-v2/" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Main Page</a>
            <div class="h-8 w-px bg-[#E8E2D2]"></div>
            <nav class="flex items-center gap-8 translate-y-[2px]">
                <a href="/astro-project-v2/concepts" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Concepts</a>
                <a href="/astro-project-v2/definitions" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Definitions</a>
                <a href="/astro-project-v2/frameworks" class="group flex items-center gap-2 transition-all duration-300 hover:-translate-y-[1px]">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#8B2626] shadow-[0_0_8px_rgba(139,38,38,0.4)]"></span>
                    <span class="font-serif text-xl text-[#2A2724]">Frameworks</span>
                </a>
            </nav>
        </div>
        <div class="font-hand text-[1.75rem] leading-none text-seal tracking-tight translate-y-1">hyperlynxt | teo</div>
    </header>

    <!-- Modal (Nuclear Fix: Moved to top and simplified) -->
    <div id="framework-modal-overlay" class="fixed inset-0 z-[70] flex items-center justify-center p-6 md:p-10" style="display:none; opacity:0; pointer-events: none; background-color: rgba(42, 39, 36, 0.4); backdrop-filter: blur(8px);">
        <div id="framework-modal-card" class="modal-card relative w-full max-w-[650px] rounded-[28px] overflow-hidden flex flex-col border border-[#2A2724]/8 bg-[#FDFCF9] shadow-2xl" style="max-height:90vh;">
            <button id="framework-close-modal-btn" class="absolute top-4 right-4 z-20 w-7 h-7 rounded-full border border-[#2A2724]/10 bg-white/60 text-[#2A2724]/35 hover:text-[#2A2724]/70 hover:border-[#2A2724]/25 flex items-center justify-center transition-all font-sans text-xs">✕</button>
            <div class="flex-1 overflow-y-auto px-10 md:px-14 pt-14 pb-12">
                <div class="flex justify-center mb-6">
                    <div id="framework-modal-stars" class="star-rating"></div>
                </div>
                <div class="modal-title-text mb-2 text-center relative px-12">
                    <p id="framework-modal-type" class="font-sans text-xs font-bold uppercase tracking-[0.2em] text-[#8B2626] opacity-60 mb-2"></p>
                    <h2 class="font-serif text-[3.5rem] md:text-[4rem] font-medium leading-none text-[#2A2724] relative inline-block">
                        <span id="framework-modal-title" class="italic"></span>
                        <svg id="framework-modal-title-underline" class="absolute h-[12px] text-[#8B2626] opacity-70 overflow-visible pointer-events-none" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display: none;">
                            <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path"></path>
                        </svg>
                    </h2>
                </div>
                <div class="w-full h-px bg-[#8B2626]/20 my-8"></div>
                <div class="modal-reveal">
                    <p id="framework-modal-description" class="font-serif text-[1.2rem] md:text-[1.4rem] leading-relaxed text-[#2A2724] mb-8"></p>
                    <div id="framework-modal-content" class="prose prose-stone prose-lg max-w-none font-serif text-[#2A2724]/80 mb-12"></div>
                    
                    <!-- Related Concepts Section -->
                    <div id="framework-related-section" style="display:none;">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="h-px flex-1 bg-[#D5CCB6]/30"></div>
                            <span class="font-sans text-[10px] font-bold uppercase tracking-[0.2em] text-[#B08D57]">Related Concepts</span>
                            <div class="h-px flex-1 bg-[#D5CCB6]/30"></div>
                        </div>
                        <div id="framework-related-items" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <!-- Items populated via JS -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <main class="flex-1 pb-32">
        <section class="w-full bg-gradient-to-b from-[#F5F2EB] to-transparent pt-20 pb-16 px-6">
            <div class="max-w-4xl mx-auto text-center">
                <span class="font-hand text-2xl text-[#8C8070] mb-2 block">scaffolding for thought</span>
                <h2 class="font-serif text-5xl md:text-7xl leading-tight text-[#2A2724] mb-8">
                    Mental <span class="italic hand-underline-sm inline-block">
                        Frameworks
                        <svg class="absolute w-[110%] h-[12px] -bottom-1 -left-[5%] text-[#8B2626] opacity-70 overflow-visible" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                            <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path animate-draw-line"></path>
                        </svg>
                    </span>
                </h2>
                <p class="font-serif italic text-lg md:text-xl text-[#8C8070] max-w-2xl mx-auto leading-relaxed">
                    Higher-order structures, heuristics, and lenses for organizing perception and action.
                </p>
            </div>
        </section>

        <div class="max-w-[1400px] mx-auto px-6 md:px-10 mb-6 flex items-center justify-between pb-3" style="border-bottom: 1px solid rgba(42,39,35,0.08);">
            <span class="font-sans text-[10px] font-bold uppercase tracking-[0.14em] text-[#2A2724]/40">Structural Scaffolding</span>
            <span id="count-label" class="font-serif italic text-[#2A2724]/35 text-sm">{frameworks.length} entries</span>
        </div>

        <div class="max-w-7xl mx-auto px-6">
            <div class="masonry-grid" id="frameworks-grid">
                {renderedFrameworks.map(({ entry }) => (
                    <div class="masonry-item-wrapper">
                        <article
                            class="framework-card rounded-3xl p-8 flex flex-col gap-6"
                            data-title={entry.data.title}
                            data-id={entry.id}
                            data-description={entry.data.description}
                            data-type={entry.data.type}
                            data-rating={entry.data.rating}
                            data-tags={entry.data.tags.join(',')}
                        >
                            <svg class="card-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 3v18"></path>
                                <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                                <path d="M3 9h18"></path>
                                <path d="M3 15h18"></path>
                            </svg>
                            <div class="flex flex-col gap-2">
                                <p class="font-sans text-[10px] font-bold uppercase tracking-widest text-[#8B2626] opacity-60">{entry.data.type}</p>
                                <h3 class="card-title font-serif text-3xl font-medium text-[#2A2724] transition-colors leading-tight">{entry.data.title}</h3>
                                <p class="font-serif text-[#8C8070] text-[16px] leading-relaxed mt-2">{entry.data.description}</p>
                            </div>
                            <div class="pt-5 border-t border-[#F5F2EB]/80 mt-auto flex items-center justify-between">
                                <div class="star-rating">
                                    {Array.from({ length: entry.data.rating || 0 }).map((_, i) => (
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" style={`transform: rotate(${(i % 2 === 0 ? 10 : -10)}deg)`}>
                                            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.3"></path>
                                        </svg>
                                    ))}
                                </div>
                                <div class="flex gap-1.5 flex-wrap justify-end">
                                    {entry.data.tags.slice(0, 2).map(tag => (
                                        <span class="bg-[#F5F2EB] text-[#8C8070] font-sans text-[9px] font-bold uppercase tracking-widest px-2 py-1 rounded-md">{tag}</span>
                                    ))}
                                </div>
                            </div>
                        </article>
                    </div>
                ))}
            </div>
        </div>
    </main>

    <ConceptModal />

    <!-- Filter Modal -->
    <div id="filter-modal" style="display:none;" class="fixed inset-0 z-[80] items-center justify-center p-6 bg-[#F5F2EB]/40 backdrop-blur-md">
        <div class="relative z-20 w-full max-w-[630px] bg-white rounded-[28px] shadow-2xl border border-white/60 overflow-hidden flex flex-col max-h-[85vh] ink-stain">
            <div class="px-7 pt-9 pb-6 border-b border-[#D5CCB6]/15 flex flex-col items-center justify-center bg-white/50 backdrop-blur-md z-10 flex-shrink-0 relative">
                <div class="text-center w-full">
                    <h2 class="text-3xl md:text-4xl font-serif font-medium text-[#2A2724] relative inline-block">
                        Filter & Sort
                        <svg class="absolute w-[110%] h-[15px] -bottom-2 -left-[5%] text-[#8B2626] opacity-80 overflow-visible" viewBox="0 0 100 10" fill="none" preserveAspectRatio="none">
                            <path d="M0 7 Q12.5 10 25 6 T50 7 T75 6 T100 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="swoosh-path animate-draw-line"/>
                        </svg>
                    </h2>
                </div>
                <button id="close-filter-btn" class="absolute top-7 right-7 w-8 h-8 rounded-full bg-[#FDFCF9] border border-[#D5CCB6]/20 flex items-center justify-center text-[#2A2724]/50 hover:text-[#2A2724] hover:bg-[#F5F2EB] transition-all group">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <div class="px-7 py-6 overflow-y-auto modal-scrollbar relative z-0 flex-grow space-y-8 h-[500px]">
                <!-- Sort -->
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#8B2626]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Sort Order</h3>
                        </div>
                        <button id="sort-direction-toggle" class="flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-[#FDFCF9] border border-[#D5CCB6]/20 text-[10px] font-bold uppercase tracking-wider text-[#2A2724]/60 hover:text-[#8B2626] transition-all group">
                            <span id="sort-direction-label">Descending</span>
                            <svg id="sort-direction-icon" xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M7 15l5 5 5-5M7 9l5-5 5 5"/></svg>
                        </button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button data-sort="rating" class="sort-btn px-4 py-2 bg-[#8B2626] text-white font-sans text-sm font-medium rounded-full shadow-lg border border-[#8B2626] transition-all">Rating</button>
                        <button data-sort="alphabetical" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:text-[#2A2724] transition-all shadow-sm">Alphabetical</button>
                        <button data-sort="date" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:text-[#2A2724] transition-all shadow-sm">Date Added</button>
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#2A2724]/15 to-transparent"></div>

                <!-- Stars -->
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#8B2626]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2"></polygon></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Minimum Complexity</h3>
                        </div>
                        <span id="min-rating-label" class="font-hand text-lg text-[#8B2626]">1+ stars</span>
                    </div>
                    <div class="flex gap-3 p-3.5 bg-white border border-[#D5CCB6]/20 rounded-2xl w-fit shadow-inner" id="filter-utility-stars">
                        <button data-rating="1" class="star-filter active active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"></path>
                            </svg>
                        </button>
                        <button data-rating="2" class="star-filter active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(15deg)">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"></path>
                            </svg>
                        </button>
                        <button data-rating="3" class="star-filter active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(-10deg)">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"></path>
                            </svg>
                        </button>
                        <button data-rating="4" class="star-filter active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(5deg)">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"></path>
                            </svg>
                        </button>
                        <button data-rating="5" class="star-filter active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(-15deg)">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"></path>
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#2A2724]/15 to-transparent"></div>

                <!-- Framework Types -->
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#8B2626]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                        <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Framework Types</h3>
                    </div>
                    <div id="filter-types-container" class="flex flex-wrap gap-2"></div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#2A2724]/15 to-transparent"></div>

                <!-- Tags -->
                <div class="pb-4">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#8B2626]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Filter by Tags</h3>
                        </div>
                        <button id="toggle-all-tags" class="font-sans text-[10px] font-bold uppercase tracking-wider text-[#8B2626]/60 hover:text-[#8B2626] transition-colors">Select All</button>
                    </div>
                    <div id="filter-tags-container" class="flex flex-wrap gap-2"></div>
                </div>
            </div>

            <div class="p-6 border-t border-[#D5CCB6]/15 bg-[#FDFCF9] relative z-10 flex items-center justify-between flex-shrink-0">
                <button id="clear-filter-btn" class="font-hand text-[1.4rem] font-medium text-[#8B2626] hover:bg-[#8B2626]/10 px-4 py-1.5 rounded-lg transition-all underline underline-offset-4">Clear Filters</button>
                <button id="apply-filter-btn" class="bg-seal hover:bg-[#6D1E1E] text-white px-6 py-3 rounded-xl font-sans text-sm font-medium transition-all shadow-md hover:-translate-y-0.5 flex items-center gap-2">
                    <span>Apply Filters</span>
                    <span id="filter-result-count" class="font-hand text-lg text-white/80 pt-0.5">-- frameworks</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Bottom Bar -->
    <div class="fixed bottom-10 left-0 right-0 flex justify-center pointer-events-none z-50">
        <div class="bg-white/80 backdrop-blur-xl border border-[#E8E2D2] rounded-[24px] shadow-[0_20px_50px_rgba(42,39,36,0.15)] p-2.5 flex items-center pointer-events-auto">
            <div class="flex items-center gap-3 pl-4 pr-3 py-2 group cursor-text" onclick="document.getElementById('framework-search').focus()">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#A39985] group-hover:text-seal transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <input type="text" id="framework-search" placeholder="Search frameworks" class="bg-transparent border-none outline-none font-sans text-xs font-bold text-[#2A2724] placeholder:text-[#A39985] w-32 transition-all focus:w-48">
            </div>
            <div class="w-px h-6 bg-[#E8E2D2] mx-1"></div>
            <button id="filter-btn" class="bg-seal hover:bg-seal/90 text-white rounded-xl px-5 py-2.5 text-[11px] uppercase tracking-widest font-sans font-bold transition-colors shadow-sm">Filter & Sort</button>
        </div>
    </div>


    <!-- Data for JS -->
    <script id="frameworks-data" type="application/json" is:inline set:html={JSON.stringify(frameworks.map(f => ({ id: f.id, ...f.data })))} />
    <div style="display:none;" aria-hidden="true">
        {renderedFrameworks.map(({ entry, Content }) => (
            <div id={`framework-content-${entry.id}`}><Content /></div>
        ))}
    </div>

    <!-- Concepts Data for Modal -->
    <script id="concepts-data" type="application/json" is:inline set:html={JSON.stringify(allConcepts.map(c => ({ id: c.id, ...c.data })))} />
    <div style="display:none;" aria-hidden="true">
        {renderedConcepts.map(({ entry, Content }) => (
            <div id={`concept-content-${entry.id}`}><Content /></div>
        ))}
    </div>

    <ConceptModal />

    <script is:inline>
        function initFrameworks() {
            console.log('initFrameworks running');
            const cards = document.querySelectorAll('.framework-card');
            const grid = document.getElementById('frameworks-grid');
            const overlay = document.getElementById('framework-modal-overlay');
            const closeBtn = document.getElementById('framework-close-modal-btn');
            
            const dataEl = document.getElementById('frameworks-data');
            const conceptsDataEl = document.getElementById('concepts-data');
            if (!dataEl || !conceptsDataEl) return;
            
            const frameworksData = JSON.parse(dataEl.textContent);
            const conceptsData = JSON.parse(conceptsDataEl.textContent);

            // Filter Elements
            const searchInput = document.getElementById('framework-search');
            const filterModal = document.getElementById('filter-modal');
            const countLabel = document.getElementById('count-label');
            const filterResultCount = document.getElementById('filter-result-count');
            const sortDirectionLabel = document.getElementById('sort-direction-label');
            const sortDirectionIcon = document.getElementById('sort-direction-icon');
            const filterTypesContainer = document.getElementById('filter-types-container');
            const filterTagsContainer = document.getElementById('filter-tags-container');

            let currentFilterState = {
                query: '',
                sort: 'rating',
                sortOrder: 'desc',
                types: ['All'],
                tags: [],
                minComplexity: 0
            };

            // ─────────────── MASONRY ───────────────
            function layoutMasonry() {
                if (!grid) return;
                const items = Array.from(document.querySelectorAll('.masonry-item-wrapper')).filter(item => item.style.display !== 'none');
                if (items.length === 0) {
                    grid.style.height = '200px';
                    return;
                }
                
                const containerWidth = grid.offsetWidth;
                let cols = 1;
                if (window.innerWidth >= 1024) cols = 3;
                else if (window.innerWidth >= 768) cols = 2;
                
                const gap = 24;
                const colWidth = (containerWidth - (gap * (cols - 1))) / cols;
                const heights = new Array(cols).fill(0);
                
                items.forEach(item => {
                    const minH = Math.min(...heights);
                    const colIdx = heights.indexOf(minH);
                    item.style.width = `${colWidth}px`;
                    item.style.transform = `translate3d(${colIdx * (colWidth + gap)}px, ${minH}px, 0)`;
                    item.style.opacity = '1';
                    heights[colIdx] += item.offsetHeight + gap;
                });
                grid.style.height = `${Math.max(...heights)}px`;
            }

            window.addEventListener('load', layoutMasonry);
            window.addEventListener('resize', layoutMasonry);
            setTimeout(layoutMasonry, 100);

            // ─────────────── FILTERING ───────────────
            const availableTypes = new Set();
            const availableTags = new Set();
            frameworksData.forEach(f => {
                if (f.type) availableTypes.add(f.type);
                if (f.tags) f.tags.forEach(t => availableTags.add(t));
            });
            const sortedTypes = Array.from(availableTypes).sort();
            const sortedTags = Array.from(availableTags).sort();

            function renderFilterTypes() {
                const allActive = currentFilterState.types.includes('All');
                let html = `<button data-type="All" class="type-filter-btn px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest transition-all ${allActive ? 'bg-[#2A2724] text-white shadow-md' : 'bg-[#F5F2EB] text-[#2A2724]/60 border border-[#D5CCB6]/20 hover:bg-[#E8E2D2]'}">All Types</button>`;
                html += sortedTypes.map(type => {
                    const isActive = currentFilterState.types.includes(type);
                    return `<button data-type="${type}" class="type-filter-btn px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest transition-all ${isActive ? 'bg-[#8B2626] text-white shadow-md' : 'bg-[#FDFCF9] text-[#2A2724]/60 border border-[#D5CCB6]/20 hover:bg-[#F5F2EB]'}">${type}</button>`;
                }).join('');
                filterTypesContainer.innerHTML = html;
                filterTypesContainer.querySelectorAll('.type-filter-btn').forEach(btn => {
                    btn.onclick = () => {
                        const type = btn.dataset.type;
                        if (type === 'All') {
                            currentFilterState.types = ['All'];
                        } else {
                            currentFilterState.types = currentFilterState.types.filter(t => t !== 'All');
                            if (currentFilterState.types.includes(type)) {
                                currentFilterState.types = currentFilterState.types.filter(t => t !== type);
                                if (currentFilterState.types.length === 0) currentFilterState.types = ['All'];
                            } else {
                                currentFilterState.types.push(type);
                            }
                        }
                        renderFilterTypes();
                        updateFilterPreview();
                    };
                });
            }

            function renderFilterTags() {
                filterTagsContainer.innerHTML = sortedTags.map(tag => {
                    const isActive = currentFilterState.tags.includes(tag);
                    return `<button data-tag="${tag}" class="tag-filter-btn px-3 py-1 rounded-full text-[10px] font-semibold uppercase tracking-widest transition-all ${isActive ? 'bg-[#8B2626] text-white shadow-md' : 'bg-[#8B2626]/10 text-[#8B2626] border border-[#8B2626]/20 hover:bg-[#8B2626]/20'}">${tag}</button>`;
                }).join('');
                filterTagsContainer.querySelectorAll('.tag-filter-btn').forEach(btn => {
                    btn.onclick = () => {
                        const tag = btn.dataset.tag;
                        if (currentFilterState.tags.includes(tag)) {
                            currentFilterState.tags = currentFilterState.tags.filter(t => t !== tag);
                        } else {
                            currentFilterState.tags.push(tag);
                        }
                        renderFilterTags();
                        updateFilterPreview();
                    };
                });
            }

            function updateFilterPreview() {
                const results = getFilteredData();
                filterResultCount.textContent = `${results.length} frameworks`;
            }

            function getFilteredData() {
                return frameworksData.filter(f => {
                    const matchesQuery = !currentFilterState.query || 
                        f.title.toLowerCase().includes(currentFilterState.query.toLowerCase()) || 
                        f.description.toLowerCase().includes(currentFilterState.query.toLowerCase());
                    const matchesType = currentFilterState.types.includes('All') || currentFilterState.types.includes(f.type);
                    const matchesTags = currentFilterState.tags.length === 0 || currentFilterState.tags.some(t => f.tags.includes(t));
                    const matchesRating = f.rating >= currentFilterState.minComplexity;
                    return matchesQuery && matchesType && matchesTags && matchesRating;
                }).sort((a, b) => {
                    let comparison = 0;
                    if (currentFilterState.sort === 'rating') comparison = (a.rating || 0) - (b.rating || 0);
                    else if (currentFilterState.sort === 'alphabetical') comparison = a.title.localeCompare(b.title);
                    else if (currentFilterState.sort === 'date') comparison = new Date(a.date_added || 0) - new Date(b.date_added || 0);
                    return currentFilterState.sortOrder === 'desc' ? -comparison : comparison;
                });
            }

            function applyFilterSystem() {
                const results = getFilteredData();
                const resultIds = new Set(results.map(r => r.id));
                
                // Sort the actual DOM elements
                const wrappers = Array.from(document.querySelectorAll('.masonry-item-wrapper'));
                wrappers.forEach(wrapper => {
                    const card = wrapper.querySelector('.framework-card');
                    const id = card.dataset.id;
                    if (resultIds.has(id)) {
                        wrapper.style.display = 'block';
                        wrapper.dataset.sortValue = results.findIndex(r => r.id === id);
                    } else {
                        wrapper.style.display = 'none';
                    }
                });

                // Move items in DOM based on sort order for masonry to pick them up in order
                const sortedWrappers = wrappers
                    .filter(w => w.style.display !== 'none')
                    .sort((a, b) => parseInt(a.dataset.sortValue) - parseInt(b.dataset.sortValue));
                
                sortedWrappers.forEach(w => grid.appendChild(w));

                countLabel.textContent = `${results.length} entries`;
                layoutMasonry();
                if (filterModal.style.display !== 'none') closeFilterModal();
            }

            // Listeners
            if (searchInput) {
                searchInput.oninput = (e) => {
                    currentFilterState.query = e.target.value;
                    applyFilterSystem();
                };
            }

            document.getElementById('filter-btn').onclick = openFilterModal;
            document.getElementById('close-filter-btn').onclick = closeFilterModal;
            document.getElementById('apply-filter-btn').onclick = applyFilterSystem;
            document.getElementById('clear-filter-btn').onclick = clearAllFilters;
            
            document.getElementById('sort-direction-toggle').onclick = () => {
                currentFilterState.sortOrder = currentFilterState.sortOrder === 'desc' ? 'asc' : 'desc';
                sortDirectionLabel.textContent = currentFilterState.sortOrder === 'desc' ? 'Descending' : 'Ascending';
                sortDirectionIcon.style.transform = currentFilterState.sortOrder === 'desc' ? 'rotate(0deg)' : 'rotate(180deg)';
                updateFilterPreview();
            };

            document.querySelectorAll('.sort-btn').forEach(btn => {
                btn.onclick = () => {
                    currentFilterState.sort = btn.dataset.sort;
                    document.querySelectorAll('.sort-btn').forEach(b => {
                        if (b === btn) {
                            b.classList.add('bg-[#8B2626]', 'text-white', 'shadow-lg');
                            b.classList.remove('bg-white', 'text-[#2A2724]/70');
                        } else {
                            b.classList.remove('bg-[#8B2626]', 'text-white', 'shadow-lg');
                            b.classList.add('bg-white', 'text-[#2A2724]/70');
                        }
                    });
                    updateFilterPreview();
                };
            });

            document.querySelectorAll('.star-filter').forEach(btn => {
                btn.onclick = () => {
                    const rating = parseInt(btn.dataset.rating);
                    currentFilterState.minComplexity = rating;
                    document.getElementById('min-rating-label').textContent = `${rating}+ stars`;
                    document.querySelectorAll('.star-filter').forEach(b => {
                        if (parseInt(b.dataset.rating) <= rating) b.classList.add('active');
                        else b.classList.remove('active');
                    });
                    updateFilterPreview();
                };
            });

            document.getElementById('toggle-all-tags').onclick = (e) => {
                if (currentFilterState.tags.length === sortedTags.length) {
                    currentFilterState.tags = [];
                    e.target.textContent = 'Select All';
                } else {
                    currentFilterState.tags = [...sortedTags];
                    e.target.textContent = 'Clear All';
                }
                renderFilterTags();
                updateFilterPreview();
            };

            function openFilterModal() {
                filterModal.style.display = 'flex';
                document.body.style.overflow = 'hidden';
                renderFilterTypes();
                renderFilterTags();
                updateFilterPreview();
            }

            function closeFilterModal() {
                filterModal.style.display = 'none';
                document.body.style.overflow = '';
            }

            function clearAllFilters() {
                currentFilterState = {
                    query: searchInput.value = '',
                    sort: 'rating',
                    sortOrder: 'desc',
                    types: ['All'],
                    tags: [],
                    minComplexity: 0
                };
                
                // Reset Sort UI
                document.querySelectorAll('.sort-btn').forEach(b => {
                    if (b.dataset.sort === 'rating') {
                        b.classList.add('bg-[#8B2626]', 'text-white', 'shadow-lg');
                        b.classList.remove('bg-white', 'text-[#2A2724]/70');
                    } else {
                        b.classList.remove('bg-[#8B2626]', 'text-white', 'shadow-lg');
                        b.classList.add('bg-white', 'text-[#2A2724]/70');
                    }
                });
                sortDirectionLabel.textContent = 'Descending';
                sortDirectionIcon.style.transform = 'rotate(0deg)';
                
                // Reset Stars UI
                document.getElementById('min-rating-label').textContent = '1+ stars';
                document.querySelectorAll('.star-filter').forEach(b => {
                    if (parseInt(b.dataset.rating) === 1) b.classList.add('active');
                    else b.classList.remove('active');
                });

                renderFilterTypes();
                renderFilterTags();
                applyFilterSystem();
            }

            // ─────────────── CARD CLICKS ───────────────
            console.log(`Setting up listeners for ${cards.length} cards`);
            cards.forEach(card => {
                card.addEventListener('click', () => {
                    console.log('Card clicked:', card.dataset.id);
                    const id = card.dataset.id;
                    const data = frameworksData.find(f => f.id === id);
                    if (!data) return;

                    const contentEl = document.getElementById(`framework-content-${id}`);
                    if (!contentEl) return;
                    
                    document.getElementById('framework-modal-title').textContent = data.title;
                    document.getElementById('framework-modal-type').textContent = data.type;
                    document.getElementById('framework-modal-description').textContent = data.description;
                    document.getElementById('framework-modal-content').innerHTML = contentEl.innerHTML;
                    
                    // Stars
                    const starHtml = Array.from({ length: data.rating }).map((_, i) => 
                        `<svg width="20" height="20" viewBox="0 0 24 24" fill="#8B2626" fill-opacity="0.3" stroke="#8B2626" stroke-width="2" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>`
                    ).join('');
                    document.getElementById('framework-modal-stars').innerHTML = starHtml;

                    // Related Concepts
                    const relatedSec = document.getElementById('framework-related-section');
                    const relatedItemsContainer = document.getElementById('framework-related-items');
                    if (data.related_concepts && data.related_concepts.length > 0) {
                        relatedItemsContainer.innerHTML = data.related_concepts.map(name => `
                            <div class="related-concept-item group p-1 bg-[#FDFCF9]/50 border border-[#D5CCB6]/40 rounded-xl flex items-center justify-between cursor-pointer hover:bg-[#FDFCF9] hover:border-[#B08D57]/40 hover:shadow-sm transition-all" data-name="${name.trim()}">
                                <p class="font-serif text-[17px] text-[#2A2724] group-hover:text-[#B08D57] font-medium transition-colors ml-2.5">${name.trim()}</p>
                                <svg class="text-[#D5CCB6]/50 group-hover:text-[#B08D57]/60 transition-colors mr-2.5" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round tracking-tighter"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                            </div>
                        `).join('');
                        relatedSec.style.display = 'block';
                    } else {
                        relatedSec.style.display = 'none';
                    }

                    overlay.style.display = 'flex';
                    overlay.style.pointerEvents = 'all';
                    requestAnimationFrame(() => { 
                        overlay.style.opacity = '1'; 
                    });
                    document.body.style.overflow = 'hidden';

                    // Underline Animation
                    const titleEl = document.getElementById('framework-modal-title');
                    const underline = document.getElementById('framework-modal-title-underline');
                    if (titleEl && underline) {
                        requestAnimationFrame(() => {
                            const rects = titleEl.getClientRects();
                            const containerRect = titleEl.parentElement.getBoundingClientRect();
                            if (rects.length > 0) {
                                const firstRect = rects[0];
                                underline.style.width = (firstRect.width * 1.05) + 'px';
                                underline.style.top = (firstRect.bottom - containerRect.top - (firstRect.height * 0.12)) + 'px';
                                underline.style.left = (firstRect.left - containerRect.left - (firstRect.width * 0.025)) + 'px';
                                underline.style.display = 'block';
                                const path = underline.querySelector('path');
                                if (path) {
                                    path.style.animation = 'none'; void path.offsetWidth;
                                    path.style.animation = 'drawSwoosh 0.8s ease-out 0.4s forwards';
                                }
                            }
                        });
                    }
                });
            });

            // Handle Related Concepts Click
            const relatedItems = document.getElementById('framework-related-items');
            if (relatedItems) {
                relatedItems.addEventListener('click', (e) => {
                    const item = e.target.closest('.related-concept-item');
                    if (!item) return;
                    const name = item.dataset.name;
                    const concept = conceptsData.find(c => c.title.toLowerCase() === name.toLowerCase());
                    if (concept) {
                        const content = document.getElementById(`concept-content-${concept.id}`).innerHTML;
                        if (window.openConceptModal) {
                            window.openConceptModal(concept.id, conceptsData, content);
                        }
                    }
                });
            }

            const closeModal = () => {
                overlay.style.opacity = '0';
                overlay.style.pointerEvents = 'none';
                setTimeout(() => { 
                    overlay.style.display = 'none'; 
                    document.body.style.overflow = ''; 
                }, 300);
            };
            if (closeBtn) closeBtn.onclick = closeModal;
            if (overlay) overlay.onclick = (e) => { if(e.target === overlay) closeModal(); };
            window.addEventListener('keydown', (e) => { if(e.key === 'Escape') closeModal(); });
        }

        // Initialize on DOMContentLoaded or immediately if already loaded
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initFrameworks);
        } else {
            initFrameworks();
        }
    </script>
</body>
</html>
