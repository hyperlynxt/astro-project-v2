---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const notes = await getCollection('notes');
notes.sort((a, b) => {
  const ratingA = a.data.rating || 0;
  const ratingB = b.data.rating || 0;
  if (ratingB !== ratingA) return ratingB - ratingA;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlas Field Notes — Notes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@400;500;600;700&family=Reenie+Beanie&display=swap" rel="stylesheet">
    <style is:global>
        /* ── Base ── */
        body {
            background-color: #FDFCF9;
            background-image:
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png");
            background-position: 0px 0px, 40px 60px, 80px 20px;
            background-repeat: repeat;
            color: #2A2724;
        }
        /* ── Theme accent — pastel purple ── */
        :root {
            --accent:       #9B7CC8;   /* main purple */
            --accent-light: #C4A8E8;   /* hover / star */
            --accent-pale:  #EDE6F8;   /* soft background chips */
            --accent-dark:  #7A5BA8;   /* deeper hover */
        }

        /* ── Nav ── */
        .glass-nav { backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); }

        /* ── Grid ── */
        .notes-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.75rem;
            align-items: start;
        }
        @media (min-width: 768px)  { .notes-grid { grid-template-columns: repeat(2,1fr); } }
        @media (min-width: 1280px) { .notes-grid { grid-template-columns: repeat(3,1fr); } }

        /* ── Card ── */
        .note-card {
            cursor: pointer;
            background-color: #fff;
            border-radius: 24px;
            padding: 2.2rem 2.2rem 1.8rem;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(42,39,35,0.10);
            box-shadow: 0 2px 12px rgba(42,39,35,0.06);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            min-height: 260px;
        }
        .note-card:hover {
            background: #F8F4FD;
            border-color: #C4A8E8;
            transform: translateY(-4px);
            box-shadow: 0 14px 28px -10px rgba(155,124,200,0.18);
        }
        .note-card:hover .card-title     { color: var(--accent); }
        .note-card:hover .card-draft-icon { color: var(--accent); }

        .card-expand {
            position: absolute; top: 1.1rem; right: 1.1rem;
            opacity: 0; transform: scale(0.85);
            transition: opacity 0.25s ease, transform 0.25s ease;
            color: rgba(42,39,35,0.28); font-size: 0.75rem; line-height: 1;
        }
        .note-card:hover .card-expand { opacity: 1; transform: scale(1); }

        /* Draft icon (pocket-knife) */
        .card-draft-icon {
            color: #2A2724;
            margin-bottom: 1rem;
            flex-shrink: 0;
            transition: color 0.3s ease;
        }

        .card-title {
            font-family: 'EB Garamond', serif;
            font-size: 1.45rem;
            font-weight: 500;
            line-height: 1.3;
            color: #2A2724;
            margin-bottom: 0.65rem;
            transition: color 0.3s ease;
        }
        .card-body {
            font-family: 'EB Garamond', serif;
            font-size: 1.01rem;
            line-height: 1.65;
            color: rgba(42,39,35,0.50);
            flex-grow: 1;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            line-clamp: 3;
            -webkit-box-orient: vertical;
        }

        /* ── Card footer ── */
        .card-footer {
            margin-top: 1.4rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(42,39,35,0.06);
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 0.75rem;
            flex-wrap: wrap;
        }
        .card-tag {
            background: var(--accent-pale);
            color: var(--accent);
            font-family: 'Inter', sans-serif;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 4px 10px;
            border-radius: 6px;
        }
        .card-tag-neutral {
            background: rgba(42,39,35,0.05);
            color: rgba(42,39,35,0.50);
            font-family: 'Inter', sans-serif;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 4px 10px;
            border-radius: 6px;
        }
        .card-status-raw      { background: #FFF3E0; color: #B06A00; }
        .card-status-refine   { background: var(--accent-pale); color: var(--accent); }
        .card-status-meta     { background: #E8F5E9; color: #2E7D32; }

        .dot-rating { display: flex; gap: 5px; align-items: center; }
        .dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--accent-pale);
            border: 1.5px solid var(--accent-light);
            transition: background 0.2s;
        }
        .dot.filled { background: var(--accent); border-color: var(--accent); }

        /* ── Animations ── */
        @keyframes cardIn     { from { opacity:0; transform: translateY(28px) scale(0.96); } to { opacity:1; transform:translateY(0) scale(1); } }
        @keyframes textReveal { from { opacity:0; transform: translateY(10px); } to { opacity:1; transform:translateY(0); } }
        @keyframes drawStroke { to { stroke-dashoffset: 0; } }
        @keyframes sidebarIn  { to { opacity:1; transform:translateY(0); } }
        @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }

        .modal-card       { background-color:#FDFCF9; background-image:url("https://www.transparenttextures.com/patterns/natural-paper.png"); animation: cardIn 0.5s cubic-bezier(0.16,1,0.3,1) forwards; }
        .modal-title-text { opacity:0; animation: textReveal 0.6s cubic-bezier(0.16,1,0.3,1) 0.1s forwards; }
        .modal-reveal     { opacity:0; animation: textReveal 0.5s cubic-bezier(0.16,1,0.3,1) 0.28s forwards; }
        .draw-line path   { stroke-dasharray:600; stroke-dashoffset:600; animation: drawStroke 1.1s cubic-bezier(0.22,1,0.36,1) 0.18s forwards; }
        .sidebar-block    { opacity:0; transform:translateY(12px); animation: sidebarIn 0.45s cubic-bezier(0.16,1,0.3,1) forwards; }
        .sidebar-block:nth-child(1){ animation-delay:.20s; }
        .sidebar-block:nth-child(2){ animation-delay:.32s; }
        .sidebar-block:nth-child(3){ animation-delay:.44s; }

        .swoosh-path { stroke-dasharray:100; stroke-dashoffset:100; }
        .animate-draw-line { animation: drawSwoosh 0.8s ease-out 0.4s forwards; }
        .hand-underline-sm { position:relative; display:inline-block; }

        /* ─────────────────────────────────────
           NOTE MODAL  (layer 1)
        ───────────────────────────────────── */
        #note-modal {
            position: fixed; inset: 0; z-index: 100;
            display: none;
            align-items: center; justify-content: center;
            padding: 2rem;
            background: rgba(42,39,35,0.32);
            backdrop-filter: blur(9px);
            -webkit-backdrop-filter: blur(9px);
        }

        .note-modal-inner {
            width: 100%; max-width: 760px;
            max-height: 90vh;
            background-color: var(--paper, #FDFCF9);
            background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                radial-gradient(circle at 10% 90%, rgba(155,124,200,0.04) 0%, transparent 60%);
            background-position: 0 0, 0 0;
            background-repeat: repeat, no-repeat;
            border-radius: 36px;
            border: 1px solid rgba(255,255,255,0.6);
            box-shadow: 0 40px 100px rgba(155,124,200,0.18);
            overflow: hidden;
            position: relative;
            display: flex;
            flex-direction: column;
        }

        /* scrollable body */
        .note-modal-scroll {
            overflow-y: auto;
            flex: 1;
            padding: 3rem 3.5rem 2.5rem;
        }

        /* close btn */
        .modal-close {
            position: absolute; top: 1.4rem; right: 1.4rem; z-index: 10;
            width: 38px; height: 38px; border-radius: 50%;
            background: rgba(255,255,255,0.85);
            border: 1px solid rgba(42,39,35,0.12);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: rgba(42,39,35,0.45);
            transition: all 0.2s;
        }
        .modal-close:hover { background: var(--accent-pale); color: var(--accent); border-color: var(--accent-light); }
        .modal-close svg { transition: transform 0.3s; }
        .modal-close:hover svg { transform: rotate(90deg); }

        /* bg letter watermark */
        .modal-bg-letter {
            position: absolute; top: 1rem; right: 2rem;
            font-family: 'EB Garamond', serif;
            font-size: 20rem; font-weight: 700;
            color: rgba(42,39,35,0.018);
            line-height: 1; pointer-events: none; user-select: none;
            z-index: 0;
        }

        /* content above watermark */
        .note-modal-scroll > * { position: relative; z-index: 1; }

        /* title block */
        .modal-title-block { margin-bottom: 2rem; }
        .modal-dot-row { display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 0.6rem; }
        .modal-title {
            font-family: 'EB Garamond', serif;
            font-size: 3rem; font-weight: 500;
            line-height: 1.1; color: var(--ink, #2A2724);
        }
        .modal-pill {
            display: inline-flex; align-items: center; gap: 5px;
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem; font-weight: 600;
            letter-spacing: 0.06em; text-transform: uppercase;
            padding: 5px 12px; border-radius: 100px;
        }
        .modal-pill-neutral {
            background: rgba(42,39,35,0.05); color: rgba(42,39,35,0.55);
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem; font-weight: 600;
            letter-spacing: 0.06em; text-transform: uppercase;
            padding: 5px 12px; border-radius: 100px;
            display: inline-flex;
        }
        .modal-status-raw    { background: #FFF3E0; color: #B06A00; }
        .modal-status-refine { background: var(--accent-pale); color: var(--accent); }
        .modal-status-meta   { background: #E8F5E9; color: #2E7D32; }

        .modal-meta-row {
            display: flex; align-items: center; gap: 0.75rem;
            margin-left: 2.75rem; flex-wrap: wrap;
        }
        .modal-date {
            font-family: 'Reenie Beanie', cursive;
            font-size: 1.3rem; color: #A39985;
        }

        .modal-divider {
            width: 100%; height: 1px;
            background: linear-gradient(90deg, rgba(196,168,232,0.4), rgba(196,168,232,0.1), transparent);
            margin-bottom: 2rem;
        }

        .modal-body-prose {
            font-family: 'EB Garamond', serif;
            font-size: 1.2rem; line-height: 1.85;
            color: rgba(42,39,35,0.82);
            margin-bottom: 2.5rem;
        }

        .modal-section-label {
            font-family: 'Inter', sans-serif;
            font-size: 0.6rem; font-weight: 700;
            letter-spacing: 0.14em; text-transform: uppercase;
            color: rgba(42,39,35,0.35);
            margin-bottom: 0.6rem;
        }
        .concept-chip {
            display: inline-block;
            background: rgba(155,124,200,0.08);
            border: 1px solid rgba(155,124,200,0.25);
            color: var(--accent-dark);
            font-family: 'EB Garamond', serif;
            font-size: 0.95rem;
            padding: 6px 14px; border-radius: 12px;
        }

        /* ── Properties button (lives inside modal footer) ── */
        .modal-footer-bar {
            padding: 1rem 2.5rem 1.5rem;
            border-top: 1px solid rgba(155,124,200,0.10);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(253,252,249,0.8);
            backdrop-filter: blur(8px);
            flex-shrink: 0;
        }

        .properties-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-family: 'Inter', sans-serif;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(42,39,35,0.45);
            background: transparent;
            border: 1.5px solid rgba(42,39,35,0.12);
            border-radius: 100px;
            padding: 7px 16px;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .properties-btn:hover {
            color: var(--accent);
            border-color: var(--accent-light);
            background: var(--accent-pale);
        }
        .properties-btn svg { flex-shrink: 0; transition: transform 0.2s; }
        .properties-btn:hover svg { transform: rotate(15deg); }

        /* ─────────────────────────────────────
           PROPERTIES MODAL  (layer 2 — nested)
        ───────────────────────────────────── */
        #props-overlay {
            position: absolute;
            inset: 0;
            z-index: 20;
            display: flex;
            align-items: flex-end;
            justify-content: stretch;
            background: rgba(42,39,35,0.18);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            border-radius: 36px;
            overflow: hidden;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease;
        }
        #props-overlay.open {
            opacity: 1;
            pointer-events: all;
        }

        /* the panel slides up from the bottom */
        .props-panel {
            width: 100%;
            background-color: var(--paper, #FDFCF9);
            background-image:
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                radial-gradient(circle at 95% 5%, rgba(155,124,200,0.07) 0%, transparent 55%);
            background-position: 0 0, 0 0;
            background-repeat: repeat, no-repeat;
            border-radius: 28px 28px 36px 36px;
            border-top: 1px solid rgba(155,124,200,0.18);
            box-shadow: 0 -12px 48px rgba(42,39,35,0.14);
            transform: translateY(100%);
            transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
            max-height: 82%;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        #props-overlay.open .props-panel {
            transform: translateY(0);
        }

        /* accent band */
        .props-band {
            height: 4px;
            background: linear-gradient(90deg, var(--accent-light), var(--accent), var(--accent-light));
            opacity: 0.55;
            border-radius: 28px 28px 0 0;
            flex-shrink: 0;
        }

        /* drag handle hint */
        .props-handle {
            display: flex; justify-content: center;
            padding: 0.9rem 0 0.2rem;
            flex-shrink: 0;
        }
        .props-handle-bar {
            width: 36px; height: 4px;
            background: rgba(42,39,35,0.12);
            border-radius: 2px;
        }

        /* header */
        .props-header {
            padding: 0.5rem 1.8rem 1.1rem;
            display: flex; align-items: center; justify-content: space-between;
            flex-shrink: 0;
        }
        .props-header-left {}
        .props-eyebrow {
            font-family: 'Inter', sans-serif;
            font-size: 9px; font-weight: 700;
            letter-spacing: 0.16em; text-transform: uppercase;
            color: rgba(42,39,35,0.28);
            margin-bottom: 0.2rem;
        }
        .props-title {
            font-family: 'EB Garamond', serif;
            font-size: 1.35rem; font-weight: 500;
            color: var(--ink, #2A2724); line-height: 1.2;
        }

        .props-close {
            width: 30px; height: 30px; border-radius: 50%;
            background: rgba(255,255,255,0.9);
            border: 1px solid rgba(42,39,35,0.10);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: rgba(42,39,35,0.38);
            transition: all 0.2s; flex-shrink: 0;
        }
        .props-close:hover { background: var(--accent-pale); color: var(--accent); border-color: var(--accent-light); }

        /* header divider */
        .props-header-divider {
            height: 1px; margin: 0 1.8rem;
            background: linear-gradient(90deg, rgba(155,124,200,0.2), transparent);
            flex-shrink: 0;
        }

        /* scrollable properties list */
        .props-body {
            overflow-y: auto;
            padding: 1.2rem 1.8rem 2rem;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
        }
        .props-body::-webkit-scrollbar { width: 4px; }
        .props-body::-webkit-scrollbar-thumb { background: rgba(155,124,200,0.2); border-radius: 10px; }

        .prop-row {
            padding: 0.9rem 0.6rem;
            border-bottom: 1px solid rgba(42,39,35,0.05);
            opacity: 0;
            transform: translateY(6px);
            transition: opacity 0.3s ease, transform 0.3s ease;
        }
        .prop-row.full-width {
            grid-column: 1 / -1;
        }
        .prop-row.row-span-2 {
            grid-row: span 2;
            border-bottom: none;
        }
        #props-overlay.open .prop-row { opacity: 1; transform: translateY(0); }
        #props-overlay.open .prop-row:nth-child(1)  { transition-delay: 0.08s; }
        #props-overlay.open .prop-row:nth-child(2)  { transition-delay: 0.12s; }
        #props-overlay.open .prop-row:nth-child(3)  { transition-delay: 0.16s; }
        #props-overlay.open .prop-row:nth-child(4)  { transition-delay: 0.20s; }
        #props-overlay.open .prop-row:nth-child(5)  { transition-delay: 0.24s; }
        #props-overlay.open .prop-row:nth-child(6)  { transition-delay: 0.28s; }
        #props-overlay.open .prop-row:nth-child(7)  { transition-delay: 0.32s; }
        #props-overlay.open .prop-row:nth-child(8)  { transition-delay: 0.36s; }
        #props-overlay.open .prop-row:nth-child(9)  { transition-delay: 0.40s; }
        #props-overlay.open .prop-row:nth-child(10) { transition-delay: 0.44s; }

        .prop-label {
            font-family: 'Inter', sans-serif;
            font-size: 8.5px; font-weight: 700;
            letter-spacing: 0.13em; text-transform: uppercase;
            color: rgba(42,39,35,0.30);
            margin-bottom: 0.4rem;
        }
        .prop-value {
            font-family: 'EB Garamond', serif;
            font-size: 1rem; color: rgba(42,39,35,0.78);
            line-height: 1.35;
        }
        .prop-value.italic-accent { color: var(--accent); font-style: italic; }
        .prop-value.handwriting {
            font-family: 'Reenie Beanie', cursive;
            font-size: 1.2rem; color: #A39985; line-height: 1.2;
        }

        /* chips inside props */
        .prop-chips { display: flex; flex-wrap: wrap; gap: 5px; }
        .prop-chip {
            font-family: 'Inter', sans-serif;
            font-size: 8.5px; font-weight: 700;
            letter-spacing: 0.09em; text-transform: uppercase;
            padding: 3px 9px; border-radius: 5px;
        }
        .prop-chip-accent   { background: var(--accent-pale); color: var(--accent); }
        .prop-chip-raw      { background: #FFF3E0; color: #B06A00; }
        .prop-chip-meta     { background: #E8F5E9; color: #2E7D32; }
        .prop-chip-neutral  { background: rgba(42,39,35,0.06); color: rgba(42,39,35,0.48); }
        .prop-concept-chip {
            display: inline-block;
            background: rgba(155,124,200,0.08);
            border: 1px solid rgba(155,124,200,0.22);
            color: var(--accent-dark);
            font-family: 'EB Garamond', serif;
            font-size: 0.88rem;
            padding: 4px 11px; border-radius: 9px;
        }

        /* status pipeline */
        .prop-pipeline { display: flex; flex-direction: column; gap: 0.4rem; }
        .prop-pipeline-step { display: flex; align-items: center; gap: 0.5rem; }
        .prop-pipeline-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
        .prop-pipeline-label { font-family: 'EB Garamond', serif; font-size: 0.9rem; }

        /* scrollbar (main modal) */
        .note-modal-scroll::-webkit-scrollbar { width: 5px; }
        .note-modal-scroll::-webkit-scrollbar-track { background: transparent; }
        .note-modal-scroll::-webkit-scrollbar-thumb { background: rgba(155,124,200,0.2); border-radius: 10px; }

        /* ── Star filter ── */
        .star-filter { transition: all 0.25s ease; cursor: pointer; display: flex; align-items: center; justify-content: center; background: none; border: none; padding: 0; }
        .star-filter.active { color: var(--accent) !important; opacity: 1 !important; }
        .star-filter.active svg { color: var(--accent) !important; }
        .star-filter.active svg path { fill: var(--accent) !important; fill-opacity: 0.7 !important; stroke: var(--accent) !important; }
        .star-filter:not(.active) { color: #A39985 !important; opacity: 0.45 !important; }
        .star-filter:not(.active) svg path { fill: #A39985 !important; fill-opacity: 0.12 !important; stroke: #A39985 !important; }
        .star-filter:hover { transform: scale(1.12); }

        /* ── Bottom bar ── */
        #bottom-bar { transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), opacity 0.4s ease; }
        #bottom-bar.hidden-bar { transform: translateY(120%); opacity: 0; pointer-events: none; }

        .modal-scrollbar::-webkit-scrollbar { width: 4px; }
        .modal-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .modal-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(155,124,200,0.2); border-radius: 10px; }
    </style>
</head>
<body class="min-h-screen antialiased selection:bg-[#9B7CC8] selection:text-white">

    <!-- ─────────────── NAV ─────────────── -->
    <header class="sticky top-0 z-50 w-full h-[80px] bg-[#F5F2EB]/95 glass-nav flex items-center justify-between px-10 shadow-sm" style="border-bottom: 0.5px solid rgba(42,39,35,0.08);">
        <div class="flex items-center gap-10">
            <a href="/astro-project-v2/" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Main Page</a>
            <div class="h-8 w-px bg-[#E8E2D2]"></div>
            <nav class="flex items-center gap-8 translate-y-[2px]">
                <a href="/astro-project-v2/notes" class="group flex items-center gap-2 transition-all duration-300 hover:-translate-y-[1px]">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#9B7CC8] shadow-[0_0_8px_rgba(155,124,200,0.55)]"></span>
                    <span class="font-serif text-xl text-[#2A2724]">Notes</span>
                </a>
            </nav>
        </div>
        <div class="font-['Reenie_Beanie'] text-[1.75rem] leading-none text-[#9B7CC8] tracking-tight translate-y-1">hyperlynxt | teo</div>
    </header>

    <!-- ─────────────── HERO ─────────────── -->
    <section class="w-full bg-gradient-to-b from-[#F5F2EB] to-transparent pt-20 pb-16 px-6">
        <div class="max-w-4xl mx-auto text-center">
            <span class="font-['Reenie_Beanie'] text-2xl text-[#8C8070] mb-2 block">thoughts mid-formation</span>
            <h2 class="font-serif text-5xl md:text-7xl leading-tight text-[#2A2724] mb-8">
                Raw
                <span class="italic hand-underline-sm inline-block">
                    Notes
                    <svg class="absolute w-[110%] h-[12px] -bottom-1 -left-[5%] text-[#9B7CC8] opacity-80 overflow-visible" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                        <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path animate-draw-line"></path>
                    </svg>
                </span>
            </h2>
            <p class="font-serif italic text-lg md:text-xl text-[#8C8070] max-w-2xl mx-auto leading-relaxed">
                Drafts, half-arguments, questions without answers. The working material before it becomes something else.
            </p>
        </div>
    </section>

    <!-- ─────────────── TOOLBAR ─────────────── -->
    <div class="max-w-[1400px] mx-auto px-6 md:px-10 mb-6 flex items-center justify-between pb-3" style="border-bottom: 1px solid rgba(42,39,35,0.08);">
        <span class="font-sans text-[10px] font-bold uppercase tracking-[0.14em] text-[#2A2724]/40">The Draft Pile</span>
        <span id="count-label" class="font-serif italic text-[#2A2724]/35 text-sm">{notes.length} notes</span>
    </div>

    <!-- ─────────────── GRID ─────────────── -->
    <main class="max-w-[1400px] mx-auto px-6 md:px-10 pb-36">
        <div class="notes-grid" id="notes-grid">
            {notes.map((entry) => {
                const statusClass =
                    entry.data.status === 'Raw'      ? 'card-status-raw'  :
                    entry.data.status === 'Refine'   ? 'card-status-refine' :
                    'card-status-meta';

                const dotsHtml = [1,2,3].map(i =>
                    `<span class="dot${i <= (entry.data.rating||0) ? ' filled' : ''}"></span>`
                ).join('');



                return (
                    <article
                        class="note-card"
                        data-id={entry.id}
                        data-title={entry.data.title}
                        data-body={entry.data.body || ''}
                        data-rating={entry.data.rating || 0}
                        data-date={entry.data.date}
                        data-status={entry.data.status || ''}
                        data-notetype={entry.data.note_type || ''}
                        data-discipline={entry.data.primary_discipline || ''}
                        data-subdiscipline={entry.data.sub_discipline || ''}
                        data-lens={entry.data.analytical_lens || ''}
                        data-concepts={Array.isArray(entry.data.concepts_used) ? entry.data.concepts_used.join('||') : (entry.data.concepts_used || '')}
                        data-tags={(entry.data.tags || []).join(',')}
                    >
                        <!-- expand hint -->
                        <span class="card-expand">↗</span>

                        <!-- Draft icon -->
                        <div class="card-draft-icon">
                            <!-- Lucide pocket-knife icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-feather"><path d="M12.67 19a2 2 0 0 0 1.416-.588l6.154-6.172a6 6 0 0 0-8.49-8.49L5.586 9.914A2 2 0 0 0 5 11.328V18a1 1 0 0 0 1 1z"/><path d="M16 8 2 22"/><path d="M17.5 15H9"/></svg>
                        </div>

                        <!-- Title -->
                        <h3 class="card-title">{entry.data.title}</h3>


                        <!-- Footer -->
                        <div class="card-footer">
                            <div class="flex flex-wrap gap-1.5 items-center">
                                <span class={`card-tag ${statusClass}`}>{entry.data.status || 'Raw'}</span>
                                {entry.data.note_type && (
                                    <span class="card-tag-neutral">{entry.data.note_type}</span>
                                )}
                            </div>

                        </div>
                    </article>
                );
            })}
        </div>
    </main>

    <!-- ─────────────── BOTTOM BAR ─────────────── -->
    <div id="bottom-bar" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-white/80 backdrop-blur-xl border border-[#E8E2D2] rounded-[24px] shadow-[0_20px_50px_rgba(42,39,36,0.15)] p-2.5 flex items-center z-50">
        <div class="flex items-center gap-3 pl-4 pr-3 py-2 group cursor-text" onclick="const input = document.getElementById('notes-search'); if(input) input.focus()">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#A39985] group-hover:text-[#9B7CC8] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            <input type="text" id="notes-search" placeholder="Search notes" class="bg-transparent border-none outline-none font-sans text-xs font-bold text-[#2A2724] placeholder:text-[#A39985] w-32 transition-all focus:w-48">
        </div>
        <div class="w-px h-6 bg-[#E8E2D2] mx-1"></div>
