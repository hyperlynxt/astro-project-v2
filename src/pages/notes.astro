                    </div>
                    <div class="flex gap-4 p-3.5 bg-white border border-[#C4A8E8]/20 rounded-2xl w-fit" id="filter-rating-dots">
                        <button data-rating="0" class="star-filter active active:scale-95">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="8" fill="currentColor" fill-opacity="0.6"></circle>
                            </svg>
                        </button>
                        <button data-rating="1" class="star-filter active:scale-95">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="8" fill="currentColor" fill-opacity="0.6"></circle>
                            </svg>
                        </button>
                        <button data-rating="2" class="star-filter active:scale-95">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="8" fill="currentColor" fill-opacity="0.6"></circle>
                            </svg>
                        </button>
                        <button data-rating="3" class="star-filter active:scale-95">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="8" fill="currentColor" fill-opacity="0.6"></circle>
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#C4A8E8]/30 to-transparent"></div>

                <!-- Status filter -->
                <div>
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-3.5 h-3.5 text-[#9B7CC8]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Status</h3>
                    </div>
                    <div class="flex flex-wrap gap-2" id="filter-status-container">
                        {['Raw','Refine','Metastasis / Converted'].map(s => (
                            <button data-status={s} class="status-filter-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:border-[#C4A8E8] transition-all shadow-sm">{s}</button>
                        ))}
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#C4A8E8]/30 to-transparent"></div>

                <!-- Note type filter -->
                <div>
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-3.5 h-3.5 text-[#9B7CC8]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                        <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Note Type</h3>
                    </div>
                    <div class="flex flex-wrap gap-2" id="filter-type-container">
                        {['Question','Observation','Synthesis','Analysis','Argument','Interpersonal'].map(t => (
                            <button data-notetype={t} class="type-filter-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:border-[#C4A8E8] transition-all shadow-sm">{t}</button>
                        ))}
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#C4A8E8]/30 to-transparent"></div>

                <!-- Discipline filter -->
                <div>
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-3.5 h-3.5 text-[#9B7CC8]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                        <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Discipline</h3>
                    </div>
                    <div class="flex flex-wrap gap-2" id="filter-discipline-container">
                        {['Sociology','Psychology','Linguistics','Cognitive Science'].map(d => (
                            <button data-discipline={d} class="discipline-filter-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:border-[#C4A8E8] transition-all shadow-sm">{d}</button>
                        ))}
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#C4A8E8]/30 to-transparent"></div>

                <!-- Tags -->
