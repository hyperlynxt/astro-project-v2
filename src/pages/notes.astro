            <!-- Footer actions -->
            <div class="px-7 pb-6 pt-4 border-t border-[#C4A8E8]/10 flex items-center justify-between bg-white/60 flex-shrink-0">
                <div class="flex items-center gap-2 text-sm font-sans text-[#2A2724]/50">
                    <span id="filter-result-count" class="font-medium text-[#9B7CC8]">{notes.length} notes</span>
                    <span>match</span>
                </div>
                <div class="flex items-center gap-3">
                    <button id="clear-filters-btn" class="px-5 py-2 rounded-full text-sm font-sans font-medium text-[#2A2724]/60 border border-[#D5CCB6]/30 hover:border-[#C4A8E8] hover:text-[#9B7CC8] transition-all">Clear</button>
                    <button id="apply-filters-btn" class="px-5 py-2 rounded-full text-sm font-sans font-medium text-white transition-all hover:-translate-y-[1px]" style="background: #9B7CC8; box-shadow: 0 4px 14px rgba(155,124,200,0.35);">Apply</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ─────────────── SCRIPTS ─────────────── -->
    <script>
        const cards       = document.querySelectorAll('.note-card');
        const notesGrid   = document.getElementById('notes-grid');
        const noteModal   = document.getElementById('note-modal');
        const filterModal = document.getElementById('filter-modal');
        const bottomBar   = document.getElementById('bottom-bar');

        // ── Filter state ──
        let filterState = {
            query:       '',
            sort:        'default',
            sortOrder:   'desc',
            minRating:   0,
            statuses:    [],
            noteTypes:   [],
            disciplines: [],
            tags:        [],
        };

        // ── Bottom bar toggle ──
        function toggleBottomBar(show) {
            bottomBar.classList.toggle('hidden-bar', !show);
        }

        /* ── helpers ── */
        function dots(n) {
            return [1,2,3].map(i => `<span class="dot${i<=n?' filled':''}"></span>`).join('');
        }
        function fmtDate(str) {
            if (!str) return '—';
            return new Date(str).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        }

        // ── Open note modal ──
        cards.forEach(card => {
            card.addEventListener('click', () => {
                const d = card.dataset;

                // watermark
                document.getElementById('modal-bg-letter').textContent = (d.title||'')[0].toUpperCase();

                // title
                document.getElementById('modal-title').textContent = d.title || '';

                // date
                document.getElementById('modal-footer-date').textContent = fmtDate(d.date);

                // body
                document.getElementById('modal-body').textContent = d.body || '';

                // store data on props button for quick access
                document.getElementById('open-props-btn').dataset.cardData = JSON.stringify(d);

                // reset props panel
                document.getElementById('props-overlay').classList.remove('open');

                noteModal.style.display = 'flex';
                document.body.style.overflow = 'hidden';
                toggleBottomBar(false);
                document.querySelector('.note-modal-scroll').scrollTop = 0;
            });
        });

        function closeModal() {
            document.getElementById('props-overlay').classList.remove('open');
            noteModal.style.display = 'none';
            if (filterModal.style.display !== 'flex') {
                document.body.style.overflow = '';
                toggleBottomBar(true);
            }
        }
        document.getElementById('close-note-modal').addEventListener('click', closeModal);
        noteModal.addEventListener('click', e => { if (e.target === noteModal) closeModal(); });

        /* ── Properties panel ── */
        document.getElementById('open-props-btn').addEventListener('click', () => {
            const raw = document.getElementById('open-props-btn').dataset.cardData;
            if (!raw) return;
            const d = JSON.parse(raw);
            buildPropsPanel(d);
            document.getElementById('props-overlay').classList.add('open');
        });

        document.getElementById('close-props-btn').addEventListener('click', () => {
            document.getElementById('props-overlay').classList.remove('open');
        });

        // click backdrop of props overlay closes it
        document.getElementById('props-overlay').addEventListener('click', e => {
            if (e.target === document.getElementById('props-overlay')) {
                document.getElementById('props-overlay').classList.remove('open');
            }
        });

        function buildPropsPanel(d) {
            document.getElementById('props-title').textContent = d.title || '—';

            const body = document.getElementById('props-body');
            body.innerHTML = '';

            const pipeline = ['Raw', 'Refine', 'Metastasis / Converted'];
            const statusIdx = pipeline.findIndex(s => s.toLowerCase().includes((d.status||'').toLowerCase()));

            const rows = [
                {
                    label: 'Status',
                    html: `<div class="prop-pipeline">
                        ${pipeline.map((step, i) => {
                            const isCurrent = i === statusIdx;
                            const isPast    = i < statusIdx;
                            let dotStyle    = 'background:rgba(42,39,35,0.15);';
                            let labelCls    = 'color:rgba(42,39,35,0.35);';
                            if (isCurrent) {
                                if (d.status==='Raw')    { dotStyle='background:#B06A00;'; labelCls='color:#B06A00;font-weight:500;'; }
                                else if (d.status==='Refine') { dotStyle='background:var(--accent);'; labelCls='color:var(--accent);font-weight:500;'; }
                                else                          { dotStyle='background:#2E7D32;'; labelCls='color:#2E7D32;font-weight:500;'; }
                            } else if (isPast) {
                                dotStyle='background:var(--accent-light);';
                            }
                            return `<div class="prop-pipeline-step">
                                <span class="prop-pipeline-dot" style="${dotStyle}"></span>
                                <span class="prop-pipeline-label" style="${labelCls}">${step}</span>
                            </div>`;
                        }).join('')}
                    </div>`,
                    span2: true
                },
                { label: 'Rating',   html: `<div class="dot-rating">${dots(parseInt(d.rating)||0)}</div>` },
                { label: 'Date',     html: `<span class="prop-value handwriting">${fmtDate(d.date)}</span>` },
                
                // Paired Row: Note Type & Analytical Lens
                { label: 'Note Type', html: d.notetype ? `<span class="prop-chip prop-chip-neutral">${d.notetype}</span>` : '<span class="prop-value">—</span>' },
                { label: 'Analytical Lens', html: d.lens ? `<span class="prop-value italic-accent">${d.lens}</span>` : '<span class="prop-value">—</span>' },

                // Paired Row: Discipline & Sub-discipline
                { label: 'Discipline', html: d.discipline ? `<span class="prop-value">${d.discipline}</span>` : '<span class="prop-value">—</span>' },
                { label: 'Sub-discipline', html: d.subdiscipline ? `<span class="prop-value">${d.subdiscipline}</span>` : '<span class="prop-value">—</span>' },

                d.tags ? {
                    label: 'Tags',
                    html: `<div class="prop-chips">${d.tags.split(',').map(t=>`<span class="prop-chip prop-chip-neutral">${t.trim()}</span>`).join('')}</div>`,
                    full: true
                } : null,
                d.concepts ? {
                    label: 'Concepts',
                    html: `<div class="prop-chips">${d.concepts.split('||').map(c=>`<span class="prop-concept-chip">${c.trim()}</span>`).join('')}</div>`,
                    full: true
                } : null,
            ].filter(Boolean);

            rows.forEach(row => {
                const div = document.createElement('div');
                div.className = 'prop-row';
                if (row.full) div.classList.add('full-width');
                if (row.span2) div.classList.add('row-span-2');
                div.innerHTML = `<p class="prop-label">${row.label}</p><div>${row.html}</div>`;
                body.appendChild(div);
            });
        }

        // ── Filter modal ──
        function openFilterModal() {
            filterModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            toggleBottomBar(false);
            renderTagFilters();
            updatePreviewCount();
        }
        function closeFilterModal() {
            filterModal.style.display = 'none';
            if (noteModal.style.display !== 'flex') {
                document.body.style.overflow = '';
                toggleBottomBar(true);
            }
        }
        document.getElementById('open-filter-btn').addEventListener('click', openFilterModal);
        document.getElementById('close-filter-btn').addEventListener('click', closeFilterModal);
        document.getElementById('apply-filters-btn').addEventListener('click', () => { applyFilters(); closeFilterModal(); });
        document.getElementById('clear-filters-btn').addEventListener('click', clearAllFilters);
        filterModal.addEventListener('click', e => { if (e.target === filterModal) closeFilterModal(); });

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                const propsOpen = document.getElementById('props-overlay').classList.contains('open');
                if (propsOpen) {
                    document.getElementById('props-overlay').classList.remove('open');
                } else {
                    closeModal();
                    closeFilterModal();
                }
            }
        });

        // ── Sort buttons ──
        document.querySelectorAll('.sort-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                filterState.sort = btn.dataset.sort;
                document.querySelectorAll('.sort-btn').forEach(b => {
                    b.classList.remove('bg-[#9B7CC8]','text-white','shadow-lg','border-[#9B7CC8]');
                    b.classList.add('bg-white','text-[#2A2724]/70','border-[#D5CCB6]/30');
                });
                btn.classList.remove('bg-white','text-[#2A2724]/70','border-[#D5CCB6]/30');
                btn.classList.add('bg-[#9B7CC8]','text-white','shadow-lg','border-[#9B7CC8]');
                updatePreviewCount();
            });
        });

        document.getElementById('sort-direction-toggle').addEventListener('click', function () {
            filterState.sortOrder = filterState.sortOrder === 'desc' ? 'asc' : 'desc';
            document.getElementById('sort-direction-label').textContent = filterState.sortOrder === 'desc' ? 'Descending' : 'Ascending';
            document.getElementById('sort-direction-icon').style.transform = filterState.sortOrder === 'asc' ? 'rotate(180deg)' : '';
            updatePreviewCount();
        });

        // ── Dot rating filter ──
        document.querySelectorAll('#filter-rating-dots .star-filter').forEach(btn => {
            btn.addEventListener('click', () => {
                const rating = parseInt(btn.dataset.rating);
                filterState.minRating = rating;
                document.querySelectorAll('#filter-rating-dots .star-filter').forEach((s, idx) => {
                    s.classList.toggle('active', idx <= rating);
                });
                document.getElementById('min-rating-label').textContent = `${rating}+ dots`;
                updatePreviewCount();
            });
        });

        // ── Status filter ──
        document.querySelectorAll('.status-filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const s = btn.dataset.status;
                const idx = filterState.statuses.indexOf(s);
                if (idx === -1) { filterState.statuses.push(s); btn.classList.add('bg-[#9B7CC8]','text-white'); btn.classList.remove('bg-white','text-[#2A2724]/70'); }
                else            { filterState.statuses.splice(idx,1); btn.classList.remove('bg-[#9B7CC8]','text-white'); btn.classList.add('bg-white','text-[#2A2724]/70'); }
                updatePreviewCount();
            });
        });

        // ── Note type filter ──
        document.querySelectorAll('.type-filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const t = btn.dataset.notetype;
                const idx = filterState.noteTypes.indexOf(t);
                if (idx === -1) { filterState.noteTypes.push(t); btn.classList.add('bg-[#9B7CC8]','text-white'); btn.classList.remove('bg-white','text-[#2A2724]/70'); }
                else            { filterState.noteTypes.splice(idx,1); btn.classList.remove('bg-[#9B7CC8]','text-white'); btn.classList.add('bg-white','text-[#2A2724]/70'); }
                updatePreviewCount();
            });
        });

        // ── Discipline filter ──
        document.querySelectorAll('.discipline-filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const d = btn.dataset.discipline;
                const idx = filterState.disciplines.indexOf(d);
                if (idx === -1) { filterState.disciplines.push(d); btn.classList.add('bg-[#9B7CC8]','text-white'); btn.classList.remove('bg-white','text-[#2A2724]/70'); }
                else            { filterState.disciplines.splice(idx,1); btn.classList.remove('bg-[#9B7CC8]','text-white'); btn.classList.add('bg-white','text-[#2A2724]/70'); }
                updatePreviewCount();
            });
        });

        // ── Tag filters (dynamic) ──
        function renderTagFilters() {
            const container = document.getElementById('filter-tags-container');
            const allTags   = new Set();
            cards.forEach(c => (c.dataset.tags || '').split(',').filter(Boolean).forEach(t => allTags.add(t.trim())));
            container.innerHTML = '';
            allTags.forEach(tag => {
                const btn = document.createElement('button');
                btn.textContent = tag;
                btn.dataset.tag = tag;
                const active = filterState.tags.includes(tag);
                btn.className = `tag-dyn-btn px-4 py-2 font-sans text-sm font-medium rounded-full border transition-all shadow-sm ${active ? 'bg-[#9B7CC8] text-white border-[#9B7CC8]' : 'bg-white text-[#2A2724]/70 border-[#D5CCB6]/30 hover:border-[#C4A8E8]'}`;
                btn.addEventListener('click', () => {
                    const idx = filterState.tags.indexOf(tag);
                    if (idx === -1) { filterState.tags.push(tag); btn.classList.add('bg-[#9B7CC8]','text-white','border-[#9B7CC8]'); btn.classList.remove('bg-white','text-[#2A2724]/70'); }
                    else            { filterState.tags.splice(idx,1); btn.classList.remove('bg-[#9B7CC8]','text-white','border-[#9B7CC8]'); btn.classList.add('bg-white','text-[#2A2724]/70'); }
                    updatePreviewCount();
                });
                container.appendChild(btn);
            });
        }

        // ── Match logic ──
        function cardMatches(card) {
            const title      = (card.dataset.title      || '').toLowerCase();
            const body       = (card.dataset.body       || '').toLowerCase();
            const rating     = parseInt(card.dataset.rating) || 0;
            const status     = (card.dataset.status     || '').toLowerCase();
            const noteType   = (card.dataset.notetype   || '').toLowerCase();
            const discipline = (card.dataset.discipline || '').toLowerCase();
            const tags       = (card.dataset.tags       || '').split(',').map(t => t.trim().toLowerCase()).filter(Boolean);

            const q = filterState.query;
            if (q && !title.includes(q) && !body.includes(q)) return false;
            if (rating < filterState.minRating) return false;
            if (filterState.statuses.length   && !filterState.statuses.some(s => status.includes(s.toLowerCase()))) return false;
            if (filterState.noteTypes.length  && !filterState.noteTypes.some(t => noteType.includes(t.toLowerCase()))) return false;
            if (filterState.disciplines.length && !filterState.disciplines.some(d => discipline.includes(d.toLowerCase()))) return false;
            if (filterState.tags.length       && !filterState.tags.some(t => tags.includes(t.toLowerCase()))) return false;
            return true;
        }

        function updatePreviewCount() {
            const count = Array.from(cards).filter(c => cardMatches(c)).length;
            document.getElementById('filter-result-count').textContent = `${count} notes`;
        }

        const originalOrder = Array.from(cards);
        function applyFilters() {
            const arr = Array.from(cards);
            arr.forEach(c => { c.style.display = cardMatches(c) ? '' : 'none'; });
            const visible  = arr.filter(c => c.style.display !== 'none');
            const isDesc   = filterState.sortOrder === 'desc';

            const sortTarget = filterState.sort === 'default'
                ? originalOrder.filter(c => visible.includes(c))
                : visible;

            if (filterState.sort !== 'default') {
                sortTarget.sort((a, b) => {
                    if (filterState.sort === 'alphabetical') {
                        const cmp = a.dataset.title.localeCompare(b.dataset.title);
                        return isDesc ? -cmp : cmp;
                    }
                    if (filterState.sort === 'rating') {
                        const cmp = parseInt(a.dataset.rating) - parseInt(b.dataset.rating);
                        return isDesc ? -cmp : cmp;
                    }
                    if (filterState.sort === 'date') {
                        const cmp = new Date(a.dataset.date).getTime() - new Date(b.dataset.date).getTime();
                        return isDesc ? -cmp : cmp;
                    }
                    return 0;
                });
            }

            sortTarget.forEach(c => notesGrid.appendChild(c));

            const total = cards.length;
            document.getElementById('count-label').textContent =
                visible.length === total ? `${total} notes` : `${visible.length} of ${total} notes`;
        }

        function clearAllFilters() {
            filterState = { query:'', sort:'default', sortOrder:'desc', minRating:0, statuses:[], noteTypes:[], disciplines:[], tags:[] };
            document.getElementById('notes-search').value = '';
            // reset sort buttons
            document.querySelectorAll('.sort-btn').forEach((b,i) => {
                b.classList.remove('bg-[#9B7CC8]','text-white','shadow-lg','border-[#9B7CC8]');
                b.classList.add('bg-white','text-[#2A2724]/70','border-[#D5CCB6]/30');
                if (i === 0) { b.classList.add('bg-[#9B7CC8]','text-white','shadow-lg'); b.classList.remove('bg-white','text-[#2A2724]/70'); }
            });
            document.querySelectorAll('#filter-rating-dots .star-filter').forEach((s,i) => s.classList.toggle('active', i === 0));
            document.getElementById('min-rating-label').textContent = '0+ dots';
            document.querySelectorAll('.status-filter-btn,.type-filter-btn,.discipline-filter-btn').forEach(b => {
                b.classList.remove('bg-[#9B7CC8]','text-white');
                b.classList.add('bg-white','text-[#2A2724]/70');
            });
            cards.forEach(c => { c.style.display = ''; });
            document.getElementById('count-label').textContent = `${cards.length} notes`;
            renderTagFilters();
            updatePreviewCount();
        }

        // ── Live search ──
        document.getElementById('notes-search').addEventListener('input', e => {
            filterState.query = e.target.value.toLowerCase().trim();
            applyFilters();
        });

        updatePreviewCount();
    </script>
</body>
</html>
