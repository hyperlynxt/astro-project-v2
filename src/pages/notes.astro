---
import { getCollection } from 'astro:content';
import '../styles/global.css';
import NoteModal from '../components/NoteModal.astro';

const notes = await getCollection('notes');
notes.sort((a, b) => {
  const ratingA = a.data.rating || 0;
  const ratingB = b.data.rating || 0;
  if (ratingB !== ratingA) return ratingB - ratingA;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlas Field Notes — Notes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@400;500;600;700&family=Reenie+Beanie&display=swap" rel="stylesheet">
    <style is:global>
        /* ── Base ── */
        body {
            background-color: #FDFCF9;
            background-image: 
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png");
            background-position: 
                0px 0px, 
                40px 60px, 
                80px 20px;
            background-repeat: repeat;
            color: #2A2724;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        /* ── Theme accent — pastel purple ── */
        :root {
            --accent:       #7BA08A;   /* main green */
            --accent-light: #A1C2AE;   /* hover / star */
            --accent-pale:  #E7F1EB;   /* soft background chips */
            --accent-dark:  #5B7B68;   /* deeper hover */
        }

        /* ── Nav ── */
        .glass-nav { backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); }

        /* ── Grid ── */
        .notes-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.75rem;
            align-items: start;
        }
        @media (min-width: 768px)  { .notes-grid { grid-template-columns: repeat(2,1fr); } }
        @media (min-width: 1280px) { .notes-grid { grid-template-columns: repeat(3,1fr); } }

        /* ── Card ── */
        .note-card {
            cursor: pointer;
            background-color: #fff;
            border-radius: 24px;
            padding: 2.2rem 2.2rem 1.8rem;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(42,39,35,0.10);
            box-shadow: 0 2px 12px rgba(42,39,35,0.06);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            min-height: 260px;
        }
        .note-card:hover {
            background: #F1F8F4;
            border-color: #A1C2AE;
            transform: translateY(-4px);
            box-shadow: 0 14px 28px -10px rgba(123,160,138,0.18);
        }
        .note-card:hover .card-title     { color: var(--accent); }
        .note-card:hover .card-draft-icon { color: var(--accent); }

        .card-expand {
            position: absolute; top: 1.1rem; right: 1.1rem;
            opacity: 0; transform: scale(0.85);
            transition: opacity 0.25s ease, transform 0.25s ease;
            color: rgba(42,39,35,0.28); font-size: 0.75rem; line-height: 1;
        }
        .note-card:hover .card-expand { opacity: 1; transform: scale(1); }

        /* Draft icon (pocket-knife) */
        .card-draft-icon {
            color: #2A2724;
            margin-bottom: 1rem;
            flex-shrink: 0;
            transition: color 0.3s ease;
        }

        .card-title {
            font-family: 'EB Garamond', serif;
            font-size: 1.45rem;
            font-weight: 500;
            line-height: 1.3;
            color: #2A2724;
            margin-bottom: 0.65rem;
            transition: color 0.3s ease;
        }
        .card-body {
            font-family: 'EB Garamond', serif;
            font-size: 1.01rem;
            line-height: 1.65;
            color: rgba(42,39,35,0.50);
            flex-grow: 1;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            line-clamp: 3;
            -webkit-box-orient: vertical;
        }

        /* ── Card footer ── */
        .card-footer {
            margin-top: 1.4rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(42,39,35,0.06);
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 0.75rem;
            flex-wrap: wrap;
        }
        .card-tag {
            background: var(--accent-pale);
            color: var(--accent);
            font-family: 'Inter', sans-serif;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 4px 10px;
            border-radius: 6px;
        }
        .card-tag-neutral {
            background: rgba(42,39,35,0.05);
            color: rgba(42,39,35,0.50);
            font-family: 'Inter', sans-serif;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 4px 10px;
            border-radius: 6px;
        }
        .card-status-raw      { background: #FFF3E0; color: #B06A00; }
        .card-status-refine   { background: var(--accent-pale); color: var(--accent); }
        .card-status-meta     { background: #E8F5E9; color: #2E7D32; }

        .dot-rating { display: flex; gap: 5px; align-items: center; }
        .dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--accent-pale);
            border: 1.5px solid var(--accent-light);
            transition: background 0.2s;
        }
        .dot.filled { background: var(--accent); border-color: var(--accent); }

        /* ── Animations ── */
        @keyframes cardIn     { from { opacity:0; transform: translateY(28px) scale(0.96); } to { opacity:1; transform:translateY(0) scale(1); } }
        @keyframes textReveal { from { opacity:0; transform: translateY(10px); } to { opacity:1; transform:translateY(0); } }
        @keyframes drawStroke { to { stroke-dashoffset: 0; } }
        @keyframes sidebarIn  { to { opacity:1; transform:translateY(0); } }
        @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }

        .modal-card       { background-color:#FDFCF9; background-image:url("https://www.transparenttextures.com/patterns/natural-paper.png"); animation: cardIn 0.5s cubic-bezier(0.16,1,0.3,1) forwards; }
        .modal-title-text { opacity:0; animation: textReveal 0.6s cubic-bezier(0.16,1,0.3,1) 0.1s forwards; }
        .modal-reveal     { opacity:0; animation: textReveal 0.5s cubic-bezier(0.16,1,0.3,1) 0.28s forwards; }
        .draw-line path   { stroke-dasharray:600; stroke-dashoffset:600; animation: drawStroke 1.1s cubic-bezier(0.22,1,0.36,1) 0.18s forwards; }
        .sidebar-block    { opacity:0; transform:translateY(12px); animation: sidebarIn 0.45s cubic-bezier(0.16,1,0.3,1) forwards; }
        .sidebar-block:nth-child(1){ animation-delay:.20s; }
        .sidebar-block:nth-child(2){ animation-delay:.32s; }
        .sidebar-block:nth-child(3){ animation-delay:.44s; }

        .swoosh-path { stroke-dasharray:100; stroke-dashoffset:100; }
        .animate-draw-line { animation: drawSwoosh 0.8s ease-out 0.4s forwards; }
        .hand-underline-sm { position:relative; display:inline-block; }

        .props-close:hover { background: var(--accent-pale); color: var(--accent); border-color: var(--accent-light); }

        /* header divider */
        .props-header-divider {
            height: 1px; margin: 0 1.8rem;
            background: linear-gradient(90deg, rgba(123,160,138,0.2), transparent);
            flex-shrink: 0;
        }

        /* scrollable properties list */
        .props-body {
            overflow-y: auto;
            padding: 1.2rem 1.8rem 2rem;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
        }
        .props-body::-webkit-scrollbar { width: 4px; }
        .props-body::-webkit-scrollbar-thumb { background: rgba(123,160,138,0.2); border-radius: 10px; }

        .prop-row {
            padding: 0.9rem 0.6rem;
            border-bottom: 1px solid rgba(42,39,35,0.05);
            opacity: 0;
            transform: translateY(6px);
            transition: opacity 0.3s ease, transform 0.3s ease;
        }
        .prop-row.full-width {
            grid-column: 1 / -1;
        }
        .prop-row.row-span-2 {
            grid-row: span 2;
            border-bottom: none;
        }
        #props-overlay.open .prop-row { opacity: 1; transform: translateY(0); }

        /* ── Star filter ── */
        .star-filter { transition: all 0.25s ease; cursor: pointer; display: flex; align-items: center; justify-content: center; background: none; border: none; padding: 0; }
        .star-filter.active { color: var(--accent) !important; opacity: 1 !important; }
        .star-filter.active svg { color: var(--accent) !important; }
        .star-filter.active svg path { fill: var(--accent) !important; fill-opacity: 0.7 !important; stroke: var(--accent) !important; }
        .star-filter:not(.active) { color: #A39985 !important; opacity: 0.45 !important; }
        .star-filter:not(.active) svg path { fill: #A39985 !important; fill-opacity: 0.12 !important; stroke: #A39985 !important; }
        .star-filter:hover { transform: scale(1.12); }

        /* ── Bottom bar ── */
        #bottom-bar { transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), opacity 0.4s ease; }
        #bottom-bar.hidden-bar { transform: translateY(120%); opacity: 0; pointer-events: none; }

        .modal-scrollbar::-webkit-scrollbar { width: 4px; }
        .modal-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .modal-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(123,160,138,0.2); border-radius: 10px; }
    </style>
</head>
<body class="min-h-screen antialiased selection:bg-[#7BA08A] selection:text-white">

    <!-- ─────────────── NAV ─────────────── -->
    <header class="sticky top-0 z-50 w-full h-[80px] bg-[#F5F2EB]/95 glass-nav flex items-center justify-between px-10 shadow-sm" style="border-bottom: 0.5px solid rgba(42,39,35,0.08);">
        <div class="flex items-center gap-10">
            <a href="/astro-project-v2/" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Main Page</a>
            <div class="h-8 w-px bg-[#E8E2D2]"></div>
            <nav class="flex items-center gap-8 translate-y-[2px]">
                <a href="/astro-project-v2/notes/" class="group flex items-center gap-2 transition-all duration-300 hover:-translate-y-[1px]">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#7BA08A] shadow-[0_0_8px_rgba(123,160,138,0.55)]"></span>
                    <span class="font-serif text-xl text-[#2A2724]">Notes</span>
                </a>
                <a href="/astro-project-v2/essays/" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Essays</a>
            </nav>
        </div>
        <div class="font-['Reenie_Beanie'] text-[1.75rem] leading-none text-[#7BA08A] tracking-tight translate-y-1">hyperlynxt | teo</div>
    </header>

    <!-- ─────────────── HERO ─────────────── -->
    <section class="w-full pt-20 pb-16 px-6">
        <div class="max-w-4xl mx-auto text-center">
            <span class="font-['Reenie_Beanie'] text-2xl text-[#8C8070] mb-2 block">thoughts mid-formation</span>
            <h2 class="font-serif text-5xl md:text-7xl leading-tight text-[#2A2724] mb-8">
                Raw
                <span class="italic hand-underline-sm inline-block">
                    Notes
                    <svg class="absolute w-[110%] h-[12px] -bottom-1 -left-[5%] text-[#7BA08A] opacity-80 overflow-visible" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                        <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path animate-draw-line"></path>
                    </svg>
                </span>
            </h2>
            <p class="font-serif italic text-lg md:text-xl text-[#8C8070] max-w-2xl mx-auto leading-relaxed">
                Drafts, half-arguments, questions without answers. The working material before it becomes something else.
            </p>
        </div>
    </section>

    <!-- ─────────────── TOOLBAR ─────────────── -->
    <div class="max-w-[1400px] mx-auto px-6 md:px-10 mb-6 flex items-center justify-between pb-3" style="border-bottom: 1px solid rgba(42,39,35,0.08);">
        <span class="font-sans text-[10px] font-bold uppercase tracking-[0.14em] text-[#2A2724]/40">The Draft Pile</span>
        <span id="count-label" class="font-serif italic text-[#2A2724]/35 text-sm">{notes.length} notes</span>
    </div>

    <!-- Data for JS -->
    <script id="notes-data" type="application/json" is:inline set:html={JSON.stringify(notes.map(n => ({
            id: n.id,
            ...n.data,
            date: n.data.date.toISOString()
        })))} />

    <!-- ─────────────── GRID ─────────────── -->
    <main class="max-w-[1400px] mx-auto px-6 md:px-10 pb-36">
        <div class="notes-grid" id="notes-grid">
            {notes.map((entry) => {
                const statusClass =
                    entry.data.status === 'Raw'      ? 'card-status-raw'  :
                    entry.data.status === 'Refine'   ? 'card-status-refine' :
                    'card-status-meta';

                const dotsHtml = [1,2,3].map(i =>
                    `<span class="dot${i <= (entry.data.rating||0) ? ' filled' : ''}"></span>`
                ).join('');



                return (
                    <article
                        class="note-card"
                        data-id={entry.id}
                        data-title={entry.data.title}
                        data-body={entry.data.body || ''}
                        data-rating={entry.data.rating || 0}
                        data-date={entry.data.date}
                        data-status={entry.data.status || ''}
                        data-notetype={entry.data.note_type || ''}
                        data-discipline={entry.data.primary_discipline || ''}
                        data-subdiscipline={entry.data.sub_discipline || ''}
                        data-lens={entry.data.analytical_lens || ''}
                        data-concepts={Array.isArray(entry.data.concepts_used) ? entry.data.concepts_used.join('||') : (entry.data.concepts_used || '')}
                        data-tags={(entry.data.tags || []).join(',')}
                    >
                        <!-- expand hint -->
                        <span class="card-expand">↗</span>

                        <!-- Draft icon -->
                        <div class="card-draft-icon">
                            <!-- Lucide pocket-knife icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-feather"><path d="M12.67 19a2 2 0 0 0 1.416-.588l6.154-6.172a6 6 0 0 0-8.49-8.49L5.586 9.914A2 2 0 0 0 5 11.328V18a1 1 0 0 0 1 1z"/><path d="M16 8 2 22"/><path d="M17.5 15H9"/></svg>
                        </div>

                        <!-- Title -->
                        <h3 class="card-title">{entry.data.title}</h3>


                        <!-- Footer -->
                        <div class="card-footer">
                            <div class="flex flex-wrap gap-1.5 items-center">
                                <span class={`card-tag ${statusClass}`}>{entry.data.status || 'Raw'}</span>
                                {entry.data.note_type && (
                                    <span class="card-tag-neutral">{entry.data.note_type}</span>
                                )}
                            </div>

                        </div>
                    </article>
                );
            })}
        </div>
    </main>

    <!-- ─────────────── BOTTOM BAR ─────────────── -->
    <div id="bottom-bar" class="fixed bottom-10 left-0 right-0 flex justify-center pointer-events-none z-50">
        <div class="bg-white/80 backdrop-blur-xl border border-[#E8E2D2] rounded-[24px] shadow-[0_20px_50px_rgba(42,39,36,0.15)] p-2.5 flex items-center pointer-events-auto">
            <div class="flex items-center gap-3 pl-4 pr-3 py-2 group cursor-text" onclick="const input = document.getElementById('notes-search'); if(input) input.focus()">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#A39985] group-hover:text-[#7BA08A] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <input type="text" id="notes-search" placeholder="Search notes" class="bg-transparent border-none outline-none font-sans text-xs font-bold text-[#2A2724] placeholder:text-[#A39985] w-32 transition-all focus:w-48">
            </div>
            <div class="w-px h-6 bg-[#E8E2D2] mx-1"></div>
            <button id="open-filter-btn" class="bg-[#7BA08A] hover:bg-[#6f917c] text-white rounded-xl px-5 py-2.5 text-[11px] uppercase tracking-widest font-sans font-bold transition-colors shadow-sm">Filter & Sort</button>
        </div>
    </div>

    <NoteModal />

    <!-- ─────────────── FILTER MODAL ─────────────── -->
    <div id="filter-modal" class="fixed inset-0 z-[60] items-center justify-center p-6" style="display:none; background: rgba(245,242,235,0.45); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
        <div class="relative z-20 w-full max-w-[620px] bg-white rounded-[28px] shadow-2xl border border-white/60 overflow-hidden flex flex-col max-h-[85vh] ink-stain">
            <!-- Header -->
            <div class="px-7 pt-9 pb-6 border-b border-[#9dbbaa]/15 flex flex-col items-center justify-center bg-white/50 backdrop-blur-md flex-shrink-0 relative">
                <div class="text-center w-full">
                    <h2 class="text-3xl md:text-4xl font-serif font-medium text-[#2A2724] relative inline-block">
                        Filter & Sort
                        <svg class="absolute w-[110%] h-[15px] -bottom-2 -left-[5%] text-[#7BA08A] opacity-80 overflow-visible" viewBox="0 0 100 10" fill="none" preserveAspectRatio="none">
                            <path d="M0 7 Q12.5 10 25 6 T50 7 T75 6 T100 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="swoosh-path animate-draw-line"/>
                        </svg>
                    </h2>
                </div>
                <button id="close-filter-btn" class="absolute top-7 right-7 w-8 h-8 rounded-full bg-[#FDFCF9] border border-[#D5CCB6]/20 flex items-center justify-center text-[#2A2724]/50 hover:text-[#7BA08A] hover:bg-[#F1F8F4] transition-all group">
                    <svg class="w-4 h-4 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <div class="px-7 py-6 overflow-y-auto modal-scrollbar flex-grow space-y-7">

                <!-- Sort -->
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Sort By</h3>
                        </div>
                        <button id="sort-direction-toggle" class="flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-[#FDFCF9] border border-[#D5CCB6]/20 text-[10px] font-bold uppercase tracking-wider text-[#2A2724]/60 hover:text-[#7BA08A] transition-all">
                            <span id="sort-direction-label">Descending</span>
                            <svg id="sort-direction-icon" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M7 15l5 5 5-5M7 9l5-5 5 5"/></svg>
                        </button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button data-sort="default" class="sort-btn px-4 py-2 bg-[#7BA08A] text-white font-sans text-sm font-medium rounded-full shadow-lg border border-[#7BA08A] transition-all">Default</button>
                        <button data-sort="alphabetical" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:border-[#9dbbaa] transition-all shadow-sm">Alphabetical</button>
                        <button data-sort="rating" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:border-[#9dbbaa] transition-all shadow-sm">Rating</button>
                        <button data-sort="date" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:border-[#9dbbaa] transition-all shadow-sm">Date</button>
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#A1C2AE]/30 to-transparent"></div>

                <!-- Min Rating -->
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Minimum Rating</h3>
                        </div>
                        <span id="min-rating-label" class="font-['Reenie_Beanie'] text-lg text-[#7BA08A]">0+ dots</span>
                    </div>
                    <div class="flex gap-4 p-3.5 bg-white border border-[#9dbbaa]/20 rounded-2xl w-fit" id="filter-rating-dots">
                        <button data-rating="0" class="star-filter active active:scale-95">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="8" fill="currentColor" fill-opacity="0.6"></circle>
                            </svg>
                        </button>
                        <button data-rating="1" class="star-filter active:scale-95">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="8" fill="currentColor" fill-opacity="0.6"></circle>
                            </svg>
                        </button>
                        <button data-rating="2" class="star-filter active:scale-95">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="8" fill="currentColor" fill-opacity="0.6"></circle>
                            </svg>
                        </button>
                        <button data-rating="3" class="star-filter active:scale-95">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="8" fill="currentColor" fill-opacity="0.6"></circle>
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#A1C2AE]/30 to-transparent"></div>

                <!-- Status filter -->
                <div>
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Status</h3>
                    </div>
                    <div class="flex flex-wrap gap-2" id="filter-status-container">
                        {['Raw','Refine','Metastasis / Converted'].map(s => (
                            <button data-status={s} class="status-filter-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:border-[#A1C2AE] transition-all shadow-sm">{s}</button>
                        ))}
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#A1C2AE]/30 to-transparent"></div>

                <!-- Note type filter -->
                <div>
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                        <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Note Type</h3>
                    </div>
                    <div class="flex flex-wrap gap-2" id="filter-type-container">
                        {['Question','Observation','Synthesis','Analysis','Argument','Interpersonal'].map(t => (
                            <button data-notetype={t} class="type-filter-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:border-[#A1C2AE] transition-all shadow-sm">{t}</button>
                        ))}
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#A1C2AE]/30 to-transparent"></div>

                <!-- Discipline filter -->
                <div>
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                        <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Discipline</h3>
                    </div>
                    <div class="flex flex-wrap gap-2" id="filter-discipline-container">
                        {['Sociology','Psychology','Linguistics','Cognitive Science'].map(d => (
                            <button data-discipline={d} class="discipline-filter-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#D5CCB6]/30 hover:border-[#A1C2AE] transition-all shadow-sm">{d}</button>
                        ))}
                    </div>
                </div>

                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#A1C2AE]/30 to-transparent"></div>

                <!-- Tags -->
                <div class="pb-4">
                    <div class="flex items-center gap-2 mb-3">
                        <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
                        <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Tags</h3>
                    </div>
                    <div id="filter-tags-container" class="flex flex-wrap gap-2"></div>
                </div>
            </div>

            <!-- Footer actions -->
            <div class="px-7 pb-6 pt-4 border-t border-[#A1C2AE]/10 flex items-center justify-between bg-white/60 flex-shrink-0">
                <div class="flex items-center gap-2 text-sm font-sans text-[#2A2724]/50">
                    <span id="filter-result-count" class="font-medium text-[#7BA08A]">{notes.length} notes</span>
                    <span>match</span>
                </div>
                <div class="flex items-center gap-3">
                    <button id="clear-filters-btn" class="font-['Reenie_Beanie'] text-[1.4rem] font-medium text-[#7BA08A] hover:bg-[#7BA08A]/10 px-4 py-1.5 rounded-lg transition-all underline underline-offset-4">Clear Filters</button>
                    <button id="apply-filters-btn" class="px-6 py-2 rounded-full text-sm font-sans font-medium text-white transition-all hover:-translate-y-[1px] shadow-lg hover:bg-[#6f917c]" style="background: #7BA08A;">Apply Filters</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ─────────────── SCRIPTS ─────────────── -->
    <script>
        // Data
        const notesJSON = JSON.parse(document.getElementById('notes-data').textContent);
        const notesGrid = document.getElementById('notes-grid');
        const cards     = document.querySelectorAll('.note-card');
        const bottomBar = document.getElementById('bottom-bar');
        const filterModal = document.getElementById('filter-modal');
        const noteModal = document.getElementById('note-modal');

        let filterState = {
            query: '',
            sort: 'default',
            sortOrder: 'desc',
            minRating: 0,
            statuses: [],
            noteTypes: [],
            disciplines: [],
            tags: []
        };

        const toggleBottomBar = (show) => {
            if (show) bottomBar.classList.remove('hidden-bar');
            else      bottomBar.classList.add('hidden-bar');
        };

        // Modal Handlers (Delegated)
        document.addEventListener('click', e => {
            const card = e.target.closest('.note-card');
            if (card) {
                const id = card.dataset.id;
                const d = notesJSON.find(n => n.id === id);
                if (!d) return;

                const bodyHtml = (d.body || '').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                
                if (window.openNoteModal) {
                    window.openNoteModal(id, notesJSON, bodyHtml);
                    toggleBottomBar(false);
                } else {
                    console.warn('openNoteModal not ready, retrying...');
                    setTimeout(() => window.openNoteModal && window.openNoteModal(id, notesJSON, bodyHtml), 100);
                }
            }
        });

        // The shared modal has its own close handlers, but we need to toggle the bottom bar back
        // We'll listen for the note-modal becoming hidden
        const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.type === 'attributes' && mutation.attributeName === 'style') {
                    if (noteModal.style.display === 'none' && filterModal.style.display === 'none') {
                        toggleBottomBar(true);
                    }
                }
            });
        });
        observer.observe(noteModal, { attributes: true });

        // Filter Modal logic (keep existing)
        function openFilterModal() {
            filterModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            toggleBottomBar(false);
            renderTagFilters();
            updatePreviewCount();
        }
        function closeFilterModal() {
            filterModal.style.display = 'none';
            if (noteModal.style.display !== 'flex') {
                document.body.style.overflow = '';
                toggleBottomBar(true);
            }
        }
        document.getElementById('open-filter-btn').addEventListener('click', openFilterModal);
        document.getElementById('close-filter-btn').addEventListener('click', closeFilterModal);
        filterModal.addEventListener('click', e => { if (e.target === filterModal) closeFilterModal(); });
        document.getElementById('apply-filters-btn').addEventListener('click', () => { applyFilters(); closeFilterModal(); });
        document.getElementById('clear-filters-btn').addEventListener('click', clearAllFilters);

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                const propsOpen = document.getElementById('props-overlay').classList.contains('open');
                if (propsOpen) {
                    document.getElementById('props-overlay').classList.remove('open');
                } else if (filterModal.style.display === 'flex') {
                    closeFilterModal();
                } else if (noteModal.style.display === 'flex') {
                    // Handled by shared component's Escape listener
                }
            }
        });

        // ──────── Sort & Filter logic ────────
        document.querySelectorAll('.sort-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                filterState.sort = btn.dataset.sort;
                document.querySelectorAll('.sort-btn').forEach(b => {
                    b.classList.remove('bg-[#7BA08A]','text-white','shadow-lg','border-[#7BA08A]');
                    b.classList.add('bg-white','text-[#2A2724]/70','border-[#D5CCB6]/30');
                });
                btn.classList.add('bg-[#7BA08A]','text-white','shadow-lg','border-[#7BA08A]');
                updatePreviewCount();
            });
        });

        document.getElementById('sort-direction-toggle').addEventListener('click', function () {
            filterState.sortOrder = filterState.sortOrder === 'desc' ? 'asc' : 'desc';
            document.getElementById('sort-direction-label').textContent = filterState.sortOrder === 'desc' ? 'Descending' : 'Ascending';
            document.getElementById('sort-direction-icon').style.transform = filterState.sortOrder === 'asc' ? 'rotate(180deg)' : '';
            updatePreviewCount();
        });

        document.querySelectorAll('#filter-rating-dots .star-filter').forEach(btn => {
            btn.addEventListener('click', () => {
                const rating = parseInt(btn.dataset.rating);
                filterState.minRating = rating;
                document.querySelectorAll('#filter-rating-dots .star-filter').forEach((s, idx) => {
                    s.classList.toggle('active', idx <= rating);
                });
                document.getElementById('min-rating-label').textContent = `${rating}+ dots`;
                updatePreviewCount();
            });
        });

        document.querySelectorAll('.status-filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const s = btn.dataset.status;
                const idx = filterState.statuses.indexOf(s);
                if (idx === -1) { filterState.statuses.push(s); btn.classList.add('bg-[#7BA08A]','text-white'); btn.classList.remove('bg-white','text-[#2A2724]/70'); }
                else            { filterState.statuses.splice(idx,1); btn.classList.remove('bg-[#7BA08A]','text-white'); btn.classList.add('bg-white','text-[#2A2724]/70'); }
                updatePreviewCount();
            });
        });

        document.querySelectorAll('.type-filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const t = btn.dataset.notetype;
                const idx = filterState.noteTypes.indexOf(t);
                if (idx === -1) { filterState.noteTypes.push(t); btn.classList.add('bg-[#7BA08A]','text-white'); btn.classList.remove('bg-white','text-[#2A2724]/70'); }
                else            { filterState.noteTypes.splice(idx,1); btn.classList.remove('bg-[#7BA08A]','text-white'); btn.classList.add('bg-white','text-[#2A2724]/70'); }
                updatePreviewCount();
            });
        });

        document.querySelectorAll('.discipline-filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const d = btn.dataset.discipline;
                const idx = filterState.disciplines.indexOf(d);
                if (idx === -1) { filterState.disciplines.push(d); btn.classList.add('bg-[#7BA08A]','text-white'); btn.classList.remove('bg-white','text-[#2A2724]/70'); }
                else            { filterState.disciplines.splice(idx,1); btn.classList.remove('bg-[#7BA08A]','text-white'); btn.classList.add('bg-white','text-[#2A2724]/70'); }
                updatePreviewCount();
            });
        });

        // ── Tag filters (dynamic) ──
        function renderTagFilters() {
            const container = document.getElementById('filter-tags-container');
            const allTags   = new Set();
            cards.forEach(c => (c.dataset.tags || '').split(',').filter(Boolean).forEach(t => allTags.add(t.trim())));
            container.innerHTML = '';
            allTags.forEach(tag => {
                const btn = document.createElement('button');
                btn.textContent = tag;
                btn.dataset.tag = tag;
                const active = filterState.tags.includes(tag);
                btn.className = `tag-dyn-btn px-4 py-2 font-sans text-sm font-medium rounded-full border transition-all shadow-sm ${active ? 'bg-[#7BA08A] text-white border-[#7BA08A]' : 'bg-white text-[#2A2724]/70 border-[#D5CCB6]/30 hover:border-[#A1C2AE]'}`;
                btn.addEventListener('click', () => {
                    const idx = filterState.tags.indexOf(tag);
                    if (idx === -1) { filterState.tags.push(tag); btn.classList.add('bg-[#7BA08A]','text-white','border-[#7BA08A]'); btn.classList.remove('bg-white','text-[#2A2724]/70'); }
                    else            { filterState.tags.splice(idx,1); btn.classList.remove('bg-[#7BA08A]','text-white','border-[#7BA08A]'); btn.classList.add('bg-white','text-[#2A2724]/70'); }
                    updatePreviewCount();
                });
                container.appendChild(btn);
            });
        }

        // ── Match logic ──
        function cardMatches(card) {
            const title      = (card.dataset.title      || '').toLowerCase();
            const body       = (card.dataset.body       || '').toLowerCase();
            const rating     = parseInt(card.dataset.rating) || 0;
            const status     = (card.dataset.status     || '').toLowerCase();
            const noteType   = (card.dataset.notetype   || '').toLowerCase();
            const discipline = (card.dataset.discipline || '').toLowerCase();
            const tags       = (card.dataset.tags       || '').split(',').map(t => t.trim().toLowerCase()).filter(Boolean);

            const q = filterState.query;
            if (q && !title.includes(q) && !body.includes(q)) return false;
            if (rating < filterState.minRating) return false;
            if (filterState.statuses.length   && !filterState.statuses.some(s => status.includes(s.toLowerCase()))) return false;
            if (filterState.noteTypes.length  && !filterState.noteTypes.some(t => noteType.includes(t.toLowerCase()))) return false;
            if (filterState.disciplines.length && !filterState.disciplines.some(d => discipline.includes(d.toLowerCase()))) return false;
            if (filterState.tags.length       && !filterState.tags.some(t => tags.includes(t.toLowerCase()))) return false;
            return true;
        }

        function updatePreviewCount() {
            const count = Array.from(cards).filter(c => cardMatches(c)).length;
            document.getElementById('filter-result-count').textContent = `${count} notes`;
        }

        const originalOrder = Array.from(cards);
        function applyFilters() {
            const arr = Array.from(cards);
            arr.forEach(c => { c.style.display = cardMatches(c) ? '' : 'none'; });
            const visible  = arr.filter(c => c.style.display !== 'none');
            const isDesc   = filterState.sortOrder === 'desc';

            let sortTarget = filterState.sort === 'default'
                ? originalOrder.filter(c => visible.includes(c))
                : visible;

            if (filterState.sort === 'default' && !isDesc) {
                sortTarget = [...sortTarget].reverse();
            }

            if (filterState.sort !== 'default') {
                sortTarget.sort((a, b) => {
                    if (filterState.sort === 'alphabetical') {
                        const cmp = a.dataset.title.localeCompare(b.dataset.title);
                        return isDesc ? -cmp : cmp;
                    }
                    if (filterState.sort === 'rating') {
                        const cmp = parseInt(a.dataset.rating) - parseInt(b.dataset.rating);
                        return isDesc ? -cmp : cmp;
                    }
                    if (filterState.sort === 'date') {
                        const cmp = new Date(a.dataset.date).getTime() - new Date(b.dataset.date).getTime();
                        return isDesc ? -cmp : cmp;
                    }
                    return 0;
                });
            }

            sortTarget.forEach(c => notesGrid.appendChild(c));

            const total = cards.length;
            document.getElementById('count-label').textContent =
                visible.length === total ? `${total} notes` : `${visible.length} of ${total} notes`;
        }

        function clearAllFilters() {
            filterState = { query:'', sort:'default', sortOrder:'desc', minRating:0, statuses:[], noteTypes:[], disciplines:[], tags:[] };
            document.getElementById('notes-search').value = '';
            
            // reset sort order UI
            document.getElementById('sort-direction-label').textContent = 'Descending';
            document.getElementById('sort-direction-icon').style.transform = '';
            // reset sort buttons
            document.querySelectorAll('.sort-btn').forEach((b,i) => {
                b.classList.remove('bg-[#7BA08A]','text-white','shadow-lg','border-[#7BA08A]');
                b.classList.add('bg-white','text-[#2A2724]/70','border-[#D5CCB6]/30');
                if (i === 0) { b.classList.add('bg-[#7BA08A]','text-white','shadow-lg'); b.classList.remove('bg-white','text-[#2A2724]/70'); }
            });
            document.querySelectorAll('#filter-rating-dots .star-filter').forEach((s,i) => s.classList.toggle('active', i === 0));
            document.getElementById('min-rating-label').textContent = '0+ dots';
            document.querySelectorAll('.status-filter-btn,.type-filter-btn,.discipline-filter-btn').forEach(b => {
                b.classList.remove('bg-[#7BA08A]','text-white');
                b.classList.add('bg-white','text-[#2A2724]/70');
            });
            cards.forEach(c => { c.style.display = ''; });
            document.getElementById('count-label').textContent = `${cards.length} notes`;
            renderTagFilters();
            updatePreviewCount();
        }

        // ── Live search ──
        document.getElementById('notes-search').addEventListener('input', e => {
            filterState.query = e.target.value.toLowerCase().trim();
            applyFilters();
        });

        updatePreviewCount();
    </script>
</body>
</html>
