---
import { getCollection, render } from 'astro:content';
import '../styles/global.css';
import ResearchDiveModal from '../components/ResearchDiveModal.astro';

const researchDives = await getCollection('researchDives');
researchDives.sort((a, b) => {
  const ratingA = a.data.rating || 0;
  const ratingB = b.data.rating || 0;
  if (ratingB !== ratingA) return ratingB - ratingA;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const renderedDives = await Promise.all(
  researchDives.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

const accentColor = "#B4BCC0";
const accentColorDark = "#8C8C8C";
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlas Field Notes - Research Dives</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600;700&family=Reenie+Beanie&display=swap" rel="stylesheet">
    <style define:vars={{ accentColor, accentColorDark }}>
        body {
            background-color: #FDFCF9;
            background-image: 
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                url("https://www.transparenttextures.com/patterns/natural-paper.png");
            background-position: 0px 0px, 40px 60px, 80px 20px;
            background-repeat: repeat;
            color: #2A2724;
        }
        .hand-underline-sm { position: relative; display: inline-block; }
        .catalog-card {
            background: white !important;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
        }
        .catalog-card:hover {
            background: #F5F2EB !important;
            border-color: #D5CCB6;
            transform: translateY(-4px);
            box-shadow: 0 12px 24px -10px rgba(42, 39, 36, 0.1);
        }
        .catalog-card:hover .model-title { color: var(--accentColorDark); }
        .bookmark-icon {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            color: #A39985;
            transition: color 0.2s ease;
            z-index: 10;
        }
        .catalog-card:hover .bookmark-icon { color: var(--accentColorDark); }
        .star-rating { display: flex; gap: 4px; color: var(--accentColorDark); }
        .masonry-grid {
            position: relative;
            width: 100%;
            transition: height 0.4s ease;
        }
        .masonry-item-wrapper {
            position: absolute;
            transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.4s ease, width 0.4s ease;
            padding: 0;
            margin: 0;
        }
        .masonry-item { 
            break-inside: avoid; 
            margin-bottom: 1.25rem; 
            display: block; 
            position: relative;
        }
        .glass-nav { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.12); border-radius: 10px; border: 2px solid transparent; background-clip: content-box; }
        ::-webkit-scrollbar-thumb:hover { background-color: rgba(42, 39, 36, 0.25); }
        
        @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }
        .swoosh-path { stroke-dasharray: 100; stroke-dashoffset: 100; }
        .animate-draw-line { animation: drawSwoosh 0.8s ease-out 0.4s forwards; }

        .catalog-card strong {
            color: var(--accentColorDark) !important;
            font-weight: 600 !important;
        }
    </style>
</head>
<body class={`min-h-screen antialiased selection:bg-[${accentColor}] selection:text-white flex flex-col`}>

    <header class="sticky top-0 z-50 w-full h-[80px] bg-[#F5F2EB]/95 glass-nav flex items-center justify-between px-10 shadow-sm" style="border-bottom: 0.5px solid rgba(42, 39, 35, 0.12);">
        <div class="flex items-center gap-10">
            <a href="/astro-project-v2/" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Main Page</a>
            <div class="h-8 w-px bg-[#E8E2D2]"></div>
            <nav class="flex items-center gap-8 translate-y-[2px]">
                <a href="/astro-project-v2/content-notes" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Content Notes</a>
                <a href="/astro-project-v2/research-dives" class="group flex items-center gap-2 transition-all duration-300 hover:-translate-y-[1px]">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#B4BCC0] shadow-[0_0_8px_rgba(180,188,192,0.4)]"></span>
                    <span class="font-serif text-xl text-[#2A2724]">Research Dives</span>
                </a>
            </nav>
        </div>
        <div class="font-['Reenie_Beanie'] text-[1.75rem] leading-none text-seal tracking-tight translate-y-1 text-[#8C8C8C]">hyperlynxt | teo</div>
    </header>

    <main class="flex-1 pb-32">
        <section class="w-full bg-gradient-to-b from-[#F5F2EB] to-transparent pt-20 pb-16 px-6">
            <div class="max-w-4xl mx-auto text-center">
                <span class="font-['Reenie_Beanie'] text-2xl text-[#8C8070] mb-2 block">Part IV</span>
                <h2 class="font-serif text-5xl md:text-7xl leading-tight text-[#2A2724] mb-8">
                    Research <span class="italic hand-underline-sm inline-block">
                        Dives
                        <svg class="absolute w-[110%] h-[12px] -bottom-1 -left-[5%] text-[#B4BCC0] opacity-70 overflow-visible" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                            <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path animate-draw-line"></path>
                        </svg>
                    </span>
                </h2>
                <p class="font-serif italic text-lg md:text-xl text-[#8C8070] max-w-2xl mx-auto leading-relaxed">
                    In-depth exploratory inquiries into specific thematic territories.
                </p>
            </div>
        </section>

        <div class="max-w-7xl mx-auto px-6">
            <div class="masonry-grid">
                {renderedDives.map(({ entry, Content }) => (
                    <div class="masonry-item-wrapper">
                        <article
                            class="masonry-item catalog-card group bg-white rounded-3xl border border-[#E8E2D2] p-8 flex flex-col gap-6 transition-all duration-500 hover:shadow-[0_20px_40px_-15px_rgba(213,204,182,0.5)]"
                            data-title={entry.data.title}
                            data-description={entry.data.description}
                            data-id={entry.id}
                            data-source={entry.data.source || ''}
                            data-tags={entry.data.tags.join(',')}
                            data-rating={entry.data.rating}
                            data-summary={entry.data.summary || ''}
                        >
                            <svg class="bookmark-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                                <path d="M2 17l10 5 10-5"></path>
                                <path d="M2 12l10 5 10-5"></path>
                            </svg>
                            <div class="flex flex-col gap-2">
                                <p class="font-sans text-[10px] font-bold uppercase tracking-widest text-[#B4BCC0] opacity-80">{entry.data.source || 'General Research'}</p>
                                <h3 class="model-title font-serif text-3xl font-medium text-[#2A2724] transition-colors leading-tight">{entry.data.title}</h3>
                                <p class="font-serif text-[#8C8070] text-[16px] leading-relaxed mt-2" set:html={(entry.data.description || '').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}></p>
                            </div>
                            <div class="pt-5 border-t border-[#F5F2EB]/80 mt-auto">
                                <div class="flex items-center justify-between mb-3">
                                    <div class="star-rating">
                                        {Array.from({ length: entry.data.rating || 0 }).map((_, i) => (
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" style={i === 1 ? "transform: rotate(15deg);" : i === 2 ? "transform: rotate(-10deg);" : i === 3 ? "transform: rotate(5deg);" : ""}>
                                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.3"></path>
                                            </svg>
                                        ))}
                                    </div>
                                    <div class="flex items-center gap-1.5 opacity-40 group-hover:opacity-100 transition-opacity">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#B4BCC0]"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="7.5 4.21 12 6.81 16.5 4.21"></polyline><polyline points="7.5 19.79 7.5 14.63 3 12"></polyline><polyline points="21 12 16.5 14.63 16.5 19.79"></polyline><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                                        <span class="font-sans text-[10px] font-bold uppercase tracking-widest text-[#2A2724]">Deep Dive</span>
                                    </div>
                                </div>
                            </div>
                        </article>
                    </div>
                ))}
            </div>
        </div>
    </main>

    <ResearchDiveModal />

    <!-- Data for JS -->
    <script id="dives-data" type="application/json" is:inline set:html={JSON.stringify(researchDives.map(c => ({
            id: c.id,
            ...c.data,
            date: c.data.date?.toISOString()
        })))} />
    <div style="display:none;" aria-hidden="true">
        {renderedDives.map(({ entry, Content }) => (
            <div id={`dive-content-${entry.id}`}><Content /></div>
        ))}
    </div>

    <script is:inline>
        function layoutMasonry() {
            const grid = document.querySelector('.masonry-grid');
            if (!grid) return;
            const items = Array.from(grid.querySelectorAll('.masonry-item-wrapper')).filter(i => i.style.display !== 'none');
            const containerWidth = grid.offsetWidth;
            let cols = 1;
            if (window.innerWidth >= 1024) cols = 3;
            else if (window.innerWidth >= 768) cols = 2;
            const gap = 20;
            const colWidth = (containerWidth - (gap * (cols - 1))) / cols;
            const colHeights = new Array(cols).fill(0);
            items.forEach(item => {
                const minH = Math.min(...colHeights);
                const colIdx = colHeights.indexOf(minH);
                const x = colIdx * (colWidth + gap);
                const y = minH;
                item.style.width = colWidth + 'px';
                item.style.transform = `translate3d(${x}px, ${y}px, 0)`;
                colHeights[colIdx] += item.offsetHeight + gap;
            });
            grid.style.height = Math.max(...colHeights) + 'px';
        }
        window.addEventListener('load', layoutMasonry);
        window.addEventListener('resize', layoutMasonry);
        document.addEventListener('click', e => {
            const card = e.target.closest('.catalog-card');
            if (card) {
                const id = card.getAttribute('data-id');
                const contentEl = document.getElementById(`dive-content-${id}`);
                const bodyHtml = contentEl ? contentEl.innerHTML : '';
                const data = JSON.parse(document.getElementById('dives-data').textContent);
                if (window.openResearchDiveModal) window.openResearchDiveModal(id, data, bodyHtml);
            }
        });
    </script>
</body>
</html>
