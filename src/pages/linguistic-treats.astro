---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const words = await getCollection('linguisticTreats');
words.sort((a, b) => {
  const starsA = a.data.stars || 0;
  const starsB = b.data.stars || 0;
  if (starsB !== starsA) return starsB - starsA;
  return new Date(b.data.date_added).getTime() - new Date(a.data.date_added).getTime();
});
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atlas Field Notes — Linguistic Treats</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@400;500;600;700&family=Reenie+Beanie&display=swap" rel="stylesheet">
    <style>
        body { background-color: #FDFCF9; background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png"); color: #2A2724; }
        .glass-nav { backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); }
        .words-grid { display: grid; grid-template-columns: 1fr; gap: 1.75rem; align-items: start; }
        @media (min-width: 640px)  { .words-grid { grid-template-columns: repeat(2,1fr); } }
        @media (min-width: 1024px) { .words-grid { grid-template-columns: repeat(3,1fr); } }
        .word-card {
            cursor: pointer; background-color: #fff; border-radius: 22px; padding: 2rem 2rem 1.6rem;
            position: relative; overflow: hidden; border: 1px solid rgba(42,39,35,0.10);
            box-shadow: 0 2px 12px rgba(42,39,35,0.06); transition: all 0.3s ease; display: flex; flex-direction: column;
        }
        .word-card:hover { background: #F5F2EB; border-color: #D5CCB6; transform: translateY(-4px); box-shadow: 0 12px 24px -10px rgba(42,39,36,0.1); }
        .word-card:hover .card-word { color: #7BA08A; }
        .word-card:hover .card-definition { color: #7BA08A; }
        .word-card:hover .card-type-icon { color: #7BA08A; }
        .card-expand { position: absolute; top: 1.1rem; right: 1.1rem; opacity: 0; transform: scale(0.85); transition: opacity 0.25s ease, transform 0.25s ease; color: rgba(42,39,35,0.28); font-size: 0.75rem; line-height: 1; }
        .word-card:hover .card-expand { opacity: 1; transform: scale(1); }
        .card-type-icon { color: #7BA08A; margin-bottom: 0.9rem; flex-shrink: 0; transition: color 0.3s ease; display: flex; align-items: baseline; gap: 1px; line-height: 1; }
        .icon-big  { font-family: 'EB Garamond', serif; font-size: 1.55rem; font-weight: 600; line-height: 1; }
        .icon-small{ font-family: 'EB Garamond', serif; font-size: 1.0rem; font-weight: 400; line-height: 1; opacity: 0.6; }
        .card-word { font-family: 'EB Garamond', serif; font-size: 2.1rem; font-weight: 500; line-height: 1.15; color: #2A2724; margin-bottom: 0.5rem; transition: color 0.3s ease; }
        .card-definition { font-family: 'EB Garamond', serif; font-size: 1.05rem; line-height: 1.65; color: rgba(42,39,35,0.50); flex-grow: 1; transition: color 0.3s ease; }
        .card-footer { margin-top: 1.4rem; padding-top: 1rem; border-top: 1px solid rgba(42,39,35,0.06); display: flex; align-items: flex-end; justify-content: space-between; gap: 0.75rem; }
        .card-tag { background: rgba(42,39,35,0.04); color: rgba(42,39,35,0.5); font-family: 'Inter', sans-serif; font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 9px; border-radius: 6px; }
        .star-rating { display: flex; gap: 4px; color: #7BA08A; }
        #modal-overlay { background: rgba(42,39,35,0.38); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); transition: opacity 0.35s ease; }
        @keyframes cardIn    { from { opacity:0; transform: translateY(28px) scale(0.96); } to { opacity:1; transform: translateY(0) scale(1); } }
        @keyframes textReveal{ from { opacity:0; transform: translateY(10px); } to { opacity:1; transform: translateY(0); } }
        @keyframes drawStroke{ to { stroke-dashoffset: 0; } }
        .modal-card      { background-color:#FDFCF9; background-image:url("https://www.transparenttextures.com/patterns/natural-paper.png"); animation: cardIn 0.5s cubic-bezier(0.16,1,0.3,1) forwards; }
        .modal-word-text { opacity:0; animation: textReveal 0.6s cubic-bezier(0.16,1,0.3,1) 0.1s forwards; }
        .modal-reveal    { opacity:0; animation: textReveal 0.5s cubic-bezier(0.16,1,0.3,1) 0.28s forwards; }
        .draw-line path  { stroke-dasharray:600; stroke-dashoffset:600; animation: drawStroke 1.1s cubic-bezier(0.22,1,0.36,1) 0.18s forwards; }
        .sidebar-block { opacity:0; transform:translateY(12px); animation: sidebarIn 0.45s cubic-bezier(0.16,1,0.3,1) forwards; }
        .sidebar-block:nth-child(1){ animation-delay:.20s; }
        .sidebar-block:nth-child(2){ animation-delay:.32s; }
        @keyframes sidebarIn { to { opacity:1; transform:translateY(0); } }
        ::-webkit-scrollbar { width:7px; } ::-webkit-scrollbar-track { background:transparent; }
        ::-webkit-scrollbar-thumb { background-color:rgba(42,39,35,0.1); border-radius:10px; }
        ::-webkit-scrollbar-thumb:hover { background-color:rgba(42,39,35,0.2); }
        .hand-underline-sm { position:relative; display:inline-block; }
        .swoosh-path { stroke-dasharray:100; stroke-dashoffset:100; }
        @keyframes drawSwoosh { to { stroke-dashoffset:0; } }
        .animate-draw-line { animation: drawSwoosh 0.8s ease-out 0.4s forwards; }
        
        /* Star Filter Fixes */
        .star-filter { transition: all 0.25s ease; cursor: pointer; display: flex; align-items: center; justify-content: center; background: none; border: none; padding: 0; }
        .star-filter.active { color: #7BA08A !important; opacity: 1 !important; }
        .star-filter.active svg { color: #7BA08A !important; }
        .star-filter.active svg path { fill: #7BA08A !important; fill-opacity: 0.8 !important; stroke: #7BA08A !important; }
        .star-filter:not(.active) { color: #A39985 !important; opacity: 0.5 !important; }
        .star-filter:not(.active) svg { color: #A39985 !important; }
        .star-filter:not(.active) svg path { fill: #A39985 !important; fill-opacity: 0.15 !important; stroke: #A39985 !important; }
        .star-filter:hover { transform: scale(1.1); }
    </style>
</head>
<body class="min-h-screen">

    <header class="sticky top-0 z-50 w-full h-[80px] bg-[#F5F2EB]/95 glass-nav flex items-center justify-between px-10 shadow-sm" style="border-bottom: 0.5px solid rgba(42,39,35,0.08);">
        <div class="flex items-center gap-10">
            <a href="/astro-project-v2/" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px] hover:opacity-80">Main Page</a>
            <div class="h-8 w-px bg-[#E8E2D2]"></div>
            <nav class="flex items-center gap-8 translate-y-[2px]">
                <a href="/astro-project-v2/quotes" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Quotes</a>
                <a href="/astro-project-v2/linguistic-treats" class="group flex items-center gap-2 transition-all duration-300 hover:-translate-y-[1px]">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#7BA08A] shadow-[0_0_8px_rgba(123,160,138,0.5)]"></span>
                    <span class="font-serif text-xl text-[#2A2724]">Linguistic Treats</span>
                </a>
            </nav>
        </div>
        <div class="font-['Reenie_Beanie'] text-[1.75rem] leading-none text-[#7BA08A] tracking-tight translate-y-1">hyperlynxt | teo</div>
    </header>

    <section class="w-full bg-gradient-to-b from-[#F5F2EB] to-transparent pt-20 pb-16 px-6">
        <div class="max-w-4xl mx-auto text-center">
            <span class="font-['Reenie_Beanie'] text-2xl text-[#8C8070] mb-2 block">words that carry whole worlds</span>
            <h2 class="font-serif text-5xl md:text-7xl leading-tight text-[#2A2724] mb-8">
                Collected <span class="italic hand-underline-sm inline-block">
                    Words
                    <svg class="absolute w-[110%] h-[12px] -bottom-1 -left-[5%] text-[#7BA08A] opacity-80 overflow-visible" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                        <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path animate-draw-line"></path>
                    </svg>
                </span>
            </h2>
            <p class="font-serif italic text-lg md:text-xl text-[#8C8070] max-w-2xl mx-auto leading-relaxed">
                Terms loved not for how they sound, but for what they name — gaps in thought, folds in meaning, semantic sleight of hand.
            </p>
        </div>
    </section>

    <div class="max-w-[1400px] mx-auto px-6 md:px-10 mb-6 flex items-center justify-between pb-3" style="border-bottom: 1px solid rgba(42,39,35,0.08);">
        <span class="font-sans text-[10px] font-bold uppercase tracking-[0.14em] text-[#2A2724]/40">The Lexicon</span>
        <span id="count-label" class="font-serif italic text-[#2A2724]/35 text-sm">{words.length} entries</span>
    </div>

    <main class="max-w-[1400px] mx-auto px-6 md:px-10 pb-36">
        <div class="words-grid" id="words-grid">
            {words.map((entry) => {
                const visibleTags = entry.data.tags.slice(0, 2);
                const overflow = entry.data.tags.length > 2 ? entry.data.tags.length - 2 : 0;
                return (
                    <article
                        class="word-card"
                        data-word={entry.data.word.toLowerCase()}
                        data-tags={entry.data.tags.join(',')}
                        data-stars={entry.data.stars}
                        data-fullword={entry.data.word}
                        data-definition={entry.data.definition}
                        data-note={entry.data.note || ''}
                    >
                        <span class="card-expand">↗</span>
                        <div class="card-type-icon"><span class="icon-big">A</span><span class="icon-small">a</span></div>
                        <div style="flex-grow:1;">
                            <p class="card-word">{entry.data.word}</p>
                            <p class="card-definition" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">{entry.data.definition}</p>
                        </div>
                        <div class="card-footer">
                            <div class="star-rating">
                                {Array.from({ length: entry.data.stars }).map((_, i) => (
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style={i === 1 ? "transform:rotate(15deg)" : i === 2 ? "transform:rotate(-10deg)" : ""}>
                                        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"></path>
                                    </svg>
                                ))}
                            </div>
                            <div class="flex items-center gap-1.5 flex-wrap justify-end flex-shrink-0">
                                {visibleTags.map(t => <span class="card-tag">{t}</span>)}
                                {overflow > 0 && <span class="card-tag">+{overflow}</span>}
                            </div>
                        </div>
                    </article>
                );
            })}
        </div>
    </main>

    <!-- Modal -->
    <div id="modal-overlay" class="fixed inset-0 z-50 items-center justify-center p-6 md:p-10" style="display:none; opacity:0;">
        <div id="modal-card" class="modal-card relative w-full max-w-[650px] rounded-[28px] overflow-hidden flex flex-col border border-[#2A2724]/[0.08] shadow-2xl animate-slide-up" style="max-height:90vh;">
            <button id="close-modal-btn" class="absolute top-4 right-4 z-20 w-7 h-7 rounded-full border border-[#2A2724]/10 bg-white/60 text-[#2A2724]/35 hover:text-[#2A2724]/70 hover:border-[#2A2724]/25 flex items-center justify-center transition-all font-sans text-xs leading-none backdrop-blur-sm">✕</button>
            <div class="flex-1 overflow-y-auto px-10 md:px-14 pt-14 pb-12 relative">
                <div class="flex justify-center mb-6">
                    <div id="modal-stars" class="star-rating px-1"></div>
                </div>
                <div class="modal-word-text mb-2">
                    <h2 class="font-serif text-[3.8rem] md:text-[4.5rem] font-medium leading-none text-[#2A2724]" id="modal-word"></h2>
                </div>
                <svg class="draw-line w-full mt-0.5 mb-6" height="14" viewBox="0 0 480 14" preserveAspectRatio="none" style="overflow:visible;">
                    <path d="M0,10 Q60,14 120,8 T240,10 T360,8 T480,10" fill="none" stroke="#7BA08A" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                <div id="modal-tags-attribution" class="flex flex-wrap items-baseline gap-2 font-serif italic text-[1.25rem] mb-10" style="display:none;">
                    <span style="color:#7BA08A;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.9rem;font-weight:700;font-style:normal;">Tags</span>
                    <span id="modal-tags-list" style="color:#B08D57;opacity:0.7;"></span>
                </div>
                <div id="summary-container" class="modal-definition mb-10">
                    <p id="modal-definition" class="font-serif text-[1.2rem] md:text-[1.4rem] leading-relaxed text-[#2A2724]"></p>
                </div>
                <div id="modal-note-section" class="modal-reveal mb-10" style="display:none;">
                    <div style="color:#7BA08A;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.8rem;font-weight:700;font-style:normal;margin-bottom:0.5rem;font-family:serif;">Notes from Self</div>
                    <span id="modal-note" class="font-['Reenie_Beanie'] text-2xl text-[#2A2724] leading-tight block"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Modal -->
    <div id="filter-modal" style="display:none;" class="fixed inset-0 z-[60] flex items-center justify-center p-6 bg-[#F5F2EB]/40 backdrop-blur-md">
        <div class="relative w-full max-w-[630px] bg-white rounded-[28px] shadow-2xl border border-white/60 overflow-hidden flex flex-col max-h-[85vh]" style="background-image:url('https://www.transparenttextures.com/patterns/natural-paper.png'),linear-gradient(white,white);">
            <div class="px-7 pt-9 pb-6 border-b border-[#2A2724]/10 flex flex-col items-center justify-center bg-white/60 backdrop-blur-md flex-shrink-0 relative">
                <div class="text-center">
                    <h2 class="text-3xl md:text-4xl font-serif font-medium text-[#2A2724] relative inline-block">
                        Filter & Sort
                        <svg class="absolute w-[110%] h-[15px] -bottom-2 -left-[5%] text-[#7BA08A] opacity-80 overflow-visible" viewBox="0 0 100 10" fill="none" preserveAspectRatio="none">
                            <path d="M0 7 Q12.5 10 25 6 T50 7 T75 6 T100 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="swoosh-path animate-draw-line"/>
                        </svg>
                    </h2>
                </div>
                <button id="close-filter-btn" class="absolute top-7 right-7 w-8 h-8 rounded-full bg-[#FDFCF9] border border-[#2A2724]/15 flex items-center justify-center text-[#2A2724]/50 hover:text-[#2A2724] hover:bg-[#F5F2EB] transition-all group">
                    <svg class="w-4 h-4 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="px-7 py-6 overflow-y-auto flex-grow space-y-8" style="max-height:500px;">
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Sort Order</h3>
                        </div>
                        <button id="sort-direction-toggle" class="flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-[#FDFCF9] border border-[#2A2724]/15 text-[10px] font-bold uppercase tracking-wider text-[#2A2724]/60 hover:text-[#7BA08A] transition-all group">
                            <span id="sort-direction-label">Descending</span>
                            <svg id="sort-direction-icon" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M7 15l5 5 5-5M7 9l5-5 5 5"/></svg>
                        </button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button data-sort="default"      class="sort-btn px-4 py-2 bg-[#7BA08A] text-white font-sans text-sm font-medium rounded-full shadow-lg border border-[#7BA08A] transition-all">Default</button>
                        <button data-sort="alphabetical" class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#2A2724]/20 hover:text-[#2A2724] transition-all shadow-sm">Alphabetical</button>
                        <button data-sort="most-stars"   class="sort-btn px-4 py-2 bg-white text-[#2A2724]/70 font-sans text-sm font-medium rounded-full border border-[#2A2724]/20 hover:text-[#2A2724] transition-all shadow-sm">Most Stars</button>
                    </div>
                </div>
                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#2A2724]/15 to-transparent"></div>
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Filter by Field</h3>
                        </div>
                        <button id="toggle-all-tags" class="font-sans text-[10px] font-bold uppercase tracking-wider text-[#7BA08A]/70 hover:text-[#7BA08A] transition-colors">Select All</button>
                    </div>
                    <div id="filter-tags-container" class="flex flex-wrap gap-2"></div>
                </div>
                <div class="w-full h-px bg-gradient-to-r from-transparent via-[#2A2724]/15 to-transparent"></div>
                <div class="pb-4">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-[#7BA08A]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <h3 class="font-sans text-[0.65rem] font-semibold uppercase tracking-widest text-[#2A2724]/50">Minimum Stars</h3>
                        </div>
                        <span class="font-['Reenie_Beanie'] text-lg text-[#7BA08A] hand-label">1+ stars</span>
                    </div>
                    <div class="flex gap-3 p-3.5 bg-[#FDFCF9] border border-[#2A2724]/10 rounded-2xl w-fit shadow-inner" id="filter-utility-stars">
                        <button data-rating="1" class="star-filter active active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"></path>
                            </svg>
                        </button>
                        <button data-rating="2" class="star-filter active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(15deg)">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"></path>
                            </svg>
                        </button>
                        <button data-rating="3" class="star-filter active:scale-95">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(-10deg)">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
            <div class="p-6 border-t border-[#2A2724]/10 bg-[#FDFCF9] flex items-center justify-between flex-shrink-0">
                <button id="clear-filter-btn" class="font-['Reenie_Beanie'] text-[1.4rem] font-medium text-[#7BA08A] hover:bg-[#7BA08A]/10 px-4 py-1.5 rounded-lg transition-all underline underline-offset-4 decoration-current">Clear Filters</button>
                <button id="apply-filter-btn" class="bg-[#7BA08A] hover:bg-[#6a9079] text-white px-6 py-3 rounded-xl font-sans text-sm font-medium transition-all shadow-md hover:-translate-y-0.5 flex items-center gap-2">
                    <span>Apply Filters</span>
                    <span id="filter-result-count" class="font-['Reenie_Beanie'] text-lg text-white/90 pt-0.5">-- words</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Floating bar -->
    <div id="bottom-bar" class="fixed bottom-10 left-0 right-0 mx-auto w-fit bg-white/80 backdrop-blur-xl border border-[#E8E2D2] rounded-[24px] shadow-[0_20px_50px_rgba(42,39,36,0.15)] p-2.5 flex items-center z-40 transition-all duration-300">
        <div class="flex items-center gap-3 pl-4 pr-3 py-2 group cursor-text" onclick="document.getElementById('words-search').focus()">
            <svg class="w-4 h-4 text-[#A39985] group-hover:text-[#2A2724] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input type="text" id="words-search" placeholder="Search words" class="bg-transparent border-none outline-none font-sans text-xs font-bold text-[#2A2724] placeholder:text-[#A39985] w-32 transition-all focus:w-48">
        </div>
        <div class="w-px h-6 bg-[#E8E2D2] mx-1"></div>
        <button id="filter-btn" class="bg-[#7BA08A] hover:bg-[#6a9079] text-white rounded-xl px-5 py-2.5 text-[11px] uppercase tracking-widest font-sans font-bold transition-colors shadow-sm">Filter & Sort</button>
    </div>

    <script is:inline>
        const overlay = document.getElementById('modal-overlay');
        const filterModal = document.getElementById('filter-modal');
        const bottomBar = document.getElementById('bottom-bar');

        function toggleBottomBar(show) {
            if (show) {
                bottomBar.style.opacity = '1';
                bottomBar.style.transform = 'translateY(0)';
                bottomBar.style.pointerEvents = 'auto';
            } else {
                bottomBar.style.opacity = '0';
                bottomBar.style.transform = 'translateY(20px)';
                bottomBar.style.pointerEvents = 'none';
            }
        }
        const cards = document.querySelectorAll('.word-card');
        const wordsGrid = document.getElementById('words-grid');

        document.getElementById('filter-btn').addEventListener('click', openFilterModal);
        document.getElementById('close-filter-btn').addEventListener('click', closeFilterModal);
        document.getElementById('apply-filter-btn').addEventListener('click', applyFilterSystem);
        document.getElementById('clear-filter-btn').addEventListener('click', clearAllFilters);
        document.getElementById('close-modal-btn').addEventListener('click', closeModalDirect);

        const STAR_ROTATIONS = [0, 15, -10];
        function buildStars(count) {
            return Array.from({ length: count }, (_, i) =>
                `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="transform:rotate(${STAR_ROTATIONS[i]||0}deg)">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"/>
                </svg>`
            ).join('');
        }

        function resetAnimation(el) { if(!el) return; el.style.animation='none'; el.offsetHeight; el.style.animation=null; }

        cards.forEach(card => {
            card.addEventListener('click', () => {
                const word = card.getAttribute('data-fullword');
                const definition = card.getAttribute('data-definition');
                const note = card.getAttribute('data-note') || '';
                const stars = parseInt(card.getAttribute('data-stars')) || 0;
                const tags = card.getAttribute('data-tags') ? card.getAttribute('data-tags').split(',') : [];

                document.getElementById('modal-word').textContent = word;
                document.getElementById('modal-definition').textContent = definition;
                const noteSection = document.getElementById('modal-note-section');
                if (note) {
                    document.getElementById('modal-note').textContent = note;
                    noteSection.style.display = 'block';
                } else {
                    noteSection.style.display = 'none';
                }
                document.getElementById('modal-stars').innerHTML = buildStars(stars);
                
                const tagsAttribution = document.getElementById('modal-tags-attribution');
                const tagsList = document.getElementById('modal-tags-list');
                if (tags.length > 0 && tags[0] !== "") {
                    tagsList.textContent = tags.map(t => t.trim()).join(', ');
                    tagsAttribution.style.display = 'flex';
                } else {
                    tagsAttribution.style.display = 'none';
                }

                resetAnimation(document.getElementById('modal-card'));
                overlay.querySelectorAll('.modal-word-text, .modal-reveal').forEach(el => resetAnimation(el));
                resetAnimation(overlay.querySelector('.draw-line path'));

                overlay.style.display = 'flex';
                overlay.style.opacity = '0';
                document.body.style.overflow = 'hidden';
                toggleBottomBar(false);
                requestAnimationFrame(() => { overlay.style.opacity = '1'; });
            });
        });

        function doClose() {
            overlay.style.opacity = '0';
            setTimeout(() => { 
                overlay.style.display = 'none'; 
                if (filterModal.style.display !== 'flex') {
                    document.body.style.overflow = '';
                    toggleBottomBar(true);
                }
            }, 320);
        }
        function closeModalDirect() { doClose(); }
        overlay.addEventListener('click', (e) => { if (e.target === overlay) doClose(); });

        let filterState = { query: '', sort: 'default', sortOrder: 'desc', tags: [], minStars: 1 };

        const allTags = [...new Set(Array.from(cards).flatMap(c =>
            c.getAttribute('data-tags') ? c.getAttribute('data-tags').split(',').map(t => t.trim()) : []
        ))].sort();

        function renderTagFilters() {
            const container = document.getElementById('filter-tags-container');
            container.innerHTML = allTags.map(tag => {
                const active = filterState.tags.includes(tag);
                return `<button data-tag="${tag}" class="tag-filter-btn px-3 py-1 rounded-full text-[10px] font-semibold uppercase tracking-widest transition-all ${active ? 'bg-[#2A4747] text-white shadow-md scale-105' : 'bg-[#F5F2EB] text-[#2A2724]/60 border border-[#2A2724]/10 hover:bg-[#E8E2D2]'}">${tag}</button>`;
            }).join('');
            container.querySelectorAll('.tag-filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const t = btn.dataset.tag;
                    filterState.tags = filterState.tags.includes(t) ? filterState.tags.filter(x => x !== t) : [...filterState.tags, t];
                    renderTagFilters(); updatePreviewCount();
                });
            });
        }
        renderTagFilters();

        document.getElementById('toggle-all-tags').addEventListener('click', function() {
            filterState.tags = filterState.tags.length === allTags.length ? [] : [...allTags];
            renderTagFilters(); updatePreviewCount();
            this.textContent = filterState.tags.length === allTags.length ? 'Clear All' : 'Select All';
        });

        document.querySelectorAll('.sort-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                filterState.sort = btn.dataset.sort;
                document.querySelectorAll('.sort-btn').forEach(b => {
                    b.classList.remove('bg-[#7BA08A]', 'text-white', 'shadow-lg', 'border-[#7BA08A]');
                    b.classList.add('bg-white', 'text-[#2A2724]/70', 'border-[#2A2724]/20');
                });
                btn.classList.remove('bg-white', 'text-[#2A2724]/70', 'border-[#2A2724]/20');
                btn.classList.add('bg-[#7BA08A]', 'text-white', 'shadow-lg', 'border-[#7BA08A]');
                updatePreviewCount();
            });
        });

        document.getElementById('sort-direction-toggle').addEventListener('click', function() {
            filterState.sortOrder = filterState.sortOrder === 'desc' ? 'asc' : 'desc';
            document.getElementById('sort-direction-label').textContent = filterState.sortOrder === 'desc' ? 'Descending' : 'Ascending';
            document.getElementById('sort-direction-icon').style.transform = filterState.sortOrder === 'asc' ? 'rotate(180deg)' : '';
            updatePreviewCount();
        });

        document.querySelectorAll('.star-filter').forEach(btn => {
            btn.addEventListener('click', () => {
                const rating = parseInt(btn.dataset.rating);
                filterState.minStars = rating;
                document.querySelectorAll('.star-filter').forEach(s => {
                    const isActive = parseInt(s.dataset.rating) <= rating;
                    s.classList.toggle('active', isActive);
                });
                const label = document.querySelector('.hand-label');
                if (label) label.textContent = `${rating}+ stars`;
                updatePreviewCount();
            });
        });

        function cardMatchesFilters(card) {
            const word  = card.dataset.word || '';
            const tags  = card.dataset.tags ? card.dataset.tags.split(',').map(t => t.trim()) : [];
            const stars = parseInt(card.dataset.stars) || 0;
            return (!filterState.query || word.includes(filterState.query)) &&
                   (filterState.tags.length === 0 || filterState.tags.some(t => tags.includes(t))) &&
                   (stars >= filterState.minStars);
        }

        function updatePreviewCount() {
            const count = Array.from(cards).filter(c => cardMatchesFilters(c)).length;
            document.getElementById('filter-result-count').textContent = `${count} words`;
        }

        const originalOrder = Array.from(cards);
        function applyFilters() {
            const cardsArr = Array.from(cards);
            cardsArr.forEach(c => { c.style.display = cardMatchesFilters(c) ? '' : 'none'; });
            const visible = cardsArr.filter(c => c.style.display !== 'none');
            const isDesc = filterState.sortOrder === 'desc';
            
            const sortTarget = filterState.sort === 'default' ? originalOrder.filter(c => visible.includes(c)) : visible;
            
            if (filterState.sort !== 'default') {
                sortTarget.sort((a, b) => {
                    if (filterState.sort === 'alphabetical') { const cmp = a.dataset.word.localeCompare(b.dataset.word); return isDesc ? -cmp : cmp; }
                    if (filterState.sort === 'most-stars')   { const cmp = parseInt(a.dataset.stars) - parseInt(b.dataset.stars); return isDesc ? -cmp : cmp; }
                    return 0;
                });
            }
            
            sortTarget.forEach(c => wordsGrid.appendChild(c));
            
            const total = cards.length;
            document.getElementById('count-label').textContent =
                visible.length === total ? `${total} entries` : `${visible.length} of ${total} entries`;
        }

        function openFilterModal() {
            filterModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            toggleBottomBar(false);
            renderTagFilters(); updatePreviewCount();
            const p = filterModal.querySelector('.swoosh-path');
            if (p) { p.style.animation = 'none'; p.offsetHeight; p.style.animation = null; }
        }

        function closeFilterModal() {
            filterModal.style.display = 'none';
            if (overlay.style.display !== 'flex') {
                document.body.style.overflow = '';
                toggleBottomBar(true);
            }
        }

        function applyFilterSystem() { applyFilters(); closeFilterModal(); }

        function clearAllFilters() {
            filterState = { query: '', sort: 'default', sortOrder: 'desc', tags: [], minStars: 1 };
            document.getElementById('words-search').value = '';
            renderTagFilters(); updatePreviewCount();
            document.querySelectorAll('.sort-btn').forEach((b, i) => {
                b.classList.remove('bg-[#7BA08A]', 'text-white', 'shadow-lg', 'border-[#7BA08A]');
                b.classList.add('bg-white', 'text-[#2A2724]/70', 'border-[#2A2724]/20');
                if (i === 0) { b.classList.add('bg-[#7BA08A]', 'text-white', 'shadow-lg'); b.classList.remove('bg-white', 'text-[#2A2724]/70', 'border-[#2A2724]/20'); }
            });
            document.querySelectorAll('.star-filter').forEach(s => {
                const isActive = parseInt(s.dataset.rating) <= 1;
                s.classList.toggle('active', isActive);
            });
            cards.forEach(c => { c.style.display = ''; });
            document.getElementById('count-label').textContent = `${cards.length} entries`;
        }

        document.getElementById('words-search').addEventListener('input', e => {
            filterState.query = e.target.value.toLowerCase().trim();
            applyFilters();
        });

        filterModal.addEventListener('click', (e) => { if (e.target === filterModal) closeFilterModal(); });
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') { doClose(); closeFilterModal(); }
        });

        updatePreviewCount();
    </script>
</body>
</html>