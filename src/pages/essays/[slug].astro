    <!-- Concept Modal -->
    <div id="concept-modal" style="display:none;" class="fixed inset-0 z-[100] bg-[#2A2724]/25 backdrop-blur-[5px] items-center justify-center p-6 md:p-10 animate-fade-in">
        <div class="w-full max-w-[1240px] h-[92vh] bg-white rounded-[40px] shadow-[0_40px_100px_rgba(42,39,36,0.15)] overflow-hidden border border-white/60 animate-modal-enter relative ring-1 ring-[#D5CCB6]/30">
            <div class="h-full flex flex-col relative bg-[#FDFCF9] ink-stain custom-scrollbar-modal overflow-y-auto z-10">
                <div class="absolute top-0 right-0 p-8 flex justify-end z-[60] pointer-events-none">
                    <button id="close-modal-btn" class="w-12 h-12 rounded-full bg-white/80 backdrop-blur-md border border-[#D5CCB6] shadow-sm hover:bg-white flex items-center justify-center text-[#2A2724] transition-all group pointer-events-auto">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 opacity-60 group-hover:opacity-100 group-hover:rotate-90 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>
                <div class="px-10 md:px-20 lg:px-24 pb-32 pt-8 relative animate-content-enter">
                    <div id="modal-concept-bg-letter" class="absolute top-10 right-16 text-[32rem] font-serif font-bold text-[#2A2724]/[0.015] leading-none pointer-events-none select-none -z-10 -rotate-3"></div>
                    <div class="mb-10">
                        <h1 class="font-serif text-5xl md:text-6xl lg:text-[5.5rem] font-medium text-[#2A2724] leading-[1.01] mb-6 tracking-tight relative">
                            <span id="modal-concept-title" class="italic inline"></span>
                            <svg id="modal-title-underline" class="absolute h-[12px] text-[#8B2626] opacity-70 overflow-visible pointer-events-none" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display: none;">
                                <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path"></path>
                            </svg>
                        </h1>
                        <div class="relative">
                            <div id="modal-stars" class="absolute flex flex-col gap-4 items-center text-[#8B2626] -left-5 md:-left-10 lg:-left-12 -translate-x-1/2 top-4 group"></div>
                            <div class="flex flex-col">
                                <div id="modal-ontology-attribution" class="font-serif italic text-[1.25rem] mb-6 flex flex-wrap items-baseline gap-x-8 gap-y-2" style="display:none;">
                                    <div id="modal-discipline-container" class="flex items-baseline gap-2">
                                        <span style="color:#8B2626;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.9rem;font-weight:700;font-style:normal;">Discipline</span>
                                        <span id="modal-discipline-text" style="color:#B08D57;opacity:0.7;font-style:italic;"></span>
                                    </div>
                                    <div id="modal-framework-container" class="flex items-baseline gap-2" style="display:none;">
                                        <span style="color:#8B2626;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.9rem;font-weight:700;font-style:normal;">Parent Framework</span>
                                        <span id="modal-framework-text" style="color:#B08D57;opacity:0.7;font-style:italic;"></span>
                                    </div>
                                </div>
                                <div id="modal-attribution" class="font-serif italic text-[1.35rem] mb-6 flex items-baseline gap-2" style="display:none;">
                                    <span style="color:#8B2626;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.9rem;font-weight:700;font-style:normal;">From the work of</span>
                                    <span id="modal-authors-list" style="color:#B08D57;opacity:0.7;font-style:italic;"></span>
                                </div>
                                <div id="modal-tags-attribution" class="font-serif italic text-[1.25rem] mb-12 flex items-baseline gap-2" style="display:none;">
                                    <span style="color:#8B2626;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.9rem;font-weight:700;font-style:normal;">Tags</span>
                                    <span id="modal-tags-list" style="color:#B08D57;opacity:0.7;font-style:italic;"></span>
                                </div>
                            </div>
                        </div>
                        <div class="font-serif text-[1.25rem] leading-[1.65] text-[#2A2724] pl-6 border-l-[3px] border-[#B08D57]/40 max-w-4xl">
                            <p id="modal-summary"></p>
                        </div>
                    </div>
                    <div id="modal-detailed-desc" class="font-serif text-xl md:text-[1.45rem] leading-[1.85] text-[#2A2724]/85 space-y-8 max-w-[900px] z-10 relative mb-20"></div>
                    <div id="modal-field-note-section" class="mb-12 max-w-[900px]" style="display:none;">
                        <div style="color:#8B2626;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.8rem;font-weight:700;font-style:normal;margin-bottom:0.5rem;">Notes of Myself</div>
                        <p id="modal-field-note" class="font-['Reenie_Beanie'] text-2xl text-[#2A2724]/90"></p>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-[1000px]">
                        <div id="modal-related-section" class="md:col-span-2 bg-white rounded-3xl border border-[#D5CCB6]/40 p-8 shadow-sm" style="display:none;">
                             <h3 class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] text-[#2A2724]/40 mb-5 flex items-center gap-2.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style="color:#8B2626;" fill="none" viewBox="0 0 24 24" stroke="#8B2626" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                                Related Concepts
                             </h3>
                             <div id="modal-related-items" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
                        </div>
                        <div class="bg-white rounded-3xl border border-[#D5CCB6]/40 p-8 shadow-sm">
                             <h3 class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] text-[#2A2724]/40 mb-4 flex items-center gap-2.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style="color:#8B2626;" fill="none" viewBox="0 0 24 24" stroke="#8B2626" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"></path></svg>
                                Origin
                             </h3>
                             <p id="modal-origin" class="font-serif text-[1.1rem] leading-relaxed text-[#2A2724]/70 italic"></p>
                        </div>
                        <div class="bg-white rounded-3xl border border-[#D5CCB6]/40 p-8 shadow-sm">
                             <h3 class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] text-[#2A2724]/40 mb-5 flex items-center gap-2.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style="color:#8B2626;" fill="none" viewBox="0 0 24 24" stroke="#8B2626" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                                Linked Insights
                             </h3>
                             <div class="flex items-baseline gap-4">
                                 <div id="modal-concept-linked" class="text-6xl font-serif text-[#2A2724] tracking-tight"></div>
                                 <div class="text-[12px] font-sans text-[#2A2724]/40 uppercase tracking-widest font-bold leading-tight">Total<br>Times Used</div>
                             </div>
                        </div>
                        <div id="modal-notes-section" class="md:col-span-2 bg-white rounded-3xl border border-[#D5CCB6]/40 p-8 shadow-sm" style="display:none;">
                             <h3 class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] text-[#2A2724]/40 mb-5 flex items-center gap-2.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style="color:#8B2626;" fill="none" viewBox="0 0 24 24" stroke="#8B2626" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                                Notes of Used
                             </h3>
                             <div id="modal-notes-items" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
                        </div>
                    </div>
                </div>
