        </div>
    </div>

    <!-- Hidden Content for Modals -->
    <div style="display:none;" aria-hidden="true">
        {renderedConcepts.map(({ entry, Content }) => (
            <div id={`concept-content-${entry.id}`}>
                <Content />
            </div>
        ))}
        {renderedNotes.map(({ entry, Content }) => (
            <div id={`note-content-${entry.id}`}>
                <Content />
            </div>
        ))}
    </div>

    <script define:vars={{ 
        sections: essay.data.sections || [],
        concepts: renderedConcepts.map(c => ({
            id: c.entry.id,
            title: c.entry.data.title,
            short: c.entry.data.short_description,
            discipline: c.entry.data.discipline,
            authors: (c.entry.data.authors || []).join(', '),
            origin: c.entry.data.origin,
            rating: c.entry.data.rating || 0,
            linked: c.entry.data.linked_notes || 0,
            fieldnote: c.entry.data.field_note || '',
            notesofused: (c.entry.data.notes_of_used || []).join(','),
            related: (c.entry.data.related_concepts || []).join(','),
            tags: (c.entry.data.tags || []).join(', ')
        })),
        notes: renderedNotes.map(n => ({
            id: n.entry.id,
            title: n.entry.data.title,
            date: n.entry.data.date,
            status: n.entry.data.status,
            notetype: n.entry.data.note_type,
            discipline: n.entry.data.primary_discipline,
            subdiscipline: n.entry.data.sub_discipline,
            lens: n.entry.data.analytical_lens,
            concepts: (n.entry.data.concepts_used || []).join('||'),
            tags: (n.entry.data.tags || []).join(',')
        }))
    }}>
        // ──────── Helpers ────────
        function dots(n) {
            let h = '';
            for(let i=1; i<=3; i++) h += `<span class="dot${i <= n ? ' filled' : ''}"></span>`;
            return h;
        }
        function fmtDate(dStr) {
            const d = new Date(dStr);
            return d.toLocaleDateString('en-US', { month:'long', year:'numeric' });
        }

        // ──────── Reading Progress ────────
        window.addEventListener('scroll', () => {
            const scrollTop = window.scrollY;
            const docHeight = document.body.scrollHeight - window.innerHeight;
            const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
            const bar = document.getElementById('read-progress');
            if (bar) bar.style.width = progress + '%';
        });

        // ──────── Dynamic Anchor IDs ────────
        const headings = document.querySelectorAll('.essay-body h2, .essay-body h3');
        headings.forEach(h => {
            const text = h.textContent.replace(/^[IVXLC]+\.\s*/, '').trim();
            const matchedSection = sections.find(s => s.trim() === text);
            if (matchedSection) {
                const id = matchedSection.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
                h.id = id;
            }
        });

        // ──────── Modal Elements ────────
        const noteModal   = document.getElementById('note-modal');
        const conceptModal = document.getElementById('concept-modal');
        const propsOverlay = document.getElementById('props-overlay');

        function openNoteModal(id) {
            const d = notes.find(n => n.id === id);
            if (!d) return;

            document.getElementById('modal-note-title').textContent = d.title;
            document.getElementById('modal-note-bg-letter').textContent = d.title[0].toUpperCase();
            document.getElementById('modal-note-date').textContent = fmtDate(d.date);
            document.getElementById('modal-note-body').innerHTML = document.getElementById(`note-content-${id}`).innerHTML;
            
            document.getElementById('open-props-btn').onclick = () => buildPropsPanel(d);
            
            noteModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function buildPropsPanel(d) {
            const body = document.getElementById('props-body');
            body.innerHTML = '';
            document.getElementById('props-title').textContent = d.title;

            const pipeline = ['Raw', 'Refine', 'Metastasis / Converted'];
            const statusIdx = pipeline.indexOf(d.status);

            const rows = [
                {
                    label: 'Status',
                    html: `<div class="prop-pipeline">
                        ${pipeline.map((step, i) => {
                            const isCurrent = i === statusIdx;
                            const isPast    = i < statusIdx;
                            let dotStyle    = 'background:rgba(42,39,35,0.15);';
                            let labelCls    = 'color:rgba(42,39,35,0.35);';
                            if (isCurrent) {
                                if (d.status==='Raw')    { dotStyle='background:#B06A00;'; labelCls='color:#B06A00;font-weight:500;'; }
                                else if (d.status==='Refine') { dotStyle='background:var(--accent);'; labelCls='color:var(--accent);font-weight:500;'; }
                                else                          { dotStyle='background:#2E7D32;'; labelCls='color:#2E7D32;font-weight:500;'; }
                            } else if (isPast) {
                                dotStyle='background:var(--accent-light);';
                            }
                            return `<div class="prop-pipeline-step">
                                <span class="prop-pipeline-dot" style="${dotStyle}"></span>
                                <span class="prop-pipeline-label" style="${labelCls}">${step}</span>
                            </div>`;
                        }).join('')}
                    </div>`,
                    span2: true
                },
                { label: 'Rating',   html: `<div class="dot-rating">${dots(parseInt(d.rating)||0)}</div>` },
                { label: 'Date',     html: `<span class="prop-value handwriting">${fmtDate(d.date)}</span>` },
                { label: 'Note Type', html: d.notetype ? `<span class="prop-chip prop-chip-neutral">${d.notetype}</span>` : '<span class="prop-value">—</span>' },
                { label: 'Analytical Lens', html: d.lens ? `<span class="prop-value italic-accent">${d.lens}</span>` : '<span class="prop-value">—</span>' },
                { label: 'Discipline', html: d.discipline ? `<span class="prop-value">${d.discipline}</span>` : '<span class="prop-value">—</span>' },
                { label: 'Sub-discipline', html: d.subdiscipline ? `<span class="prop-value">${d.subdiscipline}</span>` : '<span class="prop-value">—</span>' },
                d.tags ? {
                    label: 'Tags',
                    html: `<div class="prop-chips">${d.tags.split(',').map(t=>`<span class="prop-chip prop-chip-neutral">${t.trim()}</span>`).join(' ')}</div>`,
                    full: true
                } : null,
                d.concepts ? {
                    label: 'Concepts Used',
                    html: `<div class="prop-chips">${d.concepts.split('||').map(c=>`<span class="prop-concept-chip">${c.trim()}</span>`).join(' ')}</div>`,
                    full: true
                } : null,
            ].filter(Boolean);

            rows.forEach(row => {
                const div = document.createElement('div');
                div.className = 'prop-row';
                if (row.full) div.classList.add('full-width');
                if (row.span2) div.classList.add('row-span-2');
                div.innerHTML = `<p class="prop-label">${row.label}</p><div>${row.html}</div>`;
                body.appendChild(div);
            });

            propsOverlay.classList.add('open');
        }

        function openConceptModal(id) {
            const d = concepts.find(c => c.id === id);
            if (!d) return;

            const setElTxt = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val || ''; };
            const setElHtml = (id, val) => { const el = document.getElementById(id); if (el) el.innerHTML = val || ''; };
            const toggleSec = (id, show) => { const el = document.getElementById(id); if (el) el.style.display = show ? 'block' : 'none'; };
            const toggleSecFlex = (id, show) => { const el = document.getElementById(id); if (el) el.style.display = show ? 'flex' : 'none'; };

            setElTxt('modal-concept-title', d.title);
            setElTxt('modal-concept-bg-letter', d.title[0].toUpperCase());
            setElTxt('modal-summary', d.short);
            setElHtml('modal-detailed-desc', document.getElementById(`concept-content-${id}`).innerHTML);
            setElTxt('modal-origin', d.origin);
            setElTxt('modal-concept-linked', d.linked);

            // Discipline & Framework
            let displayDiscipline = d.discipline;
            let displayFramework = '';
            if (d.discipline && d.discipline.includes('/')) {
                const parts = d.discipline.split('/');
                displayDiscipline = parts[0].trim();
                displayFramework = parts[1].trim();
            }

            toggleSec('modal-ontology-attribution', false);
            toggleSec('modal-discipline-container', false);
            toggleSec('modal-framework-container', false);

            if (displayDiscipline || displayFramework) {
                toggleSecFlex('modal-ontology-attribution', true);
                if (displayDiscipline) {
                    setElTxt('modal-discipline-text', displayDiscipline);
                    toggleSecFlex('modal-discipline-container', true);
                }
                if (displayFramework) {
                    setElTxt('modal-framework-text', displayFramework);
                    toggleSecFlex('modal-framework-container', true);
                }
            }

            if (d.authors) {
                setElTxt('modal-authors-list', d.authors);
                toggleSecFlex('modal-attribution', true);
            } else toggleSecFlex('modal-attribution', false);

            if (d.tags) {
                setElTxt('modal-tags-list', d.tags);
                toggleSecFlex('modal-tags-attribution', true);
            } else toggleSecFlex('modal-tags-attribution', false);

            // Stars
            const rotations = ['', 'transform: rotate(15deg);', 'transform: rotate(-10deg);', 'transform: rotate(5deg);', 'transform: rotate(-15deg);'];
            const starsHtml = Array.from({length: d.rating}).map((_, i) =>
                `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="${rotations[i] || ''}">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"></path>
                </svg>`
            ).join('');
            setElHtml('modal-stars', starsHtml);

            if (d.fieldnote) { setElTxt('modal-field-note', d.fieldnote); toggleSec('modal-field-note-section', true); }
            else toggleSec('modal-field-note-section', false);

            if (d.notesofused) {
                const items = d.notesofused.split(',').filter(n => n.trim());
                setElHtml('modal-notes-items', items.map(name => `
                    <div class="group p-3.5 bg-[#FDFCF9]/50 border border-[#D5CCB6]/40 rounded-xl flex items-center justify-between cursor-pointer hover:bg-[#FDFCF9] hover:border-[#7C6B9E]/40 hover:shadow-sm transition-all">
                        <p class="font-serif text-[17px] text-[#2A2724] group-hover:text-[#7C6B9E] font-medium transition-colors">${name.trim()}</p>
                    </div>`).join(''));
                toggleSec('modal-notes-section', true);
            } else toggleSec('modal-notes-section', false);

            if (d.related) {
                const items = d.related.split(',').filter(r => r.trim());
                setElHtml('modal-related-items', items.map(name => `
                    <div class="group p-3.5 bg-[#FDFCF9]/50 border border-[#D5CCB6]/40 rounded-xl flex items-center justify-between cursor-pointer hover:bg-[#FDFCF9] hover:border-[#B08D57]/40 hover:shadow-sm transition-all">
                        <p class="font-serif text-[17px] text-[#2A2724] group-hover:text-[#B08D57] font-medium transition-colors">${name.trim()}</p>
                    </div>`).join(''));
                toggleSec('modal-related-section', true);
            } else toggleSec('modal-related-section', false);

            // Underline animation
            const titleEl = document.getElementById('modal-concept-title');
            const underline = document.getElementById('modal-title-underline');
            requestAnimationFrame(() => {
                const rects = titleEl.getClientRects();
                const containerRect = titleEl.parentElement.getBoundingClientRect();
                if (rects.length > 0) {
                    const firstRect = rects[0];
                    underline.style.width = (firstRect.width * 1.05) + 'px';
                    underline.style.top = (firstRect.bottom - containerRect.top - (firstRect.height * 0.12)) + 'px';
                    underline.style.left = (firstRect.left - containerRect.left - (firstRect.width * 0.025)) + 'px';
                    underline.style.display = 'block';
                    const path = underline.querySelector('path');
                    path.style.animation = 'none'; void path.offsetWidth;
                    path.style.animation = 'drawSwoosh 0.8s ease-out 0.4s forwards';
                }
            });

            conceptModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        // ──────── Listeners ────────
        document.querySelectorAll('.open-note-btn').forEach(btn => btn.onclick = () => openNoteModal(btn.dataset.id));
        document.querySelectorAll('.open-concept-btn').forEach(btn => btn.onclick = () => openConceptModal(btn.dataset.id));

        const hideModals = () => {
            noteModal.style.display = 'none';
            conceptModal.style.display = 'none';
            propsOverlay.classList.remove('open');
            document.body.style.overflow = '';
        };

        document.getElementById('close-note-modal').onclick = hideModals;
        document.getElementById('close-modal-btn').onclick = hideModals;
        document.getElementById('close-props-btn').onclick = () => propsOverlay.classList.remove('open');

        [noteModal, conceptModal].forEach(m => m.onclick = (e) => { if(e.target === m) hideModals(); });
        propsOverlay.onclick = (e) => { if(e.target === propsOverlay) propsOverlay.classList.remove('open'); };

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                if (propsOverlay.classList.contains('open')) propsOverlay.classList.remove('open');
                else hideModals();
            }
        });
    </script>
</body>
</html>
