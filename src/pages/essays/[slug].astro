---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(essay => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content: EssayContent } = await render(essay);

// Fetch all collections to find matches
const allConcepts = await getCollection('concepts');
const allNotes = await getCollection('notes');

// Find actual entries based on metadata strings
const linkedConcepts = (essay.data.concepts_used || [])
    .map(name => {
        const found = allConcepts.find(c => c.data.title.toLowerCase() === name.toLowerCase());
        return found ? { entry: found } : null;
    })
    .filter(Boolean);

const linkedNotes = (essay.data.notes_used || [])
    .map(name => {
        const found = allNotes.find(n => n.data.title.toLowerCase() === name.toLowerCase());
        return found ? { entry: found } : null;
    })
    .filter(Boolean);

// Pre-render content for modals
const renderedConcepts = await Promise.all(linkedConcepts.map(async (c) => {
    const { Content } = await render(c.entry);
    return { ...c, Content };
}));

const renderedNotes = await Promise.all(linkedNotes.map(async (n) => {
    const { Content } = await render(n.entry);
    return { ...n, Content };
}));
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Archive — Essay #{essay.data.essay_number.toString().padStart(3, '0')}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;700&family=Reenie+Beanie&display=swap" rel="stylesheet">
    <style>
        :root {
            --muted: #8E8981;
            --green-accent: #a8c5a0;
            --teal: #4A6B62;
            --accent: #7BA08A;
        }

        body {
            background-color: #FDFCF9;
            background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
            color: #1a1a1a;
        }

        .nav-frosted {
            background-color: rgba(245, 242, 235, 0.95);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        .status-badge {
            font-family: 'Inter', sans-serif;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            border: 1px solid;
            border-radius: 999px;
            padding: 4px 12px;
        }

        .status-published { background: #F0F7F4; border-color: #a8c5a0; color: #4A6B62; }
        .status-draft      { background: #FFF8F0; border-color: #E8C99A; color: #A07040; }
        .status-openloop   { background: #F0F7F4; border-color: #a8c5a0; color: #4A6B62; }
        .status-closed     { background: #F4F4F4; border-color: #C8C4BE; color: #6a6560; }

        .argument-block {
            border-left: 3px solid var(--green-accent);
            background: linear-gradient(to right, rgba(168,197,160,0.07), transparent);
        }

        .sidebar-card {
            background: #fff;
            border: 1px solid #E6DFD1;
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 24px;
        }

        .sidebar-card-header {
            padding: 10px 16px;
            background: rgba(245,242,235,0.6);
            border-bottom: 1px solid #E6DFD1;
        }

        .sidebar-label {
            font-family: 'Inter', sans-serif;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #8E8981;
        }

        .lens-pill {
            font-family: 'Inter', sans-serif;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            background: rgba(74,107,98,0.08);
            border: 1px solid rgba(74,107,98,0.25);
            color: #4A6B62;
            border-radius: 999px;
            padding: 3px 10px;
            display: inline-block;
        }

        .hover-underline:hover { text-decoration: underline; text-decoration-color: #4A6B62; text-underline-offset: 4px; }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-up { animation: fadeUp 0.5s cubic-bezier(0.22,1,0.36,1) both; }

        #read-progress {
            position: fixed;
            top: 80px;
            left: 0;
            height: 2px;
            width: 0%;
            background: linear-gradient(to right, #a8c5a0, #4A6B62);
            z-index: 49;
            transition: width 0.1s linear;
        }
    </style>

    <style is:global>
        /* ── Concept Modal Styles (from concepts.astro) ── */
        .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideUpScale { from { opacity: 0; transform: translateY(40px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
        @keyframes slideInRight { from { opacity: 0; transform: translateX(-40px); } to { opacity: 1; transform: translateX(0); } }
        .animate-modal-enter { opacity: 0; animation: slideUpScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s forwards; }
        .animate-content-enter { opacity: 0; animation: slideInRight 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) 0.15s forwards; }
        
        .ink-stain {
            background-color: #FDFCF9;
            background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png"), url("https://www.transparenttextures.com/patterns/natural-paper.png"), radial-gradient(circle at 10% 90%, rgba(42,39,36,0.03) 0%, rgba(253,252,249,0) 60%);
            background-position: 0px 0px, 40px 60px, 0 0;
            background-repeat: repeat, repeat, no-repeat;
        }
        .swoosh-path { stroke-dasharray: 100; stroke-dashoffset: 100; }
        @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }

        #concept-modal .modal-scrollbar::-webkit-scrollbar { width: 4px; }
        #concept-modal .modal-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.15); border-radius: 10px; }

        /* ── Note Modal Styles (from notes.astro) ── */
        :root {
            --accent: #7BA08A;
            --accent-light: #A1C2AE;
            --accent-dark: #4A6B62;
            --accent-pale: #F1F8F4;
            --paper: #FDFCF9;
            --ink: #2A2724;
        }

        #note-modal {
            position: fixed; inset: 0; z-index: 100;
            display: none;
            align-items: center; justify-content: center;
            padding: 2rem;
            background: rgba(42,39,35,0.32);
            backdrop-filter: blur(9px);
            -webkit-backdrop-filter: blur(9px);
        }

        .note-modal-inner {
            width: 100%; max-width: 760px;
            max-height: 90vh;
            background-color: var(--paper, #FDFCF9);
            background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png"),
                radial-gradient(circle at 10% 90%, rgba(123,160,138,0.04) 0%, transparent 60%);
            background-position: 0 0, 0 0;
            background-repeat: repeat, no-repeat;
            border-radius: 36px;
            border: 1px solid rgba(255,255,255,0.6);
            box-shadow: 0 40px 100px rgba(123,160,138,0.18);
            overflow: hidden;
            position: relative;
            display: flex;
            flex-direction: column;
        }

        .note-modal-scroll {
            overflow-y: auto;
            flex: 1;
            padding: 3rem 3.5rem 2.5rem;
        }
        .note-modal-scroll > * { position: relative; z-index: 1; }

        .modal-close {
            position: absolute; top: 1.4rem; right: 1.4rem; z-index: 10;
            width: 38px; height: 38px; border-radius: 50%;
            background: rgba(255,255,255,0.85);
            border: 1px solid rgba(42,39,35,0.12);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: rgba(42,39,35,0.45);
            transition: all 0.2s;
        }
        .modal-close:hover { background: var(--accent-pale); color: var(--accent); border-color: var(--accent-light); }
        .modal-close svg { transition: transform 0.3s; }
        .modal-close:hover svg { transform: rotate(90deg); }

        .modal-bg-letter {
            position: absolute; top: 1rem; right: 2rem;
            font-family: 'EB Garamond', serif;
            font-size: 20rem; font-weight: 700;
            color: rgba(42,39,35,0.018);
            line-height: 1; pointer-events: none; user-select: none;
            z-index: 0;
        }

        .modal-title-block { margin-bottom: 2rem; }
        .modal-title {
            font-family: 'EB Garamond', serif;
            font-size: 3rem; font-weight: 500;
            line-height: 1.1; color: var(--ink, #2A2724);
        }

        .modal-divider {
            width: 100%; height: 1px;
            background: linear-gradient(90deg, rgba(161,194,174,0.4), rgba(161,194,174,0.1), transparent);
            margin-bottom: 2rem;
        }

        .modal-body-prose {
            font-family: 'EB Garamond', serif;
            font-size: 1.2rem; line-height: 1.85;
            color: rgba(42,39,35,0.82);
            margin-bottom: 2.5rem;
        }
        .modal-body-prose strong, .modal-body-prose b {
            color: var(--accent);
            font-weight: 600;
        }

        .modal-footer-bar {
            padding: 1rem 2.5rem 1.5rem;
            border-top: 1px solid rgba(123,160,138,0.10);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(253,252,249,0.8);
            backdrop-filter: blur(8px);
            flex-shrink: 0;
        }

        .properties-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-family: 'Inter', sans-serif;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(42,39,35,0.45);
            background: transparent;
            border: 1.5px solid rgba(42,39,35,0.12);
            border-radius: 100px;
            padding: 7px 16px;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .properties-btn:hover {
            color: var(--accent);
            border-color: var(--accent-light);
            background: var(--accent-pale);
        }

        #props-overlay {
            position: absolute;
            inset: 0;
            z-index: 120;
            display: flex;
            align-items: flex-end;
            justify-content: stretch;
            background: rgba(42,39,35,0.18);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            border-radius: 36px;
            overflow: hidden;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease;
        }
        #props-overlay.open { opacity: 1; pointer-events: all; }

        .props-panel {
            width: 100%;
            background-color: var(--paper, #FDFCF9);
            background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
            border-radius: 28px 28px 36px 36px;
            border-top: 1px solid rgba(123,160,138,0.18);
            box-shadow: 0 -12px 48px rgba(42,39,35,0.14);
            transform: translateY(100%);
            transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
            max-height: 82%;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        #props-overlay.open .props-panel { transform: translateY(0); }

        .props-band {
            height: 4px;
            background: linear-gradient(90deg, var(--accent-light), var(--accent), var(--accent-light));
            opacity: 0.55;
            border-radius: 28px 28px 0 0;
            flex-shrink: 0;
        }

        .props-header {
            padding: 0.6rem 1.8rem 1.1rem;
            display: flex; align-items: center; justify-content: space-between;
            flex-shrink: 0;
        }
        .props-eyebrow {
            font-family: 'Inter', sans-serif;
            font-size: 9px; font-weight: 700;
            letter-spacing: 0.16em; text-transform: uppercase;
            color: rgba(42,39,35,0.28);
            margin-bottom: 0.2rem;
        }
        .props-title {
            font-family: 'EB Garamond', serif;
            font-size: 1.35rem; font-weight: 500;
            color: var(--ink, #2A2724); line-height: 1.2;
        }

        .props-close {
            width: 30px; height: 30px; border-radius: 50%;
            background: rgba(255,255,255,0.9);
            border: 1px solid rgba(42,39,35,0.10);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: rgba(42,39,35,0.38);
            transition: all 0.2s; flex-shrink: 0;
        }

        .props-body {
            overflow-y: auto;
            padding: 1.2rem 1.8rem 2rem;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
        }
        .prop-row {
            padding: 0.9rem 0.6rem;
            border-bottom: 1px solid rgba(42,39,35,0.05);
        }
        .prop-row.full-width { grid-column: 1 / -1; }
        .prop-row.row-span-2 { grid-row: span 2; border-bottom: none; }

        .prop-label {
            font-family: 'Inter', sans-serif;
            font-size: 8.5px; font-weight: 700;
            letter-spacing: 0.13em; text-transform: uppercase;
            color: rgba(42,39,35,0.30);
            margin-bottom: 0.4rem;
        }
        .prop-value {
            font-family: 'EB Garamond', serif;
            font-size: 1rem; color: rgba(42,39,35,0.78);
            line-height: 1.35;
        }
        .prop-value.italic-accent { color: var(--accent); font-style: italic; }
        .prop-value.handwriting {
            font-family: 'Reenie Beanie', cursive;
            font-size: 1.2rem; color: #A39985; line-height: 1.2;
        }

        .dot-rating { display: flex; gap: 5px; align-items: center; }
        .dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--accent-pale);
            border: 1.5px solid var(--accent-light);
        }
        .dot.filled { background: var(--accent); border-color: var(--accent); }

        .prop-chips { display: flex; flex-wrap: wrap; gap: 8px; }
        .prop-chip {
            display: inline-block;
            font-family: 'Inter', sans-serif;
            font-size: 8.5px; font-weight: 700;
            letter-spacing: 0.09em; text-transform: uppercase;
            padding: 4px 12px; border-radius: 8px;
            border: 1px solid rgba(42,39,35,0.08);
        }
        .prop-chip-neutral { background: rgba(42,39,35,0.08); color: rgba(42,39,35,0.55); }
        .prop-chip-accent  { background: var(--accent-pale); color: var(--accent); border-color: var(--accent-light); }
        .prop-concept-chip {
            display: inline-block;
            background: rgba(123,160,138,0.08);
            border: 1px solid rgba(123,160,138,0.22);
            color: var(--accent-dark);
            font-family: 'EB Garamond', serif;
            font-size: 0.88rem;
            padding: 4px 11px; border-radius: 9px;
        }
        .prop-pipeline-step { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.2rem; }
        .prop-pipeline-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
        .prop-pipeline-label { font-family: 'EB Garamond', serif; font-size: 0.9rem; }
    </style>
</head>
<body class="min-h-screen flex flex-col font-serif selection:bg-[#E6DFD1]">

    <div id="read-progress"></div>

    <header class="sticky top-0 z-50 w-full h-[80px] bg-[#F5F2EB]/95 nav-frosted flex items-center justify-between px-10 shadow-sm" style="border-bottom: 0.5px solid rgba(42,39,35,0.08);">
        <div class="flex items-center gap-10">
            <a href="/astro-project-v2/" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Main Page</a>
            <div class="h-8 w-px bg-[#E8E2D2]"></div>
            <nav class="flex items-center gap-8 translate-y-[2px]">
                <a href="/astro-project-v2/notes/" class="font-serif text-xl text-[#A39985] transition-all duration-300 hover:text-[#2A2724] hover:-translate-y-[1px]">Notes</a>
                <a href="/astro-project-v2/essays/" class="group flex items-center gap-2 transition-all duration-300 hover:-translate-y-[1px]">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#7BA08A] shadow-[0_0_8px_rgba(123,160,138,0.55)]"></span>
                    <span class="font-serif text-xl text-[#2A2724]">Essays</span>
                </a>
            </nav>
        </div>
        <div class="font-['Reenie_Beanie'] text-[1.75rem] leading-none text-[#7BA08A] tracking-tight translate-y-1">hyperlynxt | teo</div>
    </header>

    <main class="w-full max-w-[1300px] mx-auto pt-[80px] pb-[120px] pl-[30px] pr-[60px] grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-[40px] lg:gap-[80px] flex-grow">
        
        <article class="w-full max-w-[850px]">
            <header class="fade-up">
                <div class="flex items-center justify-between mb-4">
                    <div class="font-['Reenie_Beanie'] text-[1.8rem] tracking-wide" style="color:#a8c5a0">
                        Essay #{essay.data.essay_number.toString().padStart(3, '0')}
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="font-sans text-[9px] font-bold tracking-[0.18em] uppercase text-muted">Status</span>
                        <span class={`status-badge status-${essay.data.status.toLowerCase().replace(/\s/g, '')}`}>
                            {essay.data.status}
                        </span>
                    </div>
                </div>

                <h1 class="font-serif text-[3.2rem] md:text-[3.6rem] font-normal leading-[1.1] text-gray-900 mb-6">
                    {essay.data.title}
                </h1>

                <div class="flex items-center gap-6 mb-8 pb-8 border-b border-[#E6DFD1]">
                    <div class="flex items-center gap-2">
                        <span class="font-sans text-[9px] font-bold tracking-[0.18em] uppercase text-muted">Published</span>
                        <span class="font-serif text-[0.95rem] text-gray-600">{essay.data.date_published.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span>
                    </div>
                    <span class="text-[#D4C9B5]">·</span>
                    <div class="flex items-center gap-2">
                        <span class="font-sans text-[9px] font-bold tracking-[0.18em] uppercase text-muted">Analytical Lens</span>
                        <span class="lens-pill">{essay.data.analytical_lens}</span>
                    </div>
                </div>

                {essay.data.follow_up_research && (
                    <div class="argument-block px-5 py-4 rounded-r-md mb-[48px]">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="font-sans text-[9px] font-bold tracking-[0.18em] uppercase" style="color:#4A6B62">Lead Question / Argument</span>
                        </div>
                        <p class="font-serif text-[1.1rem] leading-[1.65] text-gray-800 italic">
                            {essay.data.follow_up_research}
                        </p>
                    </div>
                )}
            </header>

            <div class="font-serif text-[1.3rem] leading-[1.8] text-gray-800 flex flex-col gap-[32px] fade-up shadow-sm bg-white/30 p-8 rounded-2xl border border-white/50 essay-body">
                <EssayContent />
            </div>
        </article>

        <style is:global>
            .essay-body strong, .essay-body b {
                color: #7BA08A;
                font-weight: 600;
            }
        html {
            scroll-behavior: smooth;
        }

        .essay-body h2, .essay-body h3 {
                font-family: 'EB Garamond', serif;
                font-size: 1.7rem;
                font-weight: 500;
                color: #111827; /* gray-900 */
                margin-top: 48px;
                margin-bottom: 16px;
                padding-bottom: 12px;
                border-bottom: 1px solid #E6DFD1;
                line-height: 1.2;
            }
            .essay-body h2:first-child, .essay-body h3:first-child {
                margin-top: 0;
            }
        </style>

        <aside class="flex flex-col gap-[32px]">
            {essay.data.concepts_used && essay.data.concepts_used.length > 0 && (
                <div>
                    <div class="sidebar-label mb-4 block">Concepts Used</div>
                    <ul class="flex flex-col gap-4">
                        {essay.data.concepts_used.map((concept, i) => {
                            const found = allConcepts.find(c => c.data.title.toLowerCase() === concept.toLowerCase());
                            return (
                                <li>
                                    <div 
                                        class={`group flex items-baseline gap-3 text-gray-900 ${found ? 'cursor-pointer hover:text-[#7BA08A] transition-all open-concept-btn' : ''}`}
                                        data-id={found?.id}
                                    >
                                        <span class="font-['Reenie_Beanie'] text-[1.4rem] leading-none" style="color:#a8c5a0">{(i + 1).toString().padStart(2, '0')}</span>
                                        <span class="font-serif text-[1.1rem]">{concept}</span>
                                    </div>
                                </li>
                            );
                        })}
                    </ul>
                </div>
            )}

            {essay.data.notes_used && essay.data.notes_used.length > 0 && (
                <div>
                    <div class="sidebar-label mb-3 block">Notes Used</div>
                    <ul class="flex flex-col gap-2.5">
                        {essay.data.notes_used.map(noteTitle => {
                            const found = allNotes.find(n => n.data.title.toLowerCase() === noteTitle.toLowerCase());
                            return (
                                <li 
                                    class={`flex items-center gap-3 bg-white/60 border border-[#E6DFD1] rounded-full px-4 py-2 shadow-sm ${found ? 'cursor-pointer hover:border-[#7BA08A] transition-all open-note-btn' : ''}`}
                                    data-id={found?.id}
                                >
                                    <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color:#a8c5a0"></span>
                                    <span class="font-serif text-[0.85rem] text-gray-600 leading-tight">{noteTitle}</span>
                                </li>
                            );
                        })}
                    </ul>
                </div>
            )}

            <div>
                <div class="sidebar-label mb-3 block">Disciplines Touched</div>
                <div class="flex flex-wrap gap-2">
                    {essay.data.disciplines_touched.map(discipline => (
                        <span class="font-serif text-[0.92rem] text-gray-700 bg-white/60 border border-[#E6DFD1] rounded-full px-4 py-1.5 shadow-sm">{discipline}</span>
                    ))}
                </div>
            </div>

            {essay.data.sections && essay.data.sections.length > 0 && (
                <div class="sidebar-card shadow-lg border-none">
                    <div class="sidebar-card-header bg-[#7BA08A]/5 border-b-[#7BA08A]/10">
                        <span class="sidebar-label text-[#7BA08A]">Sections</span>
                    </div>
                    <div class="flex flex-col">
                        {essay.data.sections.map((section, i) => {
                            const sectionId = section.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
                            return (
                                <a href={`#${sectionId}`} class="flex items-center gap-3 px-4 py-3 border-b border-[#F5F2EB] last:border-0 hover:bg-[#7BA08A]/5 transition-colors group">
                                    <span class="font-['Reenie_Beanie'] text-[1rem] leading-none text-[#a8c5a0]">{(i + 1).toString().padStart(2, '0')}</span>
                                    <span class="font-serif text-[0.9rem] text-gray-700">{section}</span>
                                </a>
                            );
                        })}
                    </div>
                </div>
            )}

            <div class="mt-8">
                <div class="flex flex-wrap items-center gap-x-3 gap-y-2 font-sans text-[10px] font-bold text-muted tracking-[0.15em] uppercase">
                    {essay.data.tags.map((tag, i) => (
                        <>
                            <span>{tag}</span>
                            {i < essay.data.tags.length - 1 && <span class="opacity-30">·</span>}
                        </>
                    ))}
                </div>
            </div>
        </aside>
    </main>

    <footer class="bg-[#F5F2EB] border-t border-[#E6DFD1] py-[48px] w-full">
        <div class="text-center font-serif italic text-gray-800 opacity-50 text-[1.1rem]">
            Entry Logged. Archive Registry Sequence {essay.data.essay_number.toString().padStart(3, '0')}-E.
        </div>
    </footer>

