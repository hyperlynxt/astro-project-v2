---
---
<style is:global>
    .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes slideUpScale { from { opacity: 0; transform: translateY(40px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
    @keyframes slideInRight { from { opacity: 0; transform: translateX(-40px); } to { opacity: 1; transform: translateX(0); } }
    .animate-modal-enter { opacity: 0; animation: slideUpScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s forwards; }
    .animate-content-enter { opacity: 0; animation: slideInRight 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) 0.15s forwards; }
    
    .ink-stain {
        background-color: #FDFCF9;
        background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png"), url("https://www.transparenttextures.com/patterns/natural-paper.png"), radial-gradient(circle at 10% 90%, rgba(42,39,36,0.03) 0%, rgba(253,252,249,0) 60%);
        background-position: 0px 0px, 40px 60px, 0 0;
        background-repeat: repeat, repeat, no-repeat;
    }
    .swoosh-path { stroke-dasharray: 100; stroke-dashoffset: 100; }
    @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }

    #concept-modal .modal-scrollbar::-webkit-scrollbar { width: 4px; }
    #concept-modal .modal-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.15); border-radius: 10px; }

    #concept-modal {
        position: fixed; inset: 0; z-index: 100;
        display: none; align-items: center; justify-content: center;
        padding: 2rem; background: rgba(42,39,35,0.25);
        backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px);
    }
    .concept-modal-inner {
        width: 100%; max-width: 900px; height: 85vh;
        background: white; border-radius: 40px; overflow: hidden;
        border: 1px solid rgba(255,255,255,0.6);
        box-shadow: 0 40px 100px rgba(42,39,36,0.15);
        position: relative; ring: 1px ring-[#D5CCB6]/30;
    }
</style>

<div id="concept-modal">
    <div class="concept-modal-inner animate-modal-enter">
        <div class="h-full flex flex-col relative bg-[#FDFCF9] ink-stain overflow-y-auto modal-scrollbar z-10 p-6 md:p-12 lg:p-16">
            <!-- Close Button -->
            <button id="close-concept-btn" class="absolute top-8 right-8 w-12 h-12 rounded-full bg-white/80 backdrop-blur-md border border-[#D5CCB6] shadow-sm hover:bg-white flex items-center justify-center text-[#2A2724] transition-all group z-[60]">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 opacity-60 group-hover:opacity-100 group-hover:rotate-90 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <div class="relative animate-content-enter">
                <div id="modal-concept-bg-letter" class="absolute top-0 right-0 text-[24rem] font-serif font-bold text-[#2A2724]/[0.015] leading-none pointer-events-none select-none -z-10 -rotate-3"></div>

                <div class="mb-10">
                    <h1 class="font-serif text-4xl md:text-5xl lg:text-[4.5rem] font-medium text-[#2A2724] leading-[1.01] mb-6 tracking-tight relative pr-12">
                        <span id="modal-concept-title" class="italic inline"></span>
                        <svg id="modal-title-underline" class="absolute h-[12px] text-[#8B2626] opacity-70 overflow-visible pointer-events-none" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display: none;">
                            <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path"></path>
                        </svg>
                    </h1>
                    
                    <div class="relative">
                        <div class="flex flex-col">
                            <div id="modal-ontology-attribution" class="font-serif italic text-[1.25rem] mb-6 flex flex-wrap items-baseline gap-x-8 gap-y-2" style="display:none;">
                                <div id="modal-discipline-container" class="flex items-baseline gap-2">
                                    <span style="color:#8B2626;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.9rem;font-weight:700;font-style:normal;">Discipline</span>
                                    <span id="modal-discipline-text" style="color:#B08D57;opacity:0.7;font-style:italic;"></span>
                                </div>
                                <div id="modal-framework-container" class="flex items-baseline gap-2" style="display:none;">
                                    <span style="color:#8B2626;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.9rem;font-weight:700;font-style:normal;">Parent Framework</span>
                                    <span id="modal-framework-text" style="color:#B08D57;opacity:0.7;font-style:italic;"></span>
                                </div>
                            </div>

                            <div id="modal-attribution" class="font-serif italic text-[1.35rem] mb-6 flex items-baseline gap-2" style="display:none;">
                                <span style="color:#8B2626;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.9rem;font-weight:700;font-style:normal;">From the work of</span>
                                <span id="modal-authors-list" style="color:#B08D57;opacity:0.7;font-style:italic;"></span>
                            </div>

                            <div id="modal-tags-attribution" class="font-serif italic text-[1.25rem] mb-6 flex items-baseline gap-2" style="display:none;">
                                <span style="color:#8B2626;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.9rem;font-weight:700;font-style:normal;">Tags</span>
                                <span id="modal-tags-list" style="color:#B08D57;opacity:0.7;font-style:italic;"></span>
                            </div>

                            <div id="modal-stars" class="flex flex-row gap-1.5 items-center text-[#8B2626] mb-12"></div>
                        </div>
                    </div>

                    <div class="font-serif text-[1.25rem] leading-[1.65] text-[#2A2724] pl-6 border-l-[3px] border-[#B08D57]/40 max-w-4xl">
                        <p id="modal-summary"></p>
                    </div>
                </div>

                <div id="modal-detailed-desc" class="font-serif text-xl md:text-[1.45rem] leading-[1.85] text-[#2A2724]/85 space-y-8 max-w-[900px] z-10 relative mb-20 prose prose-ink"></div>

                <div id="modal-field-note-section" class="mb-12 max-w-[900px]" style="display:none;">
                    <div style="color:#8B2626;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.8rem;font-weight:700;font-style:normal;margin-bottom:0.5rem;">Notes of Myself</div>
                    <p id="modal-field-note" class="font-['Reenie_Beanie'] text-2xl text-[#2A2724]/90"></p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-[1000px]">
                    <div id="modal-related-section" class="md:col-span-2 bg-white rounded-3xl border border-[#D5CCB6]/40 p-8 shadow-sm" style="display:none;">
                         <h3 class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] text-[#2A2724]/40 mb-5 flex items-center gap-2.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style="color:#8B2626;" fill="none" viewBox="0 0 24 24" stroke="#8B2626" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                            Related Concepts
                         </h3>
                         <div id="modal-related-items" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
                    </div>

                    <div class="bg-white rounded-3xl border border-[#D5CCB6]/40 p-8 shadow-sm">
                         <h3 class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] text-[#2A2724]/40 mb-4 flex items-center gap-2.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style="color:#8B2626;" fill="none" viewBox="0 0 24 24" stroke="#8B2626" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"></path></svg>
                            Origin
                         </h3>
                         <p id="modal-origin" class="font-serif text-[1.1rem] leading-relaxed text-[#2A2724]/70 italic"></p>
                    </div>

                    <div class="bg-white rounded-3xl border border-[#D5CCB6]/40 p-8 shadow-sm">
                         <h3 class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] text-[#2A2724]/40 mb-5 flex items-center gap-2.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style="color:#8B2626;" fill="none" viewBox="0 0 24 24" stroke="#8B2626" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                            Linked Insights
                         </h3>
                         <div class="flex items-baseline gap-4">
                             <div id="modal-concept-linked" class="text-6xl font-serif text-[#2A2724] tracking-tight"></div>
                             <div class="text-[12px] font-sans text-[#2A2724]/40 uppercase tracking-widest font-bold leading-tight">Total<br>Times Used</div>
                         </div>
                    </div>

                    <div id="modal-notes-section" class="md:col-span-2 bg-white rounded-3xl border border-[#D5CCB6]/40 p-8 shadow-sm" style="display:none;">
                         <h3 class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] text-[#2A2724]/40 mb-5 flex items-center gap-2.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style="color:#8B2626;" fill="none" viewBox="0 0 24 24" stroke="#8B2626" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                            Notes of Used
                         </h3>
                         <div id="modal-notes-items" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        console.log('ConceptModal system initializing...');
        window.openConceptModal = function(id, conceptsSource, contentHtml) {
            const conceptModal = document.getElementById('concept-modal');
            if (!conceptModal) return;

            const d = conceptsSource.find(c => c.id === id);
            if (!d) return;

            const setElTxt = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val || ''; };
            const setElHtml = (id, val) => { const el = document.getElementById(id); if (el) el.innerHTML = val || ''; };
            const toggleSec = (id, show) => { const el = document.getElementById(id); if (el) el.style.display = show ? 'block' : 'none'; };
            const toggleSecFlex = (id, show) => { const el = document.getElementById(id); if (el) el.style.display = show ? 'flex' : 'none'; };

            setElTxt('modal-concept-title', d.title);
            setElTxt('modal-concept-bg-letter', d.title[0].toUpperCase());
            setElTxt('modal-summary', d.short || d.summary);
            setElHtml('modal-detailed-desc', contentHtml || '');
            setElTxt('modal-origin', d.origin);
            setElTxt('modal-concept-linked', d.linked);

            // Discipline & Framework
            let displayDiscipline = d.discipline;
            let displayFramework = '';
            if (d.discipline && d.discipline.includes('/')) {
                const parts = d.discipline.split('/');
                displayDiscipline = parts[0].trim();
                displayFramework = parts[1].trim();
            }

            toggleSecFlex('modal-ontology-attribution', false);
            toggleSecFlex('modal-discipline-container', false);
            toggleSecFlex('modal-framework-container', false);

            if (displayDiscipline || displayFramework) {
                toggleSecFlex('modal-ontology-attribution', true);
                if (displayDiscipline) {
                    setElTxt('modal-discipline-text', displayDiscipline);
                    toggleSecFlex('modal-discipline-container', true);
                }
                if (displayFramework) {
                    setElTxt('modal-framework-text', displayFramework);
                    toggleSecFlex('modal-framework-container', true);
                }
            }

            if (d.authors) {
                setElTxt('modal-authors-list', d.authors);
                toggleSecFlex('modal-attribution', true);
            } else toggleSecFlex('modal-attribution', false);

            if (d.tags) {
                setElTxt('modal-tags-list', d.tags);
                toggleSecFlex('modal-tags-attribution', true);
            } else toggleSecFlex('modal-tags-attribution', false);

            // Stars
            const rotations = ['', 'transform: rotate(15deg);', 'transform: rotate(-10deg);', 'transform: rotate(5deg);', 'transform: rotate(-15deg);'];
            const starsHtml = Array.from({length: parseInt(d.rating)||0}).map((_, i) =>
                `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" style="${rotations[i] || ''}">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor" fill-opacity="0.2"></path>
                </svg>`
            ).join('');
            setElHtml('modal-stars', starsHtml);

            if (d.fieldnote || d.fieldNote) { setElTxt('modal-field-note', d.fieldnote || d.fieldNote); toggleSec('modal-field-note-section', true); }
            else toggleSec('modal-field-note-section', false);

            if (d.notesofused || d.notesOfUsed) {
                const itemsStr = d.notesofused || d.notesOfUsed;
                const items = itemsStr.split(',').filter(n => n.trim());
                setElHtml('modal-notes-items', items.map(name => `
                    <div class="group p-3.5 bg-[#FDFCF9]/50 border border-[#D5CCB6]/40 rounded-xl flex items-center justify-between cursor-pointer hover:bg-[#FDFCF9] hover:border-[#7C6B9E]/40 hover:shadow-sm transition-all">
                        <p class="font-serif text-[17px] text-[#2A2724] group-hover:text-[#7C6B9E] font-medium transition-colors">${name.trim()}</p>
                    </div>`).join(''));
                toggleSec('modal-notes-section', true);
            } else toggleSec('modal-notes-section', false);

            if (d.related) {
                const items = d.related.split(',').filter(r => r.trim());
                setElHtml('modal-related-items', items.map(name => `
                    <div class="group p-3.5 bg-[#FDFCF9]/50 border border-[#D5CCB6]/40 rounded-xl flex items-center justify-between cursor-pointer hover:bg-[#FDFCF9] hover:border-[#B08D57]/40 hover:shadow-sm transition-all">
                        <p class="font-serif text-[17px] text-[#2A2724] group-hover:text-[#B08D57] font-medium transition-colors">${name.trim()}</p>
                    </div>`).join(''));
                toggleSec('modal-related-section', true);
            } else toggleSec('modal-related-section', false);

            // Underline animation
            const titleEl = document.getElementById('modal-concept-title');
            const underline = document.getElementById('modal-title-underline');
            if (titleEl && underline) {
                requestAnimationFrame(() => {
                    const rects = titleEl.getClientRects();
                    const containerRect = titleEl.parentElement.getBoundingClientRect();
                    if (rects.length > 0) {
                        const firstRect = rects[0];
                        underline.style.width = (firstRect.width * 1.05) + 'px';
                        underline.style.top = (firstRect.bottom - containerRect.top - (firstRect.height * 0.12)) + 'px';
                        underline.style.left = (firstRect.left - containerRect.left - (firstRect.width * 0.025)) + 'px';
                        underline.style.display = 'block';
                        const path = underline.querySelector('path');
                        if (path) {
                            path.style.animation = 'none'; void path.offsetWidth;
                            path.style.animation = 'drawSwoosh 0.8s ease-out 0.4s forwards';
                        }
                    }
                });
            }

            conceptModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        };

        const hideConceptModal = () => {
            const conceptModal = document.getElementById('concept-modal');
            if (conceptModal) conceptModal.style.display = 'none';
            document.body.style.overflow = '';
        };

        const closeBtn = document.getElementById('close-concept-btn');
        if (closeBtn) closeBtn.onclick = hideConceptModal;

        document.addEventListener('click', (e) => {
            const conceptModal = document.getElementById('concept-modal');
            if(e.target === conceptModal) hideConceptModal();
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') hideConceptModal();
        });
    })();
</script>
