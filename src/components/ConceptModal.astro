---
---
<style is:global>
    .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes slideUpScale { from { opacity: 0; transform: translateY(40px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
    @keyframes slideInRight { from { opacity: 0; transform: translateX(-40px); } to { opacity: 1; transform: translateX(0); } }
    .animate-modal-enter { opacity: 0; animation: slideUpScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s forwards; }
    .animate-content-enter { opacity: 0; animation: slideInRight 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) 0.15s forwards; }
    
    .ink-stain {
        background-color: #FDFCF9;
        background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png"), url("https://www.transparenttextures.com/patterns/natural-paper.png"), radial-gradient(circle at 10% 90%, rgba(42,39,36,0.03) 0%, rgba(253,252,249,0) 60%);
        background-position: 0px 0px, 40px 60px, 0 0;
        background-repeat: repeat, repeat, no-repeat;
    }
    .swoosh-path { stroke-dasharray: 100; stroke-dashoffset: 100; }
    @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }

    #concept-modal .modal-scrollbar::-webkit-scrollbar { width: 4px; }
    #concept-modal .modal-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.15); border-radius: 10px; }

    #concept-modal {
        position: fixed; inset: 0; z-index: 100;
        display: none; align-items: center; justify-content: center;
        padding: 2rem; background: rgba(42,39,35,0.25);
        backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px);
    }
    .concept-modal-inner {
        width: 100%; max-width: 900px; height: 85vh;
        background: white; border-radius: 40px; overflow: hidden;
        border: 1px solid rgba(255,255,255,0.6);
        box-shadow: 0 40px 100px rgba(42,39,36,0.15);
        position: relative; ring: 1px ring-[#D5CCB6]/30;
        display: flex; flex-direction: column;
    }

    .modal-footer-bar {
        padding: 1rem 2.5rem 1.5rem;
        border-top: 1px solid rgba(139,38,38,0.10);
        display: flex; align-items: center; justify-content: space-between;
        background: rgba(253,252,249,0.8);
        backdrop-blur: 8px; flex-shrink: 0;
    }

    .properties-btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 700;
        letter-spacing: 0.14em; text-transform: uppercase;
        color: rgba(42,39,35,0.45); background: transparent;
        border: 1.5px solid rgba(42,39,35,0.12); border-radius: 100px;
        padding: 7px 16px; cursor: pointer; transition: all 0.2s ease;
    }
    .properties-btn:hover { color: #8B2626; border-color: rgba(139,38,38,0.3); background: rgba(139,38,38,0.05); }

    #concept-props-overlay {
        position: absolute; inset: 0; z-index: 120;
        display: flex; align-items: flex-end; justify-content: stretch;
        background: rgba(42,39,35,0.18); backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px); border-radius: 40px;
        overflow: hidden; opacity: 0; pointer-events: none; transition: opacity 0.25s ease;
    }
    #concept-props-overlay.open { opacity: 1; pointer-events: all; }
    
    .concept-props-panel {
        width: 100%; background: #FDFCF9;
        background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
        border-radius: 28px 28px 40px 40px; border-top: 1px solid rgba(139,38,38,0.15);
        box-shadow: 0 -12px 48px rgba(42,39,35,0.14);
        transform: translateY(100%); transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
        max-height: 85%; display: flex; flex-direction: column; overflow: hidden;
    }
    #concept-props-overlay.open .concept-props-panel { transform: translateY(0); }

    .concept-props-band {
        height: 4px; border-radius: 28px 28px 0 0; flex-shrink: 0; opacity: 0.55;
        background: linear-gradient(90deg, #D5CCB6, #8B2626, #D5CCB6);
    }
    .concept-props-header { padding: 1.2rem 2rem 1.1rem; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    .concept-props-eyebrow {
        font-family: 'Inter', sans-serif; font-size: 9px; font-weight: 700;
        letter-spacing: 0.16em; text-transform: uppercase; color: rgba(42,39,35,0.28); margin-bottom: 0.2rem;
    }
    .concept-props-title { font-family: 'EB Garamond', serif; font-size: 1.35rem; font-weight: 500; color: #2A2724; line-height: 1.2; }
    .concept-props-close {
        width: 32px; height: 32px; border-radius: 50%; background: white;
        border: 1px solid rgba(42,39,35,0.10); display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: rgba(42,39,35,0.38); transition: all 0.2s; flex-shrink: 0;
    }
    .concept-props-close:hover { background: #F5F2EB; color: #8B2626; }

    .concept-props-body { overflow-y: auto; padding: 1.2rem 2rem 2.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
    .concept-prop-row { padding: 1rem 0.6rem; border-bottom: 1px solid rgba(42,39,35,0.05); }
    .concept-prop-row.full-width { grid-column: 1 / -1; }
    .concept-prop-row.row-span-2 { grid-row: span 2; border-bottom: none; }

    .concept-prop-label {
        font-family: 'Inter', sans-serif; font-size: 9px; font-weight: 700;
        letter-spacing: 0.13em; text-transform: uppercase; color: rgba(42,39,35,0.30); margin-bottom: 0.5rem;
    }
    .concept-prop-value { font-family: 'EB Garamond', serif; font-size: 1.05rem; color: rgba(42,39,35,0.78); line-height: 1.4; }
    .concept-prop-value.italic-accent { color: #8B2626; font-style: italic; }
    
    .dot-rating { display: flex; gap: 5px; align-items: center; }
    .dot { width: 8px; height: 8px; border-radius: 50%; background: #F5F2EB; border: 1.5px solid #D5CCB6; }
    .dot.filled { background: #8B2626; border-color: #8B2626; }

    .concept-prop-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .concept-prop-chip {
        display: inline-block; font-family: 'Inter', sans-serif; font-size: 9px; font-weight: 700;
        letter-spacing: 0.09em; text-transform: uppercase; padding: 4px 12px; border-radius: 8px;
        background: rgba(42,39,35,0.06); color: rgba(42,39,35,0.5); border: 1px solid rgba(42,39,35,0.08);
    }
    .concept-prop-concept-chip {
        display: inline-block; background: rgba(139,38,38,0.05); border: 1px solid rgba(139,38,38,0.15);
        color: #8B2626; font-family: 'EB Garamond', serif; font-size: 0.95rem; padding: 4px 12px; border-radius: 9px;
    }

    /* Red bolding for main body content and summary */
    #concept-modal strong, 
    #concept-modal b,
    #modal-detailed-desc strong,
    #modal-detailed-desc b {
        color: #8B2626 !important;
        font-weight: 600 !important;
    }
</style>

<div id="concept-modal">
    <div class="concept-modal-inner animate-modal-enter">
        <div class="flex-1 flex flex-col relative bg-[#FDFCF9] ink-stain overflow-y-auto modal-scrollbar z-10 p-6 md:p-12 lg:p-16">
            <!-- Close Button -->
            <button id="close-concept-btn" class="absolute top-8 right-8 w-12 h-12 rounded-full bg-white/80 backdrop-blur-md border border-[#D5CCB6] shadow-sm hover:bg-white flex items-center justify-center text-[#2A2724] transition-all group z-[60]">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 opacity-60 group-hover:opacity-100 group-hover:rotate-90 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <div class="relative animate-content-enter">
                <div id="modal-concept-bg-letter" class="absolute top-0 right-0 text-[24rem] font-serif font-bold text-[#2A2724]/[0.015] leading-none pointer-events-none select-none -z-10 -rotate-3"></div>

                <div class="mb-10">
                    <h1 class="font-serif text-4xl md:text-5xl lg:text-[4.5rem] font-medium text-[#2A2724] leading-[1.01] mb-6 tracking-tight relative pr-12">
                        <span id="modal-concept-title" class="inline"></span>
                        <svg id="modal-title-underline" class="absolute h-[12px] text-[#8B2626] opacity-70 overflow-visible pointer-events-none" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display: none;">
                            <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path"></path>
                        </svg>
                    </h1>
                    
                    <div class="relative">
                        <div class="flex flex-col">
                            <!-- Redundant metadata hidden per request -->
                            <div id="modal-stars" style="display:none;"></div>
                        </div>
                    </div>

                    <div class="font-serif text-[1.25rem] leading-[1.65] text-[#2A2724] pl-6 border-l-[3px] border-[#B08D57]/40 max-w-4xl">
                        <p id="modal-summary"></p>
                    </div>
                </div>

                <div id="modal-detailed-desc" class="font-serif text-xl md:text-[1.45rem] leading-[1.85] text-[#2A2724]/85 space-y-8 max-w-[900px] z-10 relative mb-20 prose prose-ink"></div>

                <div id="modal-field-note-section" class="mb-12 max-w-[900px]" style="display:none;">
                    <div style="color:#8B2626;opacity:0.8;font-variant:small-caps;letter-spacing:0.1em;font-size:0.8rem;font-weight:700;font-style:normal;margin-bottom:0.5rem;">Notes of Myself</div>
                    <p id="modal-field-note" class="font-['Reenie_Beanie'] text-2xl text-[#2A2724]/90"></p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-[1000px]">
                    <div id="modal-related-section" class="md:col-span-2 bg-white rounded-3xl border border-[#D5CCB6]/40 p-8 shadow-sm" style="display:none;">
                         <h3 class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] text-[#2A2724]/40 mb-5 flex items-center gap-2.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style="color:#8B2626;" fill="none" viewBox="0 0 24 24" stroke="#8B2626" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                            Related Concepts
                         </h3>
                         <div id="modal-related-items" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
                    </div>

                    <div id="modal-notes-section" class="md:col-span-2 bg-white rounded-3xl border border-[#D5CCB6]/40 p-8 shadow-sm" style="display:none;">
                         <h3 class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] text-[#2A2724]/40 mb-5 flex items-center gap-2.5">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" style="color:#8B2626;" fill="none" viewBox="0 0 24 24" stroke="#8B2626" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                            Notes of Used
                         </h3>
                         <div id="modal-notes-items" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="modal-footer-bar">
            <button id="open-concept-props-btn" class="properties-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
                Concept Properties
            </button>
        </footer>

        <!-- Properties Slide-up Panel -->
        <div id="concept-props-overlay">
            <div class="concept-props-panel">
                <div class="concept-props-band"></div>
                <div class="concept-props-header">
                    <div>
                        <p class="concept-props-eyebrow">Properties</p>
                        <h3 id="concept-props-title" class="concept-props-title"></h3>
                    </div>
                    <button id="close-concept-props-btn" class="concept-props-close">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>
                <div id="concept-props-body" class="concept-props-body"></div>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        console.log('ConceptModal system initializing...');

        function dots(n) {
            let h = '';
            for(let i=1; i<=3; i++) {
                h += `<span class="dot${i <= n ? ' filled' : ''}"></span>`;
            }
            return h;
        }

        function buildPropsPanel(d) {
            const body = document.getElementById('concept-props-body');
            const titleEl = document.getElementById('concept-props-title');
            const overlay = document.getElementById('concept-props-overlay');
            if (!body || !titleEl || !overlay) return;

            body.innerHTML = '';
            titleEl.textContent = d.title;

            let displayDiscipline = d.discipline;
            let displayFramework = '';
            if (d.discipline && d.discipline.includes('/')) {
                const parts = d.discipline.split('/');
                displayDiscipline = parts[0].trim();
                displayFramework = parts[1].trim();
            }

            const rows = [
                { label: 'Rating', html: `<div class="dot-rating">${dots(parseInt(d.rating)||0)}</div>` },
                { label: 'Linked Notes', html: `<span class="concept-prop-value italic-accent">${d.linked_notes || d.linked || 0} insights</span>` },
                { label: 'Discipline', html: `<span class="concept-prop-value">${displayDiscipline || '—'}</span>` },
                { label: 'Parent Framework', html: `<span class="concept-prop-value">${displayFramework || '—'}</span>` },
                { label: 'Origin', html: `<span class="concept-prop-value italic-accent">${d.origin || '—'}</span>`, full: true },
                { 
                    label: 'From the work of', 
                    html: (d.authors) ? `<div class="concept-prop-chips">${(Array.isArray(d.authors) ? d.authors : d.authors.split(',')).map(a => `<span class="concept-prop-chip">${a.trim()}</span>`).join('')}</div>` : '<span class="concept-prop-value">—</span>',
                    full: true 
                },
                { 
                    label: 'Tags', 
                    html: (d.tags) ? `<div class="concept-prop-chips">${(Array.isArray(d.tags) ? d.tags : d.tags.split(',')).map(t => `<span class="concept-prop-chip">${t.trim()}</span>`).join('')}</div>` : '<span class="concept-prop-value">—</span>',
                    full: true 
                }
            ];

            rows.forEach(row => {
                const div = document.createElement('div');
                div.className = 'concept-prop-row';
                if (row.full) div.classList.add('full-width');
                div.innerHTML = `<p class="concept-prop-label">${row.label}</p><div>${row.html}</div>`;
                body.appendChild(div);
            });

            overlay.classList.add('open');
        }

        window.openConceptModal = function(id, conceptsSource, contentHtml) {
            const conceptModal = document.getElementById('concept-modal');
            if (!conceptModal) return;

            const d = conceptsSource.find(c => c.id === id);
            if (!d) return;

            const setElTxt = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val || ''; };
            const setElHtml = (id, val) => { const el = document.getElementById(id); if (el) el.innerHTML = val || ''; };
            const toggleSec = (id, show) => { const el = document.getElementById(id); if (el) el.style.display = show ? 'block' : 'none'; };

            setElTxt('modal-concept-title', d.title);
            setElTxt('modal-concept-bg-letter', d.title[0].toUpperCase());
            
            const summaryRaw = d.short_description || d.short || d.summary || '';
            setElHtml('modal-summary', summaryRaw.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>'));

            setElHtml('modal-detailed-desc', contentHtml || '');

            const propsBtn = document.getElementById('open-concept-props-btn');
            if (propsBtn) propsBtn.onclick = () => buildPropsPanel(d);

            if (d.fieldnote || d.fieldNote) { setElTxt('modal-field-note', d.fieldnote || d.fieldNote); toggleSec('modal-field-note-section', true); }
            else toggleSec('modal-field-note-section', false);

            if (d.notes_of_used || d.notesofused || d.notesOfUsed) {
                const raw = d.notes_of_used || d.notesofused || d.notesOfUsed;
                const items = (Array.isArray(raw) ? raw : raw.split(',')).filter(n => n.trim());
                setElHtml('modal-notes-items', items.map(name => `
                    <div class="group p-3.5 bg-[#FDFCF9]/50 border border-[#D5CCB6]/40 rounded-xl flex items-center justify-between cursor-pointer hover:bg-[#FDFCF9] hover:border-[#7C6B9E]/40 hover:shadow-sm transition-all">
                        <p class="font-serif text-[17px] text-[#2A2724] group-hover:text-[#7C6B9E] font-medium transition-colors">${name.trim()}</p>
                    </div>`).join(''));
                toggleSec('modal-notes-section', true);
            } else toggleSec('modal-notes-section', false);

            if (d.related_concepts || d.related) {
                const raw = d.related_concepts || d.related;
                const items = (Array.isArray(raw) ? raw : raw.split(',')).filter(r => r.trim());
                setElHtml('modal-related-items', items.map(name => `
                    <div class="group p-3.5 bg-[#FDFCF9]/50 border border-[#D5CCB6]/40 rounded-xl flex items-center justify-between cursor-pointer hover:bg-[#FDFCF9] hover:border-[#B08D57]/40 hover:shadow-sm transition-all">
                        <p class="font-serif text-[17px] text-[#2A2724] group-hover:text-[#B08D57] font-medium transition-colors">${name.trim()}</p>
                    </div>`).join(''));
                toggleSec('modal-related-section', true);
            } else toggleSec('modal-related-section', false);

            conceptModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';

            // Underline animation
            const titleEl = document.getElementById('modal-concept-title');
            const underline = document.getElementById('modal-title-underline');
            if (titleEl && underline) {
                requestAnimationFrame(() => {
                    const rects = titleEl.getClientRects();
                    const containerRect = titleEl.parentElement.getBoundingClientRect();
                    if (rects.length > 0) {
                        const firstRect = rects[0];
                        underline.style.width = (firstRect.width * 1.05) + 'px';
                        underline.style.top = (firstRect.bottom - containerRect.top - (firstRect.height * 0.12)) + 'px';
                        underline.style.left = (firstRect.left - containerRect.left - (firstRect.width * 0.025)) + 'px';
                        underline.style.display = 'block';
                        const path = underline.querySelector('path');
                        if (path) {
                            path.style.animation = 'none'; void path.offsetWidth;
                            path.style.animation = 'drawSwoosh 0.8s ease-out 0.4s forwards';
                        }
                    }
                });
            }

            const scrollContainer = conceptModal.querySelector('.modal-scrollbar');
            if (scrollContainer) scrollContainer.scrollTop = 0;
        };

        const hideConceptModal = () => {
            const conceptModal = document.getElementById('concept-modal');
            if (conceptModal) conceptModal.style.display = 'none';
            const propsOverlay = document.getElementById('concept-props-overlay');
            if (propsOverlay) propsOverlay.classList.remove('open');
            document.body.style.overflow = '';
        };

        const closeBtn = document.getElementById('close-concept-btn');
        if (closeBtn) closeBtn.onclick = hideConceptModal;

        const closePropsBtn = document.getElementById('close-concept-props-btn');
        if (closePropsBtn) closePropsBtn.onclick = () => {
            document.getElementById('concept-props-overlay').classList.remove('open');
        };

        document.addEventListener('click', (e) => {
            const conceptModal = document.getElementById('concept-modal');
            const propsOverlay = document.getElementById('concept-props-overlay');
            if(e.target === conceptModal) hideConceptModal();
            if(e.target === propsOverlay) propsOverlay.classList.remove('open');
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const propsOverlay = document.getElementById('concept-props-overlay');
                if (propsOverlay && propsOverlay.classList.contains('open')) {
                    propsOverlay.classList.remove('open');
                } else {
                    hideConceptModal();
                }
            }
        });
    })();
</script>
