---
---
<style is:global>
    :root {
        --accent: #7BA08A;
        --accent-light: #A1C2AE;
        --accent-dark: #4A6B62;
        --accent-pale: #F1F8F4;
        --paper: #FDFCF9;
        --ink: #2A2724;
    }

    #note-modal {
        position: fixed; inset: 0; z-index: 100;
        display: none;
        align-items: center; justify-content: center;
        padding: 2rem;
        background: rgba(42,39,35,0.32);
        backdrop-filter: blur(9px);
        -webkit-backdrop-filter: blur(9px);
    }

    .note-modal-inner {
        width: 100%; max-width: 760px;
        max-height: 90vh;
        background-color: var(--paper, #FDFCF9);
        background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png"),
            radial-gradient(circle at 10% 90%, rgba(123,160,138,0.04) 0%, transparent 60%);
        background-position: 0 0, 0 0;
        background-repeat: repeat, no-repeat;
        border-radius: 36px;
        border: 1px solid rgba(255,255,255,0.6);
        box-shadow: 0 40px 100px rgba(123,160,138,0.18);
        overflow: hidden;
        position: relative;
        display: flex;
        flex-direction: column;
    }

    .note-modal-scroll {
        overflow-y: auto;
        flex: 1;
        padding: 3.5rem 3.5rem 2.5rem;
    }
    .note-modal-scroll::-webkit-scrollbar { width: 5px; }
    .note-modal-scroll::-webkit-scrollbar-thumb { background: rgba(123,160,138,0.2); border-radius: 10px; }

    .modal-close {
        position: absolute; top: 1.4rem; right: 1.4rem; z-index: 130;
        width: 38px; height: 38px; border-radius: 50%;
        background: rgba(255,255,255,0.85);
        border: 1px solid rgba(42,39,35,0.12);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: rgba(42,39,35,0.45);
        transition: all 0.2s;
    }
    .modal-close:hover { background: var(--accent-pale); color: var(--accent); border-color: var(--accent-light); }
    .modal-close svg { transition: transform 0.3s; }
    .modal-close:hover svg { transform: rotate(90deg); }

    .modal-bg-letter {
        position: absolute; top: 1rem; right: 2rem;
        font-family: 'EB Garamond', serif;
        font-size: 20rem; font-weight: 700;
        color: rgba(42,39,35,0.018);
        line-height: 1; pointer-events: none; user-select: none;
        z-index: 0;
    }

    .modal-title-block { margin-bottom: 2rem; }
    .modal-title {
        font-family: 'EB Garamond', serif;
        font-size: 3rem; font-weight: 500;
        line-height: 1.1; color: var(--ink, #2A2724);
    }

    .modal-divider {
        width: 100%; height: 1px;
        background: linear-gradient(90deg, rgba(161,194,174,0.4), rgba(161,194,174,0.1), transparent);
        margin-bottom: 2rem;
    }

    .modal-body-prose {
        font-family: 'EB Garamond', serif;
        font-size: 1.2rem; line-height: 1.85;
        color: rgba(42,39,35,0.82);
        margin-bottom: 2.5rem;
    }
    .modal-body-prose strong, .modal-body-prose b { color: var(--accent); font-weight: 600; }
    .modal-body-prose ul {
        list-style-type: disc;
        padding-left: 1.5rem;
        margin-top: 1rem;
        margin-bottom: 2rem;
    }
    .modal-body-prose ol {
        list-style-type: decimal;
        padding-left: 1.5rem;
        margin-top: 1rem;
        margin-bottom: 2rem;
    }
    .modal-body-prose li {
        margin-bottom: 0.45rem;
        padding-left: 0.5rem;
    }
    .modal-body-prose li::marker {
        color: var(--accent);
        font-weight: 700;
    }

    .modal-body-prose h2 {
        font-family: 'EB Garamond', serif;
        font-size: 1.8rem; font-weight: 500; color: var(--ink);
        margin-top: 50px; margin-bottom: 20px;
        padding-bottom: 14px; border-bottom: 1.5px solid rgba(161,194,174,0.3);
        line-height: 1.1;
    }
    .modal-body-prose h3 {
        font-family: 'EB Garamond', serif;
        font-size: 1.6rem; font-weight: 500; color: var(--ink);
        margin-top: 32px; margin-bottom: 16px;
        padding-bottom: 10px; border-bottom: 1px solid rgba(161,194,174,0.2);
        line-height: 1.2;
    }
    .modal-body-prose h4 {
        font-family: 'EB Garamond', serif;
        font-size: 1.3rem; font-weight: 500; color: var(--ink);
        margin-top: 18px; margin-bottom: 10px;
        padding-bottom: 8px; border-bottom: 1px solid rgba(161,194,174,0.1);
        line-height: 1.2;
    }
    .modal-body-prose h3 + h4 {
        margin-top: 8px;
    }
    .modal-body-prose p {
        margin-bottom: 22px;
    }
    .modal-body-prose li p {
        margin-bottom: 0;
    }
    .modal-body-prose p:last-child {
        margin-bottom: 0;
    }

    .modal-footer-bar {
        padding: 1rem 2.5rem 1.5rem;
        border-top: 1px solid rgba(123,160,138,0.10);
        display: flex; align-items: center; justify-content: space-between;
        background: rgba(253,252,249,0.8);
        backdrop-filter: blur(8px);
        flex-shrink: 0;
    }

    .properties-btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 700;
        letter-spacing: 0.14em; text-transform: uppercase;
        color: rgba(42,39,35,0.45); background: transparent;
        border: 1.5px solid rgba(42,39,35,0.12); border-radius: 100px;
        padding: 7px 16px; cursor: pointer; transition: all 0.2s ease;
    }
    .properties-btn:hover { color: var(--accent); border-color: var(--accent-light); background: var(--accent-pale); }

    #props-overlay {
        position: absolute; inset: 0; z-index: 120;
        display: flex; align-items: flex-end; justify-content: stretch;
        background: rgba(42,39,35,0.18); backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px); border-radius: 36px;
        overflow: hidden; opacity: 0; pointer-events: none; transition: opacity 0.25s ease;
    }
    #props-overlay.open { opacity: 1; pointer-events: all; }

    .props-panel {
        width: 100%; background-color: var(--paper, #FDFCF9);
        background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
        border-radius: 28px 28px 36px 36px; border-top: 1px solid rgba(123,160,138,0.18);
        box-shadow: 0 -12px 48px rgba(42,39,35,0.14);
        transform: translateY(100%); transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
        max-height: 82%; display: flex; flex-direction: column; overflow: hidden;
    }
    #props-overlay.open .props-panel { transform: translateY(0); }

    .props-band {
        height: 4px; border-radius: 28px 28px 0 0; flex-shrink: 0; opacity: 0.55;
        background: linear-gradient(90deg, var(--accent-light), var(--accent), var(--accent-light));
    }
    .props-header { padding: 0.6rem 1.8rem 1.1rem; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    .props-eyebrow {
        font-family: 'Inter', sans-serif; font-size: 9px; font-weight: 700;
        letter-spacing: 0.16em; text-transform: uppercase; color: rgba(42,39,35,0.28); margin-bottom: 0.2rem;
    }
    .props-title { font-family: 'EB Garamond', serif; font-size: 1.35rem; font-weight: 500; color: var(--ink, #2A2724); line-height: 1.2; }
    .props-close {
        width: 30px; height: 30px; border-radius: 50%; background: rgba(255,255,255,0.9);
        border: 1px solid rgba(42,39,35,0.10); display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: rgba(42,39,35,0.38); transition: all 0.2s; flex-shrink: 0;
    }

    .props-body { overflow-y: auto; padding: 1.2rem 1.8rem 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
    .prop-row { padding: 0.9rem 0.6rem; border-bottom: 1px solid rgba(42,39,35,0.05); }
    .prop-row.full-width { grid-column: 1 / -1; }
    .prop-row.row-span-2 { grid-row: span 2; border-bottom: none; }

    .prop-label {
        font-family: 'Inter', sans-serif; font-size: 8.5px; font-weight: 700;
        letter-spacing: 0.13em; text-transform: uppercase; color: rgba(42,39,35,0.30); margin-bottom: 0.4rem;
    }
    .prop-value { font-family: 'EB Garamond', serif; font-size: 1rem; color: rgba(42,39,35,0.78); line-height: 1.35; }
    .prop-value.italic-accent { color: var(--accent); font-style: italic; }
    .prop-value.handwriting { font-family: 'Reenie Beanie', cursive; font-size: 1.2rem; color: #A39985; line-height: 1.2; }

    .dot-rating { display: flex; gap: 5px; align-items: center; }
    .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-pale); border: 1.5px solid var(--accent-light); }
    .dot.filled { background: var(--accent); border-color: var(--accent); }

    .prop-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .prop-chip {
        display: inline-block; font-family: 'Inter', sans-serif; font-size: 8.5px; font-weight: 700;
        letter-spacing: 0.09em; text-transform: uppercase; padding: 4px 12px; border-radius: 8px;
        border: 1px solid rgba(42,39,35,0.08);
    }
    .prop-chip-neutral { background: rgba(42,39,35,0.08); color: rgba(42,39,35,0.55); }
    .prop-chip-accent  { background: var(--accent-pale); color: var(--accent); border-color: var(--accent-light); }
    .prop-concept-chip {
        display: inline-block; background: rgba(123,160,138,0.08); border: 1px solid rgba(123,160,138,0.22);
        color: var(--accent-dark); font-family: 'EB Garamond', serif; font-size: 0.88rem; padding: 4px 11px; border-radius: 9px;
    }
    .prop-pipeline-step { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.2rem; }
    .prop-pipeline-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .prop-pipeline-label { font-family: 'EB Garamond', serif; font-size: 0.9rem; }
</style>

<div id="note-modal">
    <div class="note-modal-inner">
        <button id="close-note-modal" class="modal-close">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>

        <div id="modal-note-bg-letter" class="modal-bg-letter"></div>

        <div class="note-modal-scroll">
            <header class="modal-title-block">
                <h2 id="modal-note-title" class="modal-title"></h2>
                <div id="modal-note-date" class="font-serif italic text-lg text-[#A39985] mt-2 opacity-80"></div>
            </header>

            <div class="modal-divider"></div>

            <div id="modal-note-body" class="modal-body-prose"></div>
        </div>

        <footer class="modal-footer-bar">
            <button id="open-props-btn" class="properties-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
                Note Properties
            </button>
        </footer>

        <!-- Properties Slide-up Panel -->
        <div id="props-overlay">
            <div class="props-panel">
                <div class="props-band"></div>
                <div class="props-header">
                    <div>
                        <p class="props-eyebrow">Properties</p>
                        <h3 id="props-title" class="props-title"></h3>
                    </div>
                    <button id="close-props-btn" class="props-close">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>
                <div id="props-body" class="props-body"></div>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        console.log('NoteModal system initializing...');
        function dots(n) {
            let h = '';
            for(let i=1; i<=3; i++) h += `<span class="dot${i <= n ? ' filled' : ''}"></span>`;
            return h;
        }
        function fmtDate(dStr) {
            const d = new Date(dStr);
            return d.toLocaleDateString('en-US', { month:'long', year:'numeric' });
        }

        function buildPropsPanel(d) {
            const body = document.getElementById('props-body');
            const titleEl = document.getElementById('props-title');
            const overlay = document.getElementById('props-overlay');
            if (!body || !titleEl || !overlay) return;

            body.innerHTML = '';
            titleEl.textContent = d.title;

            const pipeline = ['Raw', 'Refine', 'Metastasis / Converted'];
            const statusIdx = pipeline.indexOf(d.status);

            const rows = [
                {
                    label: 'Status',
                    html: `<div class="prop-pipeline">
                        ${pipeline.map((step, i) => {
                            const isCurrent = i === statusIdx;
                            const isPast    = i < statusIdx;
                            let dotStyle    = 'background:rgba(42,39,35,0.15);';
                            let labelCls    = 'color:rgba(42,39,35,0.35);';
                            if (isCurrent) {
                                if (d.status==='Raw')    { dotStyle='background:#B06A00;'; labelCls='color:#B06A00;font-weight:500;'; }
                                else if (d.status==='Refine') { dotStyle='background:var(--accent);'; labelCls='color:var(--accent);font-weight:500;'; }
                                else                          { dotStyle='background:#2E7D32;'; labelCls='color:#2E7D32;font-weight:500;'; }
                            } else if (isPast) {
                                dotStyle='background:var(--accent-light);';
                            }
                            return `<div class="prop-pipeline-step">
                                <span class="prop-pipeline-dot" style="${dotStyle}"></span>
                                <span class="prop-pipeline-label" style="${labelCls}">${step}</span>
                            </div>`;
                        }).join('')}
                    </div>`,
                    span2: true
                },
                { label: 'Rating',   html: `<div class="dot-rating">${dots(parseInt(d.rating)||0)}</div>` },
                { label: 'Date',     html: `<span class="prop-value handwriting">${fmtDate(d.date)}</span>` },
                { label: 'Note Type', html: (d.note_type || d.notetype) ? `<span class="prop-chip prop-chip-neutral">${d.note_type || d.notetype}</span>` : '<span class="prop-value">—</span>' },
                { label: 'Analytical Lens', html: (d.analytical_lens || d.lens) ? `<span class="prop-value italic-accent">${d.analytical_lens || d.lens}</span>` : '<span class="prop-value">—</span>' },
                { label: 'Discipline', html: (d.primary_discipline || d.discipline) ? `<span class="prop-value">${d.primary_discipline || d.discipline}</span>` : '<span class="prop-value">—</span>' },
                { label: 'Sub-discipline', html: (d.sub_discipline || d.subdiscipline) ? `<span class="prop-value">${d.sub_discipline || d.subdiscipline}</span>` : '<span class="prop-value">—</span>' },
                (d.tags) ? {
                    label: 'Tags',
                    html: `<div class="prop-chips">${(Array.isArray(d.tags) ? d.tags : d.tags.split(',')).map(t=>`<span class="prop-chip prop-chip-neutral">${t.trim()}</span>`).join(' ')}</div>`,
                    full: true
                } : null,
                (d.concepts_used || d.concepts) ? {
                    label: 'Concepts Used',
                    html: `<div class="prop-chips">${(function() {
                        const raw = d.concepts_used || d.concepts;
                        if (Array.isArray(raw)) return raw;
                        if (typeof raw === 'string' && raw.includes('||')) return raw.split('||');
                        return [raw];
                    })().map(c=>`<span class="prop-concept-chip">${c.trim()}</span>`).join(' ')}</div>`,
                    full: true
                } : null,
            ].filter(Boolean);

            rows.forEach(row => {
                const div = document.createElement('div');
                div.className = 'prop-row';
                if (row.full) div.classList.add('full-width');
                if (row.span2) div.classList.add('row-span-2');
                div.innerHTML = `<p class="prop-label">${row.label}</p><div>${row.html}</div>`;
                body.appendChild(div);
            });
            overlay.classList.add('open');
        }

        window.openNoteModal = function(id, notesSource, contentHtml) {
            const noteModal = document.getElementById('note-modal');
            if (!noteModal) return;

            const d = notesSource.find(n => n.id === id);
            if (!d) return;

            const titleEl = document.getElementById('modal-note-title');
            const bgLetterEl = document.getElementById('modal-note-bg-letter');
            const dateEl = document.getElementById('modal-note-date');
            const bodyEl = document.getElementById('modal-note-body');
            const propsBtn = document.getElementById('open-props-btn');

            if (titleEl) titleEl.textContent = d.title;
            if (bgLetterEl) bgLetterEl.textContent = d.title[0].toUpperCase();
            if (dateEl) dateEl.textContent = fmtDate(d.date);
            if (bodyEl) bodyEl.innerHTML = contentHtml || '';
            if (propsBtn) propsBtn.onclick = () => buildPropsPanel(d);
            
            noteModal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        };

        const hideNoteModal = () => {
            const noteModal = document.getElementById('note-modal');
            if (noteModal) noteModal.style.display = 'none';
            const propsOverlay = document.getElementById('props-overlay');
            if (propsOverlay) propsOverlay.classList.remove('open');
            document.body.style.overflow = '';
        };

        const closeBtn = document.getElementById('close-note-modal');
        if (closeBtn) closeBtn.onclick = hideNoteModal;

        const closePropsBtn = document.getElementById('close-props-btn');
        if (closePropsBtn) closePropsBtn.onclick = () => {
            const propsOverlay = document.getElementById('props-overlay');
            if (propsOverlay) propsOverlay.classList.remove('open');
        };

        document.addEventListener('click', (e) => {
            const noteModal = document.getElementById('note-modal');
            const propsOverlay = document.getElementById('props-overlay');
            if(e.target === noteModal) hideNoteModal();
            if(e.target === propsOverlay) propsOverlay.classList.remove('open');
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const propsOverlay = document.getElementById('props-overlay');
                if (propsOverlay && propsOverlay.classList.contains('open')) {
                    propsOverlay.classList.remove('open');
                } else {
                    hideNoteModal();
                }
            }
        });
    })();
</script>
