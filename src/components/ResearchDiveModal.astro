---
---
<style is:global>
    .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes slideUpScale { from { opacity: 0; transform: translateY(40px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
    @keyframes slideInRight { from { opacity: 0; transform: translateX(-40px); } to { opacity: 1; transform: translateX(0); } }
    .animate-modal-enter { opacity: 0; animation: slideUpScale 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s forwards; }
    .animate-content-enter { opacity: 0; animation: slideInRight 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) 0.15s forwards; }
    
    .ink-stain {
        background-color: #FDFCF9;
        background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png"), url("https://www.transparenttextures.com/patterns/natural-paper.png"), radial-gradient(circle at 10% 90%, rgba(42,39,36,0.03) 0%, rgba(253,252,249,0) 60%);
        background-position: 0px 0px, 40px 60px, 0 0;
        background-repeat: repeat, repeat, no-repeat;
    }
    .swoosh-path { stroke-dasharray: 100; stroke-dashoffset: 100; }
    @keyframes drawSwoosh { to { stroke-dashoffset: 0; } }

    #dive-modal .modal-scrollbar::-webkit-scrollbar { width: 4px; }
    #dive-modal .modal-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(42, 39, 36, 0.15); border-radius: 10px; }

    #dive-modal {
        position: fixed; inset: 0; z-index: 100;
        display: none; align-items: center; justify-content: center;
        padding: 2rem; background: rgba(42,39,35,0.25);
        backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px);
    }
    .dive-modal-inner {
        width: 100%; max-width: 900px; height: 85vh;
        background: white; border-radius: 40px; overflow: hidden;
        border: 1px solid rgba(255,255,255,0.6);
        box-shadow: 0 40px 100px rgba(42,39,36,0.15);
        position: relative; ring: 1px ring-[#D5CCB6]/30;
        display: flex; flex-direction: column;
    }

    .modal-footer-bar {
        padding: 1rem 2.5rem 1.5rem;
        border-top: 1px solid rgba(180,188,192,0.15);
        display: flex; align-items: center; justify-content: space-between;
        background: rgba(253,252,249,0.8);
        backdrop-blur: 8px; flex-shrink: 0;
    }

    .properties-btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 700;
        letter-spacing: 0.14em; text-transform: uppercase;
        color: rgba(42,39,35,0.45); background: transparent;
        border: 1.5px solid rgba(42,39,35,0.12); border-radius: 100px;
        padding: 7px 16px; cursor: pointer; transition: all 0.2s ease;
    }
    .properties-btn:hover { color: #B4BCC0; border-color: rgba(180,188,192,0.4); background: rgba(180,188,192,0.05); }

    #dive-props-overlay {
        position: absolute; inset: 0; z-index: 120;
        display: flex; align-items: flex-end; justify-content: stretch;
        background: rgba(42,39,35,0.18); backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px); border-radius: 40px;
        overflow: hidden; opacity: 0; pointer-events: none; transition: opacity 0.25s ease;
    }
    #dive-props-overlay.open { opacity: 1; pointer-events: all; }
    
    .dive-props-panel {
        width: 100%; background: #FDFCF9;
        background-image: url("https://www.transparenttextures.com/patterns/natural-paper.png");
        border-radius: 28px 28px 40px 40px; border-top: 1px solid rgba(180,188,192,0.2);
        box-shadow: 0 -12px 48px rgba(42,39,35,0.14);
        transform: translateY(100%); transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
        max-height: 85%; display: flex; flex-direction: column; overflow: hidden;
    }
    #dive-props-overlay.open .dive-props-panel { transform: translateY(0); }

    .dive-props-band {
        height: 4px; border-radius: 28px 28px 0 0; flex-shrink: 0; opacity: 0.55;
        background: linear-gradient(90deg, #D5CCB6, #B4BCC0, #D5CCB6);
    }
    .dive-props-header { padding: 1.2rem 2rem 1.1rem; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    .dive-props-eyebrow {
        font-family: 'Inter', sans-serif; font-size: 9px; font-weight: 700;
        letter-spacing: 0.16em; text-transform: uppercase; color: rgba(42,39,35,0.28); margin-bottom: 0.2rem;
    }
    .dive-props-title { font-family: 'EB Garamond', serif; font-size: 1.35rem; font-weight: 500; color: #2A2724; line-height: 1.2; }
    .dive-props-close {
        width: 32px; height: 32px; border-radius: 50%; background: white;
        border: 1px solid rgba(42,39,35,0.10); display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: rgba(42,39,35,0.38); transition: all 0.2s; flex-shrink: 0;
    }
    .dive-props-close:hover { background: #F5F2EB; color: #B4BCC0; }

    .dive-props-body { overflow-y: auto; padding: 1.2rem 2rem 2.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
    .dive-prop-row { padding: 1rem 0.6rem; border-bottom: 1px solid rgba(42,39,35,0.05); }
    .dive-prop-row.full-width { grid-column: 1 / -1; }

    .dive-prop-label {
        font-family: 'Inter', sans-serif; font-size: 9px; font-weight: 700;
        letter-spacing: 0.13em; text-transform: uppercase; color: rgba(42,39,35,0.30); margin-bottom: 0.5rem;
    }
    .dive-prop-value { font-family: 'EB Garamond', serif; font-size: 1.05rem; color: rgba(42,39,35,0.78); line-height: 1.4; }
    .dive-prop-value.italic-accent { color: #8C8C8C; font-style: italic; }
    
    .dot-rating { display: flex; gap: 5px; align-items: center; }
    .dot { width: 8px; height: 8px; border-radius: 50%; background: #F5F2EB; border: 1.5px solid #D5CCB6; }
    .dot.filled { background: #B4BCC0; border-color: #B4BCC0; }

    .dive-prop-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .dive-prop-chip {
        display: inline-block; font-family: 'Inter', sans-serif; font-size: 9px; font-weight: 700;
        letter-spacing: 0.09em; text-transform: uppercase; padding: 4px 12px; border-radius: 8px;
        background: rgba(42,39,35,0.06); color: rgba(42,39,35,0.5); border: 1px solid rgba(42,39,35,0.08);
    }

    #dive-modal strong, 
    #dive-modal b {
        color: #8C8C8C !important;
        font-weight: 600 !important;
    }

    #modal-dive-body h2 {
        font-family: 'EB Garamond', serif; font-size: 1.8rem; font-weight: 500; color: #111827;
        margin-top: 50px; margin-bottom: 20px; padding-bottom: 14px;
        border-bottom: 1.5px solid #E6DFD1; line-height: 1.1;
    }
    #modal-dive-body h3 {
        font-family: 'EB Garamond', serif; font-size: 1.6rem; font-weight: 500; color: #111827;
        margin-top: 32px; margin-bottom: 16px; padding-bottom: 10px;
        border-bottom: 1px solid rgba(230,223,209,0.7); line-height: 1.2;
    }
    #modal-dive-body h4 {
        font-family: 'EB Garamond', serif; font-size: 1.3rem; font-weight: 500; color: #111827;
        margin-top: 18px; margin-bottom: 10px; padding-bottom: 8px;
        border-bottom: 1px solid rgba(230,223,209,0.4); line-height: 1.2;
    }
    #modal-dive-body h3 + h4 { margin-top: 8px; }

    #modal-dive-body p { margin-bottom: 22px; }
    #modal-dive-body li p { margin-bottom: 0; }
    #modal-dive-body p:last-child { margin-bottom: 0; }

    #modal-dive-body ul {
        list-style-type: disc; padding-left: 1.5rem;
        margin-top: 0.5rem; margin-bottom: 1.25rem;
    }
    #modal-dive-body ol {
        list-style-type: decimal; padding-left: 1.5rem;
        margin-top: 0.5rem; margin-bottom: 1.25rem;
    }
    #modal-dive-body li {
        margin-bottom: 0.15rem !important;
        padding-left: 0.5rem; line-height: 1.6;
    }
    #modal-dive-body li::marker { color: #B4BCC0; font-weight: 700; }
</style>

<div id="dive-modal">
    <div class="dive-modal-inner animate-modal-enter">
        <div class="flex-1 flex flex-col relative bg-[#FDFCF9] ink-stain overflow-y-auto modal-scrollbar z-10 p-6 md:p-12 lg:p-16">
            <button id="close-dive-modal-btn" class="absolute top-8 right-8 w-12 h-12 rounded-full bg-white/80 backdrop-blur-md border border-[#D5CCB6] shadow-sm hover:bg-white flex items-center justify-center text-[#2A2724] transition-all group z-[60]">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 opacity-60 group-hover:opacity-100 group-hover:rotate-90 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <div class="relative animate-content-enter">
                <div id="modal-dive-bg-letter" class="absolute top-0 right-0 text-[24rem] font-serif font-bold text-[#2A2724]/[0.015] leading-none pointer-events-none select-none -z-10 -rotate-3"></div>

                <div class="mb-14 text-center flex flex-col items-center">
                    <div id="modal-dive-stars" class="flex gap-1 text-[#B4BCC0] mb-6"></div>
                    <p id="modal-dive-source" class="font-sans text-xs font-bold uppercase tracking-[0.2em] text-[#B4BCC0] opacity-80 mb-2"></p>
                    <h1 class="font-serif text-4xl md:text-5xl lg:text-[4.5rem] font-medium text-[#2A2724] leading-tight mb-8 tracking-tight relative inline-block mx-auto">
                        <span id="modal-dive-title" class="inline"></span>
                        <svg id="modal-dive-underline" class="absolute h-[12px] text-[#B4BCC0] opacity-70 overflow-visible pointer-events-none" viewBox="0 0 100 10" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display: none;">
                            <path d="M0,8 C25,12 75,4 100,8" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="swoosh-path"></path>
                        </svg>
                    </h1>
                    <div class="max-w-3xl mx-auto">
                        <div id="modal-dive-summary" class="font-serif text-[1.25rem] md:text-[1.4rem] leading-relaxed text-[#2A2724]"></div>
                    </div>
                </div>

                <div id="modal-dive-body" class="font-serif text-xl md:text-[1.45rem] leading-[1.85] text-[#2A2724]/85 max-w-[900px] z-10 relative mb-20"></div>
            </div>
        </div>

        <footer class="modal-footer-bar">
            <button id="open-dive-props-btn" class="properties-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
                Dive Properties
            </button>
        </footer>

        <div id="dive-props-overlay">
            <div class="dive-props-panel">
                <div class="dive-props-band"></div>
                <div class="dive-props-header">
                    <div>
                        <p class="dive-props-eyebrow">Properties</p>
                        <h3 id="dive-props-title" class="dive-props-title"></h3>
                    </div>
                    <button id="close-dive-props-btn" class="dive-props-close">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>
                <div id="dive-props-body" class="dive-props-body"></div>
            </div>
        </div>
    </div>
</div>

<script is:inline>
    (function() {
        function dots(n) {
            let h = '';
            for(let i=1; i<=3; i++) h += `<span class="dot${i <= n ? ' filled' : ''}"></span>`;
            return h;
        }

        function buildDiveProps(d) {
            const body = document.getElementById('dive-props-body');
            const title = document.getElementById('dive-props-title');
            body.innerHTML = '';
            title.textContent = d.title;

            const rows = [
                { label: 'Rating', html: `<div class="dot-rating">${dots(parseInt(d.rating)||0)}</div>` },
                { label: 'Date', html: `<span class="dive-prop-value italic-accent">${new Date(d.date).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric'})}</span>` },
                { label: 'Target / Subject', html: `<span class="dive-prop-value">${d.source || 'General Research'}</span>` },
                { 
                    label: 'Tags', 
                    html: (d.tags) ? `<div class="dive-prop-chips">${(Array.isArray(d.tags) ? d.tags : d.tags.split(',')).map(t => `<span class="dive-prop-chip">${t.trim()}</span>`).join('')}</div>` : '<span class="dive-prop-value">—</span>',
                    full: true 
                }
            ];

            rows.forEach(row => {
                const div = document.createElement('div');
                div.className = 'dive-prop-row';
                if (row.full) div.classList.add('full-width');
                div.innerHTML = `<p class="dive-prop-label">${row.label}</p><div>${row.html}</div>`;
                body.appendChild(div);
            });
            document.getElementById('dive-props-overlay').classList.add('open');
        }

        window.openResearchDiveModal = function(id, source, bodyHtml) {
            const modal = document.getElementById('dive-modal');
            const d = source.find(c => c.id === id);
            if (!d) return;

            document.getElementById('modal-dive-title').textContent = d.title;
            document.getElementById('modal-dive-bg-letter').textContent = d.title[0].toUpperCase();
            document.getElementById('modal-dive-source').textContent = d.source || 'General Research';
            
            const starHtml = Array.from({ length: parseInt(d.rating) || 0 }).map((_, i) => 
                `<svg width="22" height="22" viewBox="0 0 24 24" fill="#B4BCC0" fill-opacity="0.3" stroke="#B4BCC0" stroke-width="2" stroke-linejoin="round" style="transform: rotate(${(i % 2 === 0 ? 10 : -10)}deg)"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>`
            ).join('');
            document.getElementById('modal-dive-stars').innerHTML = starHtml;
            
            document.getElementById('modal-dive-summary').innerHTML = (d.summary || d.description || '').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            document.getElementById('modal-dive-body').innerHTML = bodyHtml || '';

            document.getElementById('open-dive-props-btn').onclick = () => buildDiveProps(d);

            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';

            // Underline
            const titleEl = document.getElementById('modal-dive-title');
            const underline = document.getElementById('modal-dive-underline');
            requestAnimationFrame(() => {
                const rects = titleEl.getClientRects();
                const containerRect = titleEl.parentElement.getBoundingClientRect();
                if (rects.length > 0) {
                    const r = rects[0];
                    underline.style.width = (r.width * 1.05) + 'px';
                    underline.style.top = (r.bottom - containerRect.top - (r.height * 0.12)) + 'px';
                    underline.style.left = (r.left - containerRect.left - (r.width * 0.025)) + 'px';
                    underline.style.display = 'block';
                    const path = underline.querySelector('path');
                    if (path) { path.style.animation = 'none'; void path.offsetWidth; path.style.animation = 'drawSwoosh 0.8s ease-out 0.4s forwards'; }
                }
            });
        };

        const hide = () => {
            document.getElementById('dive-modal').style.display = 'none';
            document.getElementById('dive-props-overlay').classList.remove('open');
            document.body.style.overflow = '';
        };

        document.getElementById('close-dive-modal-btn').onclick = hide;
        document.getElementById('close-dive-props-btn').onclick = () => document.getElementById('dive-props-overlay').classList.remove('open');
        document.getElementById('dive-modal').onclick = e => { if(e.target === document.getElementById('dive-modal')) hide(); };
        document.getElementById('dive-props-overlay').onclick = e => { if(e.target === document.getElementById('dive-props-overlay')) document.getElementById('dive-props-overlay').classList.remove('open'); };
    })();
</script>
